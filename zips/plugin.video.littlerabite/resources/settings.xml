        </setting>
        
        <!-- Hidden token storage -->
        <setting id="simkl_access_token" type="text" default="" visible="false">
            <level>3</level>
        </setting>
        
        <!-- Show username (read-only) -->
        <setting id="simkl_username" type="text" label="Logged in as" default="" enable="false">
            <level>0</level>
        </setting>
        
        <setting id="simkl_user_id" type="text" default="" visible="false">
            <level>3</level>
        </setting>
        
        <setting id="simkl_info" type="label" label="Simkl syncs anime from your watching lists">
            <level>0</level>
        </setting>
    </category>
    
    <!-- Advanced Settings -->
    <category label="30500">
        <setting id="advanced_header" label="30501" type="lsep"/>
        
        <setting id="debug_logging" type="bool" label="Enable Debug Logging" default="false">
            <level>1</level>
        </setting>
        
        <setting id="clear_header" label="Database Management" type="lsep"/>
        
        <setting id="clear_database" type="action" label="Clear Database">
            <level>1</level>
            <data>RunPlugin(plugin://plugin.video.littlerabite/?action=clear_database)</data>
        </setting>
        
        <setting id="clear_sync_queue" type="action" label="Clear pending sync operations">
            <level>1</level>
            <data>RunPlugin(plugin://plugin.video.littlerabite/?action=clear_sync_queue)</data>
        </setting>
        
        <setting id="database_path" type="text" label="Database Path" default="" enable="false">
            <level>1</level>
        </setting>
    </category>
</settings>
