            <level>0</level>
        </setting>
        
        <setting id="anilist_authenticate" type="action" label="Authenticate with AniList" enable="eq(-1,true)">
            <level>0</level>
            <data>RunPlugin(plugin://plugin.video.littlerabite/?action=anilist_auth)</data>
        </setting>
        
        <setting id="anilist_sync" type="action" label="Sync Now" enable="eq(-2,true)">
            <level>0</level>
            <data>RunPlugin(plugin://plugin.video.littlerabite/?action=anilist_sync)</data>
        </setting>
        
        <setting id="anilist_logout" type="action" label="Logout" enable="eq(-3,true)">
            <level>0</level>
            <data>RunPlugin(plugin://plugin.video.littlerabite/?action=anilist_logout)</data>
        </setting>
        
        <!-- Hidden token storage -->
        <setting id="anilist_access_token" type="text" default="" visible="false">
            <level>3</level>
        </setting>
        
        <!-- Show username (read-only) -->
        <setting id="anilist_username" type="text" label="Logged in as" default="" enable="false">
            <level>0</level>
        </setting>
        
        <setting id="anilist_user_id" type="text" default="" visible="false">
            <level>3</level>
        </setting>
        
        <setting id="anilist_info" type="label" label="AniList syncs anime from your watching lists">
            <level>0</level>
        </setting>
    </category>
    
    <!-- Account: Simkl -->
    <category label="Account: Simkl">
        <setting id="simkl_header" label="Simkl Configuration" type="lsep"/>
        
        <setting id="simkl_enabled" type="bool" label="Enable Simkl" default="false">
            <level>0</level>
        </setting>
        
        <setting id="simkl_authenticate" type="action" label="Authenticate with Simkl" enable="eq(-1,true)">
            <level>0</level>
            <data>RunPlugin(plugin://plugin.video.littlerabite/?action=simkl_auth)</data>
        </setting>
        
        <setting id="simkl_sync" type="action" label="Sync Now" enable="eq(-2,true)">
            <level>0</level>
            <data>RunPlugin(plugin://plugin.video.littlerabite/?action=simkl_sync)</data>
        </setting>
        
        <setting id="simkl_logout" type="action" label="Logout" enable="eq(-3,true)">
            <level>0</level>
