<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings>
    <!-- General Settings -->
    <category label="30100">
        <setting id="general_header" label="30101" type="lsep"/>
        
        <!-- Sync Interval -->
        <setting id="sync_interval" type="slider" label="30102" default="60">
            <level>0</level>
            <constraints>
                <minimum>5</minimum>
                <step>5</step>
                <maximum>180</maximum>
            </constraints>
        </setting>
        
        <setting id="auto_sync_enabled" type="bool" label="Enable automatic background sync" default="true">
            <level>0</level>
        </setting>
        
        <setting id="show_notifications" type="bool" label="Show Notifications" default="true">
            <level>0</level>
        </setting>
        
        <setting id="show_sync_notifications" type="bool" label="Display notifications for sync operations" default="false">
            <level>0</level>
        </setting>
    </category>
    
    <!-- Account: Trakt -->
    <category label="Account: Trakt">
        <setting id="trakt_header" label="Trakt Configuration" type="lsep"/>
        
        <setting id="trakt_enabled" type="bool" label="Enable Trakt" default="true">
            <level>0</level>
        </setting>
        
        <setting id="trakt_authenticate" type="action" label="Authenticate with Trakt" enable="eq(-1,true)">
            <level>0</level>
            <data>RunPlugin(plugin://plugin.video.littlerabite/?action=trakt_auth)</data>
        </setting>
        
        <setting id="trakt_sync" type="action" label="Sync Now" enable="eq(-2,true)">
            <level>0</level>
            <data>RunPlugin(plugin://plugin.video.littlerabite/?action=trakt_sync)</data>
        </setting>
        
        <setting id="trakt_logout" type="action" label="Logout" enable="eq(-3,true)">
            <level>0</level>
            <data>RunPlugin(plugin://plugin.video.littlerabite/?action=trakt_logout)</data>
        </setting>
        
        <!-- Hidden token storage -->
        <setting id="trakt_access_token" type="text" default="" visible="false">
            <level>3</level>
        </setting>
        
        <setting id="trakt_refresh_token" type="text" default="" visible="false">
            <level>3</level>
        </setting>
        
        <setting id="trakt_expires_at" type="text" default="" visible="false">
            <level>3</level>
        </setting>
        
        <!-- Show username (read-only) -->
        <setting id="trakt_username" type="text" label="Logged in as" default="" enable="false">
            <level>0</level>
        </setting>
        
        <setting id="trakt_user_id" type="text" default="" visible="false">
            <level>3</level>
        </setting>
    </category>
    
    <!-- Account: AniList -->
    <category label="Account: AniList">
