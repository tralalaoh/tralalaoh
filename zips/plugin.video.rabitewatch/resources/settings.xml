<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!--  GENERAL                                                -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <category label="32100">

        <!-- Sync -->
        <setting id="sync_on_startup"    type="bool"   label="32111" default="true"/>
        <setting id="startup_pull_limit" type="slider" label="32130" default="5"
                  range="1,1,50" option="int"
                  enable="eq(-1,true)" subsetting="true"/>
        <setting id="sync_interval"      type="slider" label="32112" default="15"
                  range="0,5,120" option="int"/>
        <setting id="sync_now"        type="action" label="32113"
                  action="RunPlugin(plugin://plugin.video.rabitewatch/?action=sync_all)"/>

        <setting type="sep"/>

        <!-- Continue Watching -->
        <setting id="continue_watching_limit"  type="slider" label="32121"
                  default="25" range="5,5,200" option="int"/>
        <setting id="hide_completed"           type="bool"   label="32122" default="true"/>
        <setting id="resume_threshold"         type="slider" label="32123"
                  default="95" range="80,5,100" option="int"
                  enable="eq(-1,true)"/>
        <setting id="continue_watching_source" type="enum"   label="32124"
                  lvalues="32125|32126|32127|32128" default="0"/>
        <setting id="simkl_include_in_cw"     type="bool"   label="32129" default="false"/>

    </category>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!--  SERVICES + METADATA                                    -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <category label="32300">

        <!-- Trakt -->
        <setting id="trakt_enabled"          type="bool"   label="32311" default="true"/>
        <setting id="trakt_use_for_metadata" type="bool"   label="32312" default="true"
                  enable="eq(-1,true)" subsetting="true"/>

        <setting type="sep"/>

        <!-- AniList -->
        <setting id="anilist_enabled"          type="bool"   label="32321" default="true"/>
        <setting id="anilist_use_for_metadata" type="bool"   label="32322" default="true"
                  enable="eq(-1,true)" subsetting="true"/>

        <setting type="sep"/>

        <!-- Simkl -->
        <setting id="simkl_enabled"          type="bool"   label="32331" default="true"/>
        <setting id="simkl_use_for_metadata" type="bool"   label="32332" default="true"
                  enable="eq(-1,true)" subsetting="true"/>

        <setting type="sep"/>

        <!-- TMDB Enrichment -->
        <setting id="tmdb_enrichment_enabled" type="bool"   label="32211" default="true"/>
        <setting id="tmdb_api_key"            type="text"   label="32212" default=""
                  option="hidden"
                  enable="eq(-1,true)" subsetting="true"/>
        <setting id="tmdb_fetch_clearlogo"    type="bool"   label="32213" default="true"
                  enable="eq(-2,true)" subsetting="true"/>
        <setting id="tmdb_fetch_plot"         type="bool"   label="32214" default="true"
                  enable="eq(-3,true)" subsetting="true"/>
        <setting id="tmdb_fetch_runtime"      type="bool"   label="32215" default="true"
                  enable="eq(-4,true)" subsetting="true"/>

    </category>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!--  ADVANCED                                               -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <category label="32400">

        <setting id="debug_logging"  type="bool"   label="32411" default="false"/>
        <setting id="clear_database" type="action" label="32421"
                  action="RunPlugin(plugin://plugin.video.rabitewatch/?action=clear_db)"/>

    </category>

</settings>
