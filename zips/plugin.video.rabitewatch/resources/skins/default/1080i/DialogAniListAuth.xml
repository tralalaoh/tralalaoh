                    <posx>86</posx>
                    <posy>13</posy>
                    <width>900</width>
                    <height>34</height>
                    <font>font20</font>
                    <textcolor>FFE8F4FF</textcolor>
                    <label>Connect AniList</label>
                    <align>left</align>
                    <aligny>center</aligny>
                </control>

                <!-- Subtitle -->
                <control type="label">
                    <posx>86</posx>
                    <posy>47</posy>
                    <width>900</width>
                    <height>26</height>
                    <font>font12</font>
                    <textcolor>FF4A6580</textcolor>
                    <label>RABITE WATCH · ANILIST AUTHENTICATION</label>
                    <align>left</align>
                </control>

                <!-- Header bottom border -->
                <control type="image">
                    <posx>0</posx>
                    <posy>79</posy>
                    <width>1480</width>
                    <height>1</height>
                    <texture colordiffuse="55102030">special://home/addons/plugin.video.rabitewatch/media/white.png</texture>
                    <aspectratio>stretch</aspectratio>
                </control>
            </control>
