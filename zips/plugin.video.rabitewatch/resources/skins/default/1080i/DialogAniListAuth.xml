                    <posy>22</posy>
                    <width>28</width>
                    <height>3</height>
                    <texture colordiffuse="FF02A9FF">special://home/addons/plugin.video.rabitewatch/media/white.png</texture>
                    <aspectratio>stretch</aspectratio>
                </control>
                <control type="image">
                    <posx>529</posx>
                    <posy>22</posy>
                    <width>3</width>
                    <height>28</height>
