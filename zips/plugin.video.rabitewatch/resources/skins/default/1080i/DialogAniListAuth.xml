<?xml version="1.0" encoding="UTF-8"?>
<!--
    Rabite Watch — AniList Authentication Dialog
    =============================================
    File   : resources/skins/Default/1080i/DialogAniListAuth.xml
    Window : type="dialog"   (floats above the current screen)

    Layout (1920 × 1080 reference resolution)
    ─────────────────────────────────────────────────────────────────────
    ┌─────────────────────────────────────────────────────────────────┐
    │  HEADER — icon + "Connect AniList" title                        │
    ├──────────────────────────────────┬──────────────────────────────┤
    │  LEFT — step-by-step             │  RIGHT — QR code image       │
    │  instructions                    │                              │
    │                                  │                              │
    ├──────────────────────────────────┴──────────────────────────────┤
    │  STATUS label (feedback / error messages)                       │
    ├─────────────────────────────────────────────────────────────────┤
    │  [  Enter Token  ]                           [  Cancel  ]       │
    └─────────────────────────────────────────────────────────────────┘

    Control ID map (must match _AniListWindowDialog constants in services/anilist.py):
        100  image   QR code
        200  label   status / feedback
        300  button  Enter Token
        301  button  Cancel

    Navigation map:
        Enter Token  ←→  Cancel   (left/right)
        Both buttons go up to themselves (no other focusable controls above)
-->
<window type="dialog">

    <!-- Default focused control when the dialog opens -->
    <defaultcontrol always="true">300</defaultcontrol>

    <controls>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!--  BACKGROUND SCRIM — darkens whatever is behind the dialog -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <control type="image">
            <posx>0</posx>
            <posy>0</posy>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="BB000000">special://home/addons/plugin.video.rabitewatch/media/white.png</texture>
            <aspectratio>stretch</aspectratio>
        </control>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!--  DIALOG PANEL  — centred, 1480 × 720                     -->
        <!--  posx = (1920 − 1480) / 2 = 220                          -->
        <!--  posy = (1080 −  720) / 2 = 180                          -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <control type="group">
            <posx>220</posx>
            <posy>180</posy>
            <width>1480</width>
            <height>720</height>

            <!-- ── Panel background ── -->
            <control type="image">
                <posx>0</posx>
                <posy>0</posy>
                <width>1480</width>
                <height>720</height>
                <texture colordiffuse="F20D1B2E">special://home/addons/plugin.video.rabitewatch/media/white.png</texture>
                <aspectratio>stretch</aspectratio>
            </control>

            <!-- ── Top accent bar (AniList blue #02A9FF) ── -->
            <control type="image">
                <posx>0</posx>
                <posy>0</posy>
                <width>1480</width>
                <height>4</height>
                <texture colordiffuse="FF02A9FF">special://home/addons/plugin.video.rabitewatch/media/white.png</texture>
                <aspectratio>stretch</aspectratio>
            </control>

            <!-- ── Outer border ── -->
            <control type="image">
                <posx>0</posx>
                <posy>0</posy>
                <width>1480</width>
                <height>720</height>
                <texture border="1" colordiffuse="55102030">special://home/addons/plugin.video.rabitewatch/media/white.png</texture>
                <aspectratio>stretch</aspectratio>
            </control>


            <!-- ══════════════════════════════════════════════════════ -->
            <!--  HEADER  (y: 4 → 84, h: 80)                          -->
            <!-- ══════════════════════════════════════════════════════ -->
            <control type="group">
                <posx>0</posx>
                <posy>4</posy>
                <width>1480</width>
                <height>80</height>

                <!-- Header tinted background -->
                <control type="image">
                    <posx>0</posx>
                    <posy>0</posy>
                    <width>1480</width>
                    <height>80</height>
                    <texture colordiffuse="20FFFFFF">special://home/addons/plugin.video.rabitewatch/media/white.png</texture>
                    <aspectratio>stretch</aspectratio>
                </control>

                <!-- AniList service icon -->
                <control type="image">
                    <posx>24</posx>
                    <posy>16</posy>
                    <width>48</width>
                    <height>48</height>
