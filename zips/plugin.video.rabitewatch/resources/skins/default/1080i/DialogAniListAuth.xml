                        <align>left</align>
                        <wrapmultiline>true</wrapmultiline>
                    </control>
                </control>

                <!-- Step 4 -->
                <control type="group">
                    <posx>0</posx>
                    <posy>326</posy>
                    <width>784</width>
                    <height>90</height>

                    <control type="image">
                        <posx>0</posx>
                        <posy>0</posy>
                        <width>32</width>
                        <height>32</height>
                        <texture colordiffuse="3002A9FF">special://home/addons/plugin.video.rabitewatch/media/white.png</texture>
                        <aspectratio>stretch</aspectratio>
                    </control>
                    <control type="label">
                        <posx>0</posx>
                        <posy>0</posy>
                        <width>32</width>
                        <height>32</height>
                        <font>font13</font>
                        <textcolor>FF02A9FF</textcolor>
                        <label>4</label>
                        <align>center</align>
                        <aligny>center</aligny>
                    </control>

                    <control type="label">
                        <posx>48</posx>
                        <posy>0</posy>
                        <width>736</width>
                        <height>26</height>
                        <font>font16</font>
                        <textcolor>FFD0E4F8</textcolor>
                        <label>Press "Enter Token" and paste it here</label>
                        <align>left</align>
                    </control>
                    <control type="label">
                        <posx>48</posx>
                        <posy>28</posy>
                        <width>736</width>
                        <height>56</height>
                        <font>font12</font>
                        <textcolor>FF4A6580</textcolor>
                        <label>Use Kore, a Bluetooth keyboard, or the on-screen keyboard to paste your token and confirm.</label>
                        <align>left</align>
                        <wrapmultiline>true</wrapmultiline>
                    </control>
                </control>

                <!-- Manual URL hint -->
                <control type="label">
                    <posx>0</posx>
                    <posy>430</posy>
                    <width>784</width>
                    <height>26</height>
                    <font>font12</font>
                    <textcolor>FF2A4560</textcolor>
                    <label>No QR scanner? Visit: anilist.co/api/v2/oauth/authorize?client_id=35064&amp;response_type=token</label>
                    <align>left</align>
                    <wrapmultiline>true</wrapmultiline>
                </control>

            </control>
            <!-- /LEFT -->


            <!-- ── Vertical divider ── -->
            <control type="image">
                <posx>826</posx>
                <posy>84</posy>
                <width>1</width>
                <height>546</height>
                <texture colordiffuse="55102030">special://home/addons/plugin.video.rabitewatch/media/white.png</texture>
                <aspectratio>stretch</aspectratio>
            </control>


            <!-- ── RIGHT — QR Code ── -->
            <control type="group">
                <posx>850</posx>
                <posy>100</posy>
                <width>606</width>
                <height>510</height>

                <!-- Section heading -->
                <control type="label">
                    <posx>0</posx>
                    <posy>0</posy>
                    <width>606</width>
                    <height>22</height>
                    <font>font12</font>
                    <textcolor>FF4A6580</textcolor>
                    <label>SCAN TO AUTHORIZE</label>
                    <align>center</align>
                </control>

                <!-- White background behind QR (QR codes need white bg) -->
                <control type="image">
                    <posx>90</posx>
                    <posy>36</posy>
                    <width>428</width>
                    <height>428</height>
                    <texture colordiffuse="FFFFFFFF">special://home/addons/plugin.video.rabitewatch/media/white.png</texture>
                    <aspectratio>stretch</aspectratio>
                </control>

                <!-- QR code image — ID 100, set at runtime via setImage() -->
                <control type="image" id="100">
                    <posx>102</posx>
                    <posy>48</posy>
                    <width>404</width>
                    <height>404</height>
                    <!-- Default texture shown before onInit() fires.     -->
                    <!-- Replaced immediately by Python with the real PNG. -->
                    <texture>special://home/addons/plugin.video.rabitewatch/media/anilist.png</texture>
                    <aspectratio>keep</aspectratio>
                </control>

                <!-- Blue corner bracket — Top Left -->
                <control type="image">
                    <posx>76</posx>
                    <posy>22</posy>
                    <width>28</width>
                    <height>3</height>
                    <texture colordiffuse="FF02A9FF">special://home/addons/plugin.video.rabitewatch/media/white.png</texture>
                    <aspectratio>stretch</aspectratio>
                </control>
                <control type="image">
                    <posx>76</posx>
                    <posy>22</posy>
