<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog">
    <defaultcontrol always="true">200</defaultcontrol>
    <controls>

        <!-- ══════════════════════════════════════════════════════════
             Backdrop: click outside the panel to dismiss
        ══════════════════════════════════════════════════════════ -->
        <control type="button">
            <left>0</left><top>0</top>
            <width>1920</width><height>1080</height>
            <texturefocus /><texturenofocus /><label></label>
            <onclick>Action(close)</onclick>
        </control>

        <!-- ══════════════════════════════════════════════════════════
             Main dialog frame  1500 × 900  centred in 1920×1080
        ══════════════════════════════════════════════════════════ -->
        <control type="group">
            <centerleft>50%</centerleft>
            <centertop>50%</centertop>
            <width>1500</width>
            <height>900</height>

            <!-- Background panel -->
            <control type="image">
                <left>0</left><top>0</top>
                <width>1500</width><height>900</height>
                <texture diffuse="special://skin/media/masks/dialog-bg-large.png">special://skin/media/dialogs/dialog-gradient.png</texture>
            </control>

            <!-- ── HEADER ROW  (y 0–90) ──────────────────────────────── -->

            <!-- Dialog title -->
            <control type="label">
                <left>30</left><top>0</top>
                <width>560</width><height>90</height>
                <font>font32_title</font>
                <label>Choose Icon</label>
                <textcolor>FFFFFFFF</textcolor>
                <shadowcolor>black</shadowcolor>
                <aligny>center</aligny>
            </control>

            <!-- ── Search box: rounded-rectangle input style ───────── -->
            <!--
                Background layer: squarish mask over semi-transparent white
                gives a modern rounded-rectangle input field look.
            -->
            <control type="image">
                <left>602</left><top>18</top>
                <width>454</width><height>52</height>
                <texture diffuse="special://skin/media/masks/dialog-bg-squareish.png" colordiffuse="18FFFFFF">special://skin/media/colors/white.png</texture>
            </control>

            <!-- Search magnifier icon -->
            <control type="image">
                <left>614</left><top>30</top>
                <width>24</width><height>24</height>
                <aspectratio>keep</aspectratio>
                <texture colordiffuse="66FFFFFF">special://skin/media/icons/search.png</texture>
            </control>

            <!-- Search button (click area + focus highlight)  id=300 -->
            <control type="button" id="300">
                <left>602</left><top>18</top>
                <width>454</width><height>52</height>
                <label>[COLOR grey]Search icons...[/COLOR]</label>
                <font>font25_title</font>
                <align>left</align>
                <aligny>center</aligny>
                <textoffsetx>38</textoffsetx>
                <textcolor>CCFFFFFF</textcolor>
                <focusedcolor>FFFFFFFF</focusedcolor>
                <!-- Focus adds a brighter overlay — same squarish shape -->
                <texturefocus diffuse="special://skin/media/masks/dialog-bg-squareish.png" colordiffuse="2CFFFFFF">special://skin/media/colors/white.png</texturefocus>
                <texturenofocus />
                <ondown>400</ondown>
            </control>

            <!-- Clear search button  id=301 -->
            <control type="button" id="301">
                <left>1060</left><top>23</top>
                <width>40</width><height>40</height>
                <texturefocus colordiffuse="CCFFFFFF">special://skin/media/dialogs/close.png</texturefocus>
                <texturenofocus colordiffuse="3CFFFFFF">special://skin/media/dialogs/close.png</texturenofocus>
                <label></label>
                <ondown>401</ondown>
            </control>

            <!-- Browse filesystem button  id=500 -->
            <control type="button" id="500">
                <left>1114</left><top>18</top>
                <width>172</width><height>52</height>
                <label>Browse...</label>
                <font>font25_title</font>
                <align>center</align>
                <textcolor>unfocused_text</textcolor>
                <focusedcolor>FFFFFFFF</focusedcolor>
                <texturefocus colordiffuse="button_focus">special://skin/media/buttons/dialog-btn.png</texturefocus>
                <texturenofocus colordiffuse="14FFFFFF">special://skin/media/buttons/dialog-btn.png</texturenofocus>
                <ondown>402</ondown>
            </control>

            <!-- Close X button -->
            <control type="button">
                <left>1432</left><top>18</top>
                <width>48</width><height>48</height>
                <texturefocus colordiffuse="EEFFFFFF">special://skin/media/dialogs/close.png</texturefocus>
                <texturenofocus colordiffuse="44FFFFFF">special://skin/media/dialogs/close.png</texturenofocus>
                <label></label>
                <onclick>Action(close)</onclick>
            </control>

            <!-- Header separator -->
            <control type="image">
                <left>16</left><top>90</top>
                <right>16</right><height>1</height>
                <texture colordiffuse="18FFFFFF">special://skin/media/colors/white.png</texture>
            </control>

            <!-- ── CATEGORY TABS  (y 96–154) ─────────────────────────── -->

            <!-- Tab: Side Menu  id=400 -->
            <control type="button" id="400">
                <left>20</left><top>98</top>
                <width>200</width><height>50</height>
                <label>[B]Side Menu[/B]</label>
                <font>font25_title</font>
                <align>center</align>
                <textcolor>FFFFFFFF</textcolor>
                <focusedcolor>FFFFFFFF</focusedcolor>
                <texturefocus colordiffuse="button_focus">special://skin/media/buttons/dialog-btn.png</texturefocus>
                <texturenofocus colordiffuse="button_focus">special://skin/media/buttons/dialog-btn.png</texturenofocus>
                <onup>300</onup>
                <ondown>200</ondown>
            </control>

            <!-- Tab: Logos  id=401 -->
            <control type="button" id="401">
                <left>230</left><top>98</top>
                <width>200</width><height>50</height>
                <label>Logos</label>
                <font>font25_title</font>
                <align>center</align>
                <textcolor>AAFFFFFF</textcolor>
                <focusedcolor>FFFFFFFF</focusedcolor>
                <texturefocus colordiffuse="button_focus">special://skin/media/buttons/dialog-btn.png</texturefocus>
                <texturenofocus colordiffuse="14FFFFFF">special://skin/media/buttons/dialog-btn.png</texturenofocus>
                <onup>301</onup>
                <ondown>200</ondown>
            </control>

            <!-- Tab: Emoji  id=402 -->
            <control type="button" id="402">
                <left>440</left><top>98</top>
                <width>200</width><height>50</height>
                <label>Emoji</label>
                <font>font25_title</font>
                <align>center</align>
                <textcolor>AAFFFFFF</textcolor>
                <focusedcolor>FFFFFFFF</focusedcolor>
                <texturefocus colordiffuse="button_focus">special://skin/media/buttons/dialog-btn.png</texturefocus>
                <texturenofocus colordiffuse="14FFFFFF">special://skin/media/buttons/dialog-btn.png</texturenofocus>
                <onup>500</onup>
                <ondown>200</ondown>
            </control>

            <!-- Tabs separator -->
            <control type="image">
                <left>16</left><top>156</top>
                <right>16</right><height>1</height>
                <texture colordiffuse="18FFFFFF">special://skin/media/colors/white.png</texture>
            </control>

            <!-- ── ICON GRID  (y 164 – bottom 70) ────────────────────── -->
            <!--
                Item size 155×160  →  floor(1462/155) = 9 items per row
                Visible rows: floor(666/160) = 4 rows → 36 visible items
            -->
            <control type="panel" id="200">
                <scrolltime condition="Skin.HasSetting(touchmode)">0</scrolltime>
                <left>20</left><top>164</top>
                <width>1462</width><bottom>70</bottom>
                <onup>400</onup>
                <ondown>9991</ondown>
                <orientation>vertical</orientation>
                <pagecontrol>201</pagecontrol>
                <viewtype label="icon">icon</viewtype>

                <!-- Normal item layout -->
                <itemlayout width="155" height="160">
                    <!-- Icon image — centred with generous breathing room -->
                    <control type="image">
                        <left>22</left><top>14</top>
                        <width>111</width><height>96</height>
                        <aspectratio>keep</aspectratio>
                        <texture>$INFO[ListItem.Thumb]</texture>
                    </control>
                    <!-- Name label — 2-line wrap, small font -->
                    <control type="label">
                        <left>4</left><top>114</top>
                        <width>147</width><height>42</height>
                        <font>font12</font>
                        <textcolor>66FFFFFF</textcolor>
                        <align>center</align>
                        <aligny>top</aligny>
                        <label>$INFO[ListItem.Label]</label>
                        <scroll>false</scroll>
                    </control>
                </itemlayout>

                <!-- Focused item layout — grey highlight, no accent line -->
                <focusedlayout width="155" height="160">
                    <control type="group">
                        <animation effect="zoom" time="150" tween="sine" easing="inout" start="100" end="110" center="auto">Focus</animation>
                        <!-- Grey highlight box -->
                        <control type="image">
                            <left>3</left><top>3</top>
                            <width>149</width><height>154</height>
                            <texture colordiffuse="2AFFFFFF">special://skin/media/colors/white.png</texture>
                        </control>
                        <!-- Icon image -->
                        <control type="image">
                            <left>22</left><top>14</top>
                            <width>111</width><height>96</height>
                            <aspectratio>keep</aspectratio>
                            <texture>$INFO[ListItem.Thumb]</texture>
                        </control>
                        <!-- Name label -->
                        <control type="label">
                            <left>4</left><top>114</top>
                            <width>147</width><height>42</height>
                            <font>font12</font>
                            <textcolor>FFFFFFFF</textcolor>
                            <align>center</align>
                            <aligny>top</aligny>
                            <label>$INFO[ListItem.Label]</label>
                            <scroll>false</scroll>
                        </control>
                    </control>
                </focusedlayout>
            </control>

            <!-- Scrollbar -->
            <control type="scrollbar" id="201">
                <left>1486</left><top>164</top>
                <width>14</width><bottom>70</bottom>
                <orientation>vertical</orientation>
                <onleft>200</onleft>
            </control>

            <!-- ── FOOTER ─────────────────────────────────────────────── -->

            <control type="image">
                <left>16</left><bottom>68</bottom>
                <right>16</right><height>1</height>
                <texture colordiffuse="18FFFFFF">special://skin/media/colors/white.png</texture>
            </control>

            <control type="button" id="9991">
                <right>20</right><bottom>8</bottom>
                <width>160</width><height>52</height>
                <label>Cancel</label>
                <font>font25_title</font>
                <align>center</align>
                <textcolor>unfocused_text</textcolor>
                <focusedcolor>FFFFFFFF</focusedcolor>
                <texturefocus colordiffuse="button_focus">special://skin/media/buttons/dialog-btn.png</texturefocus>
                <texturenofocus colordiffuse="14FFFFFF">special://skin/media/buttons/dialog-btn.png</texturenofocus>
                <onclick>Action(close)</onclick>
                <onup>200</onup>
            </control>

        </control>
    </controls>
</window>
