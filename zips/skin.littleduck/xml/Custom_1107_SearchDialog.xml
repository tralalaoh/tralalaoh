<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog" id="1107">
	<defaultcontrol>9000</defaultcontrol>
	<include>Animation_DialogPopupOpenClose</include>
	<controls>
		<control type="group">
			<centerleft>50%</centerleft>
			<width>600</width>
			<centertop>60%</centertop>
			<height>700</height>
			<include content="DialogBackgroundCommons">
				<param name="width" value="600" />
				<param name="height" value="485" />
				<param name="header_label" value="$LOCALIZE[137] [COLOR accent_color][B](TMDb Helper)[/B][/COLOR]" />
				<param name="header_id" value="" />
				<param name="diffusetexture" value="masks/dialog-bg-squareish.png" />
			</include>
			<control type="panel" id="9000">
				<scrolltime condition="Skin.HasSetting(touchmode)">0</scrolltime>
				<include>ButtonMenuList</include>
				<content>
					<item>
						<label>Combined (Movies + TV Shows)</label>
						<onclick>Dialog.Close(all)</onclick>
						<onclick>ActivateWindow(Videos,"plugin://plugin.video.themoviedb.helper/?info=search&amp;tmdb_type=both&amp;query=$INFO[Skin.String(SearchInputEncoded)]",return)</onclick>
					</item>
					<item>
						<label>Movies</label>
						<onclick>Dialog.Close(all)</onclick>
						<onclick>ActivateWindow(Videos,"plugin://plugin.video.themoviedb.helper/?info=search&amp;tmdb_type=movie&amp;query=$INFO[Skin.String(SearchInputEncoded)]",return)</onclick>
					</item>
					<item>
						<label>TV Shows</label>
						<onclick>Dialog.Close(all)</onclick>
						<onclick>ActivateWindow(Videos,"plugin://plugin.video.themoviedb.helper/?info=search&amp;tmdb_type=tv&amp;query=$INFO[Skin.String(SearchInputEncoded)]",return)</onclick>
					</item>
					<item>
						<label>Actors/Actresses</label>
						<onclick>Dialog.Close(all)</onclick>
						<onclick>ActivateWindow(Videos,"plugin://plugin.video.themoviedb.helper/?info=search&amp;tmdb_type=person&amp;query=$INFO[Skin.String(SearchInputEncoded)]",return)</onclick>
					</item>
					<item>
						<label>Movie Collections</label>
						<onclick>Dialog.Close(all)</onclick>
						<onclick>ActivateWindow(Videos,"plugin://plugin.video.themoviedb.helper/?info=search&amp;tmdb_type=collection&amp;query=$INFO[Skin.String(SearchInputEncoded)]",return)</onclick>
					</item>
					<item>
						<label>Keywords</label>
						<onclick>Dialog.Close(all)</onclick>
						<onclick>ActivateWindow(Videos,"plugin://plugin.video.themoviedb.helper/?info=search&amp;tmdb_type=keyword&amp;query=$INFO[Skin.String(SearchInputEncoded)]",return)</onclick>
					</item>
					<item>
						<label>AI Recommendations (Gemini)</label>
						<onclick>Dialog.Close(all)</onclick>
						<onclick>ActivateWindow(Videos,"plugin://plugin.video.themoviedb.helper/?info=gemini&amp;query=$INFO[Skin.String(SearchInputEncoded)]",return)</onclick>
					</item>
					<item>
						<label>Addons</label>
						<onclick>Dialog.Close(all)</onclick>
						<onclick>ActivateWindow(addonbrowser,addons://search/,return)</onclick>
					</item>
					<item>
						<label>YouTube</label>
						<onclick>Dialog.Close(all)</onclick>
						<onclick condition="System.AddonIsEnabled(plugin.video.youtube)">
							ActivateWindow(videos,"plugin://plugin.video.youtube/kodion/search/list/",return)</onclick>
						<onclick
							condition="System.HasAddon(plugin.video.youtube) + !System.AddonIsEnabled(plugin.video.youtube)">
							EnableAddon(plugin.video.youtube)</onclick>
						<onclick condition="!System.HasAddon(plugin.video.youtube)">
							InstallAddon(plugin.video.youtube)</onclick>
					</item>
				</content>
			</control>
			<include content="UpDownArrows">
				<param name="container_id" value="9000" />
				<param name="posx" value="276" />
				<param name="up_posy" value="-40" />
				<param name="down_posy" value="500" />
			</include>
		</control>
	</controls>
</window>
