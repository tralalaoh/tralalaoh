<?xml version="1.0" encoding="UTF-8"?>
<includes>

	<!--
		View 510 — Landscape Row (v2 — Arctic Fuse inspired)
		Changes vs v1:
		  - Drop shadow behind each card (overlays/shadow.png, offset +2,+4)
		  - Progress bar moved below image (not overlaid) — clean separation
		  - Focus: white inner glow (18% overlay) + gold border + DepthContentPopout
		  - Watched indicator uses duck-gold tint (consistent with indicators)
		Card layout defined in Includes_CardLayouts.xml: LandscapeRowCard
	-->
	<include name="View_510_LandscapeRow">
		<control type="group">
			<visible>Control.IsVisible(510)</visible>
			<include>OpenClose_Right</include>
			<include>Visible_Right</include>

			<!-- ============================================================ -->
			<!-- FANART BACKGROUND — hidden in playlist (live video behind) -->
			<!-- ============================================================ -->
			<include content="FanartDiffuseBackground">
				<param name="fanart" value="$INFO[Container(510).ListItem.Art(fanart)]" />
				<param name="fadetime" value="600" />
				<param name="visible" value="!Window.IsActive(videoplaylist)" />
			</include>

			<!-- Left vignette -->
			<control type="image">
				<left>0</left>
				<top>0</top>
				<width>100%</width>
				<height>100%</height>
				<aspectratio>stretch</aspectratio>
				<texture>overlays/fanart_overlay.png</texture>
			</control>

			<!-- Bottom gradient -->
			<control type="image">
				<left>0</left>
				<top>380</top>
				<width>100%</width>
				<height>700</height>
				<aspectratio>stretch</aspectratio>
				<texture>overlays/gradient-bottom.png</texture>
			</control>

			<!-- ============================================================ -->
			<!-- INFO HEADER — full hero for normal browsing                  -->
			<!-- ============================================================ -->
			<control type="group">
				<visible>!Window.IsActive(videoplaylist)</visible>
				<include content="SpotlightViewHero">
	<param name="clearlogo_texture" value="$INFO[Container(510).ListItem.Art(clearlogo)]"/>
	<param name="clearlogo_visible" value="!String.IsEmpty(Container(510).ListItem.Art(clearlogo))"/>
	<param name="title_label"       value="$INFO[Container(510).ListItem.Label]"/>
	<param name="title_visible"     value="String.IsEmpty(Container(510).ListItem.Art(clearlogo))"/>
	<param name="infoline_label"    value="$INFO[Container(510).ListItem.Rating,[COLOR accent_color]★ ,[/COLOR]]$INFO[Container(510).ListItem.Year, [COLOR unfocused_text]|[/COLOR] ]$INFO[Container(510).ListItem.MPAA, [COLOR unfocused_text]|[/COLOR] ]$INFO[Container(510).ListItem.Duration(h), [COLOR unfocused_text]|[/COLOR] , h]$INFO[Container(510).ListItem.Duration(mm),,m]$INFO[Container(510).ListItem.EndTime, [COLOR unfocused_text]|[/COLOR] Ends ]"/>
	<param name="plot_label"        value="$INFO[Container(510).ListItem.Plot]"/>
</include>
			</control>

			<!-- ============================================================ -->
			<!-- PLAYLIST MODE — header above cards + info/progress below   -->
			<!-- ============================================================ -->
			<control type="group">
				<visible>Window.IsActive(videoplaylist)</visible>

				<!-- "Video playlist" header label above the card row -->
				<control type="label">
					<left>75</left>
					<top>532</top>
					<width>900</width>
					<height>42</height>
					<font>font25_title</font>
					<textcolor>unfocused_text</textcolor>
					<shadowcolor>text_shadow</shadowcolor>
					<label>$LOCALIZE[31065]</label>
				</control>

				<!-- Thin divider between card row and progress strip -->
				<control type="image">
					<left>75</left>
					<top>875</top>
					<width>1770</width>
					<height>1</height>
					<texture colordiffuse="30FFFFFF">colors/white.png</texture>
				</control>

				<!-- Current playback time — left -->
				<control type="label">
					<left>75</left>
					<top>854</top>
					<width>300</width>
					<height>26</height>
					<font>font12</font>
					<textcolor>unfocused_text</textcolor>
					<shadowcolor>text_shadow</shadowcolor>
					<label>$INFO[Player.Time]</label>
					<visible>Player.HasVideo</visible>
				</control>

				<!-- Total duration — right -->
				<control type="label">
					<right>75</right>
					<top>854</top>
					<width>300</width>
					<height>26</height>
					<font>font12</font>
					<textcolor>unfocused_text</textcolor>
					<shadowcolor>text_shadow</shadowcolor>
					<align>right</align>
					<label>$INFO[Player.Duration]</label>
					<visible>Player.HasVideo</visible>
				</control>

				<!-- Playback progress bar -->
				<control type="progress">
					<left>75</left>
					<top>882</top>
					<width>1770</width>
					<height>4</height>
					<texturebg colordiffuse="30FFFFFF">colors/white.png</texturebg>
					<midtexture colordiffuse="accent_color" border="2,0,2,0">progress/progress-nib.png</midtexture>
					<info>Player.Progress</info>
					<visible>Player.HasVideo</visible>
				</control>

				<!-- Focused item thumbnail -->
				<control type="image">
					<left>75</left>
					<top>904</top>
					<width>80</width>
					<height>45</height>
					<texture diffuse="masks/landscape.png" fallback="DefaultVideo.png" background="true">$INFO[Container(510).ListItem.Art(thumb)]</texture>
					<aspectratio aligny="center">keep</aspectratio>
				</control>

				<!-- Focused item title -->
				<control type="fadelabel">
					<left>168</left>
					<top>904</top>
					<width>248</width>
					<height>34</height>
					<font>font36_title</font>
					<shadowcolor>text_shadow</shadowcolor>
					<label>$INFO[Container(510).ListItem.Label]</label>
				</control>

				<!-- Show / source label (grey, below title) -->
				<control type="label">
					<left>168</left>
					<top>942</top>
					<width>248</width>
					<height>26</height>
					<font>font12</font>
					<textcolor>grey</textcolor>
					<shadowcolor>text_shadow</shadowcolor>
					<label>$INFO[Container(510).ListItem.TVShowTitle]</label>
				</control>

				<!-- Episode / item description (right column) -->
				<control type="textbox">
					<left>430</left>
					<top>904</top>
					<right>75</right>
					<height>64</height>
					<font>font12</font>
					<textcolor>grey</textcolor>
					<shadowcolor>text_shadow</shadowcolor>
					<label>$INFO[Container(510).ListItem.Plot]</label>
				</control>
			</control>

			<!-- ============================================================ -->
			<!-- LANDSCAPE CARD ROW — id=510                                  -->
			<!-- Card image: 380×214 (16:9) | progress: 3px below image      -->
			<!-- Label: 52px | Total item: 390×290                           -->
			<!-- ============================================================ -->
			<control type="fixedlist" id="510">
				<left>75</left>
				<top>580</top>
				<right>20</right>
				<height>420</height>
				<orientation>horizontal</orientation>
				<movement>2</movement>
				<preloaditems>3</preloaditems>
				<scrolltime tween="cubic" easing="out">500</scrolltime>
				<onleft>510</onleft>
				<onright>510</onright>
				<onup>804</onup>
				<ondown>noop</ondown>
				<viewtype label="Landscape Row">icon</viewtype>
				<pagecontrol>5102</pagecontrol>
				<visible>$EXP[Exp_View_510] | Window.IsActive(videoplaylist)</visible>

				<texturefocus />
<texturenofocus />
<itemlayout width="390" height="290">
					<include>LandscapeRowCard</include>
				</itemlayout>

				<focusedlayout width="390" height="290">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<include content="LandscapeRowCard">
							<param name="focused" value="true"/>
						</include>
					</control>
				</focusedlayout>
			</control>

			<!-- Horizontal scrollbar -->
			<control type="scrollbar" id="5102">
				<left>75</left>
				<bottom>20</bottom>
				<right>20</right>
				<height>5</height>
				<orientation>horizontal</orientation>
				<texturenib>colors/white.png</texturenib>
				<texturenibfocus>colors/white.png</texturenibfocus>
				<textureback>colors/white.png</textureback>
				<colorback>20FFFFFF</colorback>
				<colornib>accent_color</colornib>
				<colornibfocus>white</colornibfocus>
			</control>

		</control>
	</include>

</includes>
