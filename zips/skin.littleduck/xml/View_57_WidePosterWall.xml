<?xml version="1.0" encoding="UTF-8"?>
<includes>

	<!--
		View 57 — Wide Poster Wall
		Vertical panel grid of portrait (2:3) poster cards.
		Best for: movies, TV shows, sets, seasons, actors.
		Card layout: PosterCardLayout from Includes_CardLayouts.xml (250×420 cards).
	-->
	<include name="View_57_WidePosterWall">
		<control type="group">
			<include>OpenClose_Right</include>
			<top>-15</top>
			<visible>Control.IsVisible(57)</visible>
			<include>Visible_Right</include>
			<include>FanartDiffuseBackground</include>
			<control type="panel" id="57">
				<scrolltime condition="Skin.HasSetting(touchmode)">0</scrolltime>
				<left>555</left>
				<top>120</top>
				<right>15</right>
				<height>100%</height>
				<onleft>9000</onleft>
				<onright>531</onright>
				<onup condition="Integer.IsGreater(Container.NumPages,1)">57</onup>
				<onup condition="!Integer.IsGreater(Container.NumPages,1)">804</onup>
				<ondown>57</ondown>
				<viewtype label="Poster Grid">icon</viewtype>
				<preloaditems>2</preloaditems>
				<pagecontrol>531</pagecontrol>
				<scrolltime tween="cubic" easing="out">500</scrolltime>
				<visible>$EXP[Exp_View_57]</visible>
				<include content="PosterCardLayout">
					<param name="panel_id" value="57"/>
					<param name="fallback" value="DefaultVideoCover.png"/>
					<param name="label2" value=""/>
				</include>
			</control>
		</control>
	</include>

</includes>
