<?xml version="1.0" encoding="UTF-8"?>
<includes>

	<!-- Horizontal media codec flags strip.
	     For use inside a vertical grouplist (info panel).
	     Shows: video resolution, video codec, audio codec, audio channels.
	     Params: height (default 32), width (default 48), itemgap (default 6) -->
	<include name="Furniture_Codecs">
		<param name="height">32</param>
		<param name="width">48</param>
		<param name="itemgap">6</param>
		<definition>
			<control type="grouplist">
				<scrolltime condition="Skin.HasSetting(touchmode)">0</scrolltime>
				<orientation>horizontal</orientation>
				<align>left</align>
				<height>$PARAM[height]</height>
				<itemgap>$PARAM[itemgap]</itemgap>
				<visible>[Container.Content(movies) | Container.Content(tvshows) | Container.Content(seasons) | Container.Content(episodes)]</visible>
				<control type="image">
					<texture background="true">$INFO[ListItem.VideoResolution,flags/color/resolution/,.png]</texture>
					<aspectratio>keep</aspectratio>
					<height>$PARAM[height]</height>
					<width>$PARAM[width]</width>
					<visible>!String.IsEmpty(ListItem.VideoResolution)</visible>
				</control>
				<control type="image">
					<texture background="true">$INFO[ListItem.VideoCodec,flags/color/source/,.png]</texture>
					<aspectratio>keep</aspectratio>
					<height>$PARAM[height]</height>
					<width>$PARAM[width]</width>
					<visible>!String.IsEmpty(ListItem.VideoCodec)</visible>
				</control>
				<control type="image">
					<texture background="true">$INFO[ListItem.AudioCodec,flags/color/audio/,.png]</texture>
					<aspectratio>keep</aspectratio>
					<height>$PARAM[height]</height>
					<width>$PARAM[width]</width>
					<visible>!String.IsEmpty(ListItem.AudioCodec)</visible>
				</control>
				<control type="image">
					<texture background="true">$INFO[ListItem.AudioChannels,flags/color/channels/,.png]</texture>
					<aspectratio>keep</aspectratio>
					<height>$PARAM[height]</height>
					<width>$PARAM[width]</width>
					<visible>!String.IsEmpty(ListItem.AudioChannels)</visible>
				</control>
			</control>
		</definition>
	</include>

</includes>
