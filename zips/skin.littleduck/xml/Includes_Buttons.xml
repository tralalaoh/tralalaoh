	<include name="ButtonMenuList">
		<left>0</left>
		<top>80</top>
		<width>600</width>
		<height>380</height>
		<onleft>9000</onleft>
		<onright>9000</onright>
		<onup>9000</onup>
		<ondown>9000</ondown>
