<?xml version="1.0" encoding="UTF-8"?>
<includes>

	<!-- Central pill focus-bar texture includes.
	     Use these everywhere instead of hardcoding colordiffuse="button_focus".
	     To retheme the entire skin, edit $VAR[ColorHighlight] in Variables.xml. -->
	<include name="Texture_Pill_H">
		<texturefocus border="12" colordiffuse="$VAR[ColorHighlight]">masks/focus_pill.png</texturefocus>
		<alttexturefocus border="12" colordiffuse="$VAR[ColorHighlight]">masks/focus_pill.png</alttexturefocus>
		<texturenofocus />
		<alttexturenofocus />
	</include>

	<include name="Texture_Pill_H_Image">
		<texture border="12" colordiffuse="$VAR[ColorHighlight]">masks/focus_pill.png</texture>
	</include>

	<include name="Texture_Pill_H_Dim">
		<texture border="12" colordiffuse="$VAR[ColorHighlight2]">masks/focus_pill.png</texture>
	</include>

	<include name="OSDButton">
		<textureradioonfocus colordiffuse="focused_text">$PARAM[texture]</textureradioonfocus>
		<textureradioonnofocus colordiffuse="unfocused_text">$PARAM[texture]</textureradioonnofocus>
		<textureradioofffocus colordiffuse="focused_text">$PARAM[texture]</textureradioofffocus>
		<textureradiooffnofocus colordiffuse="unfocused_text">$PARAM[texture]</textureradiooffnofocus>
		<textureradioondisabled colordiffuse="disabled">$PARAM[texture]</textureradioondisabled>
		<textureradiooffdisabled colordiffuse="disabled">$PARAM[texture]</textureradiooffdisabled>
		<texturefocus colordiffuse="button_focus">osd/fullscreen/buttons/button-fo.png</texturefocus>
		<texturenofocus />
		<width>80</width>
		<height>80</height>
		<radiowidth>52</radiowidth>
		<radioheight>52</radioheight>
		<radioposx>14</radioposx>
		<radioposy>14</radioposy>
		<font></font>
		<animation center="40,40" effect="zoom" end="100" reversible="false" start="95" time="480" tween="back">Focus</animation>
	</include>
	<include name="InfoDialogMetadata">
		<param name="onclick_condition">false</param>
		<param name="onclick">noop</param>
		<param name="altclick_condition">false</param>
		<param name="altclick">noop</param>
		<definition>
			<control type="togglebutton" id="$PARAM[control_id]">
				<include>FocusBounce</include>
				<width>472</width>
				<height>49</height>
				<textoffsetx>16</textoffsetx>
				<aligny>center</aligny>
				<font>font12</font>
				<textcolor>unfocused_text</textcolor>
				<focusedcolor>focused_text</focusedcolor>
				<texturefocus border="12" colordiffuse="$VAR[ColorHighlight]">masks/focus_pill.png</texturefocus>
				<alttexturefocus border="12" colordiffuse="$VAR[ColorHighlight]">masks/focus_pill.png</alttexturefocus>
				<texturenofocus />
				<alttexturenofocus />
				<onclick>noop</onclick>
				<onclick condition="$PARAM[onclick_condition]">$PARAM[onclick]</onclick>
				<altclick>noop</altclick>
				<altclick condition="$PARAM[altclick_condition]">$PARAM[altclick]</altclick>
				<label>$PARAM[label]</label>
				<altlabel>$PARAM[altlabel]</altlabel>
				<usealttexture>Control.HasFocus($PARAM[control_id])</usealttexture>
				<visible>$PARAM[visible]</visible>
			</control>
		</definition>
	</include>
	<include name="DefaultSettingButton">
		<param name="height">90</param>
		<param name="left">0</param>
		<param name="right">20</param>
		<param name="textoffsetx">30</param>
		<definition>
			<textoffsetx>$PARAM[textoffsetx]</textoffsetx>
			<top>0</top>
			<left>$PARAM[left]</left>
			<height>$PARAM[height]</height>
			<right>$PARAM[right]</right>
			<aligny>center</aligny>
			<wrapmultiline>true</wrapmultiline>
			<invalidcolor>invalid</invalidcolor>
			<selectedcolor>selected</selectedcolor>
			<font>font_settings_item</font>
			<textcolor>unfocused_text</textcolor>
			<focusedcolor>focused_text</focusedcolor>
			<texturefocus border="12" colordiffuse="$VAR[ColorHighlight]">masks/focus_pill.png</texturefocus>
			<texturenofocus border="12" colordiffuse="1EFFFFFF">masks/focus_pill.png</texturenofocus>
			<!-- Pill toggle for radiobutton state -->
			<radiowidth>120</radiowidth>
			<radioheight>56</radioheight>
			<radioposy>17</radioposy>
			<textureradioonfocus>buttons/toggle-pill-on.png</textureradioonfocus>
			<textureradioonnofocus>buttons/toggle-pill-on.png</textureradioonnofocus>
			<textureradioofffocus>buttons/toggle-pill-off.png</textureradioofffocus>
			<textureradiooffnofocus>buttons/toggle-pill-off.png</textureradiooffnofocus>
			<include>FocusBounce</include>
			<label2></label2>
		</definition>
	</include>
	<include name="DefaultSystemSettingsButton">
		<param name="height">80</param>
		<param name="right">20</param>
		<param name="textoffsetx">30</param>
		<definition>
			<textoffsetx>$PARAM[textoffsetx]</textoffsetx>
