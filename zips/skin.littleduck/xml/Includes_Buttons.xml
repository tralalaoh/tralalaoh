	<!-- Crew circle display for DialogVideoInfo: photo + name + role (non-interactive) -->
	<include name="InfoDialogCrewCircle">
		<param name="image" />
		<param name="name" />
		<param name="role" />
		<param name="visible">true</param>
		<definition>
			<control type="group">
				<height>84</height>
				<visible>$PARAM[visible]</visible>
				<!-- Gold accent left bar -->
				<control type="image">
					<left>0</left>
					<top>17</top>
					<width>4</width>
					<height>50</height>
					<texture colordiffuse="accent_color">colors/white.png</texture>
				</control>
				<!-- Actor photo fallback -->
				<control type="image">
					<left>12</left>
					<top>7</top>
					<width>70</width>
					<height>70</height>
					<aspectratio aligny="center">keep</aspectratio>
					<texture diffuse="masks/poster.png">DefaultActorSolid.png</texture>
				</control>
				<!-- Actor photo -->
				<control type="image">
					<left>12</left>
					<top>7</top>
					<width>70</width>
					<height>70</height>
					<aspectratio aligny="center">keep</aspectratio>
					<texture diffuse="masks/poster.png" background="true">$PARAM[image]</texture>
				</control>
				<!-- Name -->
				<control type="label">
					<left>92</left>
					<top>13</top>
					<width>370</width>
					<height>30</height>
					<font>font14</font>
					<textcolor>unfocused_text</textcolor>
					<label>$PARAM[name]</label>
				</control>
				<!-- Role label (gold) -->
				<control type="label">
					<left>92</left>
					<top>47</top>
					<width>370</width>
					<height>26</height>
					<font>font12</font>
					<textcolor>accent_color</textcolor>
					<label>$PARAM[role]</label>
				</control>
			</control>
		</definition>
	</include>

	<!-- Compact label/value row for DialogVideoInfo info section (non-interactive) -->
	<include name="InfoDialogCompactRow">
		<param name="visible">true</param>
		<definition>
			<control type="group">
				<height>40</height>
				<visible>$PARAM[visible]</visible>
				<control type="label">
					<left>4</left>
					<top>0</top>
					<width>130</width>
					<height>40</height>
					<aligny>center</aligny>
					<font>font12</font>
					<textcolor>accent_color</textcolor>
					<label>$PARAM[label]</label>
				</control>
				<control type="label">
					<left>140</left>
					<top>0</top>
					<right>0</right>
					<height>40</height>
					<aligny>center</aligny>
					<font>font12</font>
					<textcolor>unfocused_text</textcolor>
					<label>$PARAM[value]</label>
				</control>
			</control>
		</definition>
	</include>

</includes>
