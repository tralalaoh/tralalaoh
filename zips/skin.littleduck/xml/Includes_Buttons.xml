			<font>font_settings_item</font>
			<invalidcolor>invalid</invalidcolor>
			<selectedcolor>selected</selectedcolor>
			<texturefocus border="12" colordiffuse="FFFFFFFF">masks/focus_pill.png</texturefocus>
			<texturenofocus border="12" colordiffuse="1EFFFFFF">masks/focus_pill.png</texturenofocus>
			<include>FocusBounce</include>
			<label2></label2>
		</definition>
	</include>
	<include name="DialogSettingButton">
		<param name="height">90</param>
