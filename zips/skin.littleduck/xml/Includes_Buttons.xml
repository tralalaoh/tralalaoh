		<font>font12</font>
		<textoffsetx>30</textoffsetx>
		<textoffsety>10</textoffsety>
		<textcolor>button_focus</textcolor>
	</include>
	<include name="DefaultDialogButton">
		<param name="width">250</param>
		<param name="height">67</param>
		<param name="wrapmultiline">false</param>
		<param name="font">font25_title</param>
		<param name="onclick"></param>
		<param name="visible">true</param>
		<definition>
			<control type="button" id="$PARAM[id]">
				<width>$PARAM[width]</width>
				<height>$PARAM[height]</height>
				<label>$PARAM[label]</label>
				<font>$PARAM[font]</font>
				<textoffsetx>20</textoffsetx>
				<onclick>$PARAM[onclick]</onclick>
				<wrapmultiline>$PARAM[wrapmultiline]</wrapmultiline>
				<align>center</align>
				<textcolor>unfocused_text</textcolor>
				<focusedcolor>FFFFFFFF</focusedcolor>
				<texturefocus colordiffuse="button_focus">buttons/dialog-btn.png</texturefocus>
				<texturenofocus colordiffuse="12FFFFFF">buttons/dialog-btn.png</texturenofocus>
				<visible>$PARAM[visible]</visible>
			</control>
		</definition>
	</include>
	<include name="KeyboardButton">
		<width>84</width>
		<height>84</height>
		<texturefocus colordiffuse="$VAR[ColorHighlight]">common/circle.png</texturefocus>
		<texturenofocus colordiffuse="dialog_fg_06" border="40">common/menu.png</texturenofocus>
