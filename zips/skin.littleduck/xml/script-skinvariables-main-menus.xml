<?xml version="1.0" encoding="UTF-8"?>
<includes>

    <!--
        Main menu items for the side navigation.
        Paths, labels, and icons are driven by Skin.String settings so that
        no file regeneration is ever needed when the user changes a menu.
        Default values are set in shortcuts/skinvariables-startup.json.
    -->

    <include name="MoviesMainMenu">
        <item>
            <label>$INFO[Skin.String(menu.movies.label)]</label>
            <onclick>ActivateWindow(Videos,$INFO[Skin.String(menu.movies.path)],return)</onclick>
            <property name="menu_id">$NUMBER[19000]</property>
            <thumb>$INFO[Skin.String(menu.movies.icon)]</thumb>
            <property name="id">movies</property>
            <visible>!Skin.HasSetting(HomeMenuNoMovieButton)</visible>
        </item>
    </include>

