<?xml version="1.0" encoding="UTF-8"?>
<includes>

	<!--
		View 511 — Poster Row
		Full-screen fanart backdrop + horizontal row of portrait (2:3) poster cards.
		Arctic-inspired. Shows more items than view 51 (Poster carousel).
		Best for: movies, tvshows, sets, seasons, actors.
		Uses $EXP[Exp_View_511] for content-aware visibility (script-skinviewtypes-includes.xml).
		Card layout defined in Includes_CardLayouts.xml: PosterRowCard
	-->
	<include name="View_511_PosterRow">
		<control type="group">
			<visible>Control.IsVisible(511)</visible>
			<include>OpenClose_Right</include>
			<include>Visible_Right</include>

			<!-- ============================================================ -->
			<!-- FANART BACKGROUND                                            -->
			<!-- ============================================================ -->
			<include content="FanartDiffuseBackground">
				<param name="fanart" value="$INFO[Container(511).ListItem.Art(fanart)]" />
				<param name="fadetime" value="600" />
			</include>

			<!-- Left vignette -->
			<control type="image">
				<left>0</left>
				<top>0</top>
				<width>100%</width>
				<height>100%</height>
				<aspectratio>stretch</aspectratio>
				<texture>overlays/fanart_overlay.png</texture>
			</control>

			<!-- Bottom gradient -->
			<control type="image">
				<left>0</left>
				<top>300</top>
				<width>100%</width>
				<height>780</height>
				<aspectratio>stretch</aspectratio>
				<texture>overlays/gradient-bottom.png</texture>
			</control>

			<!-- ============================================================ -->
			<!-- INFO HEADER                                                  -->
			<!-- ============================================================ -->
			<include content="SpotlightViewHero">
	<param name="clearlogo_texture" value="$INFO[Container(511).ListItem.Art(clearlogo)]"/>
	<param name="clearlogo_visible" value="!String.IsEmpty(Container(511).ListItem.Art(clearlogo))"/>
	<param name="title_label"       value="$INFO[Container(511).ListItem.Label]"/>
	<param name="title_visible"     value="String.IsEmpty(Container(511).ListItem.Art(clearlogo))"/>
	<param name="infoline_label"    value="$INFO[Container(511).ListItem.Rating,[COLOR accent_color]★ ,[/COLOR]]$INFO[Container(511).ListItem.Year, [COLOR unfocused_text]|[/COLOR] ]$INFO[Container(511).ListItem.MPAA, [COLOR unfocused_text]|[/COLOR] ]$INFO[Container(511).ListItem.Duration(h), [COLOR unfocused_text]|[/COLOR] , h]$INFO[Container(511).ListItem.Duration(mm),,m]$INFO[Container(511).ListItem.EndTime, [COLOR unfocused_text]|[/COLOR] Ends ]"/>
	<param name="plot_label"        value="$INFO[Container(511).ListItem.Plot]"/>
</include>

			<!-- ============================================================ -->
			<!-- POSTER CARD ROW — id=511                                     -->
			<!-- Cards: 220×330 (2:3 portrait) + 54px label = 396px height   -->
			<!-- ~6 cards visible across 1920px                               -->
			<!-- ============================================================ -->
			<control type="fixedlist" id="511">
				<left>75</left>
				<top>580</top>
				<right>20</right>
				<height>540</height>
				<orientation>horizontal</orientation>
				<movement>2</movement>
				<preloaditems>3</preloaditems>
				<scrolltime tween="cubic" easing="out">500</scrolltime>
				<onleft>511</onleft>
				<onright>511</onright>
				<onup>804</onup>
				<ondown>noop</ondown>
				<viewtype label="Poster Row">icon</viewtype>
				<pagecontrol>5112</pagecontrol>
				<visible>$EXP[Exp_View_511]</visible>

				<texturefocus />
<texturenofocus />
<itemlayout width="244" height="406">
					<include>PosterRowCard</include>
				</itemlayout>

				<focusedlayout width="244" height="406">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<include content="PosterRowCard">
							<param name="focused" value="true"/>
						</include>
					</control>
				</focusedlayout>
			</control>

			<!-- Horizontal scrollbar -->
			<control type="scrollbar" id="5112">
				<left>75</left>
				<bottom>20</bottom>
				<right>20</right>
				<height>5</height>
				<orientation>horizontal</orientation>
				<texturenib>colors/white.png</texturenib>
				<texturenibfocus>colors/white.png</texturenibfocus>
				<textureback>colors/white.png</textureback>
				<colorback>20FFFFFF</colorback>
				<colornib>accent_color</colornib>
				<colornibfocus>white</colornibfocus>
			</control>

		</control>
	</include>

</includes>
