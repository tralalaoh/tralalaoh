					<include content="InfoDialogCompactRow">
						<param name="label" value="$LOCALIZE[29909]" />
						<param name="value" value="$INFO[ListItem.Studio]" />
						<param name="visible" value="!String.IsEmpty(ListItem.Studio)" />
