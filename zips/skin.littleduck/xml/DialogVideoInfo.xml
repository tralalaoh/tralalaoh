				<control type="label">
					<left>75</left>
					<top>140</top>
					<width>800</width>
					<height>44</height>
					<font>font25_title</font>
					<textcolor>accent_color</textcolor>
					<label>$LOCALIZE[206]</label>
				</control>

				<!-- Online cast (TMDb Helper) -->
				<control type="panel" id="50">
					<scrolltime condition="Skin.HasSetting(touchmode)">0</scrolltime>
					<visible>!String.IsEmpty(Window(Home).Property(TMDbHelper.ListItem.Monitor.TMDb_ID)) | !String.IsEmpty(ListItem.UniqueID(tmdb))</visible>
