<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol always="true">8</defaultcontrol>
	<onload>SetProperty(infobackground,$ESCINFO[ListItem.Art(fanart)],home)</onload>
	<!-- OSD mode: button 8 (Play) is hidden, redirect focus to plot button -->
	<onload condition="Player.HasVideo">SetFocus(138)</onload>
	<onunload>ClearProperty(infobackground,home)</onunload>
	<controls>

		<!-- ── Fanart scrim (fanart driven by Home.xml via infobackground property) ── -->
		<control type="image">
			<left>0</left>
			<top>0</top>
			<width>100%</width>
			<height>100%</height>
			<texture colordiffuse="E6000000">colors/black.png</texture>
			<animation effect="fade" start="0" end="100" time="300" delay="100">WindowOpen</animation>
			<animation effect="fade" start="100" end="0" time="200">WindowClose</animation>
		</control>

		<!-- ════════════════════════════════════════════════════════════════
		     OUTER SCROLL CONTAINER
		     Vertical grouplist — each child group is a full-width "section".
		     Sections slide into view as the user navigates DOWN.
		     Currently holds only Section 1 (main info).
		     Future steps will add Section 2+ (Similar, Reco, Videos…).
		     ════════════════════════════════════════════════════════════════ -->
		<control type="grouplist" id="9001">
			<scrolltime condition="Skin.HasSetting(touchmode)">0</scrolltime>
			<orientation>vertical</orientation>
			<left>0</left>
			<top>0</top>
			<right>0</right>
			<height>100%</height>
			<itemgap>0</itemgap>
			<scrolltime tween="quadratic" easing="out">400</scrolltime>
			<onleft>9001</onleft>
			<onright>9001</onright>
			<scrollbarid>9002</scrollbarid>

			<!-- ════════════════════════════════════════════════════════════
			     SECTION 1 — MAIN INFO (fills the screen on open)
			     Layout (all positions relative to this group):
			       top=20   Title + subtitle
			       top=130  Cast row (header + horizontal panel)
			       top=387  Middle: Poster | Plot | Details
			       top=796  Button row
			     ════════════════════════════════════════════════════════════ -->
			<control type="group" id="9010">
				<right>0</right>
				<height>1102</height>
				<animation effect="fade" start="0" end="100" time="300" delay="180">WindowOpen</animation>
				<animation effect="fade" start="100" end="0" time="200">WindowClose</animation>

				<!-- Gold accent border at very top of section -->
				<control type="image">
					<left>0</left>
					<top>0</top>
					<right>0</right>
					<height>3</height>
					<texture colordiffuse="accent_color">colors/white.png</texture>
				</control>

				<!-- ── TITLE ── -->
				<control type="label">
					<left>75</left>
					<top>18</top>
					<right>75</right>
					<height>68</height>
					<font>font52_title</font>
					<textcolor>unfocused_text</textcolor>
					<shadowcolor>text_shadow</shadowcolor>
					<label>$VAR[VideoInfoMainLabelVar]</label>
					<scroll>true</scroll>
				</control>

				<!-- ── SUBTITLE (tagline / episode / genre) ── -->
				<control type="label">
					<left>75</left>
					<top>90</top>
					<right>75</right>
					<height>34</height>
					<font>font14</font>
					<textcolor>accent_color</textcolor>
					<shadowcolor>text_shadow</shadowcolor>
					<label>$VAR[VideoInfoSubLabelVar]</label>
					<scroll>true</scroll>
				</control>

				<!-- Divider -->
				<control type="image">
					<left>75</left>
					<top>130</top>
					<right>75</right>
					<height>2</height>
					<texture colordiffuse="28FFFFFF">colors/white.png</texture>
				</control>

				<!-- ── CAST ROW ── -->
