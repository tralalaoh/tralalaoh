						<param name="card_height" value="200" />
						<param name="img_width" value="80" />
						<param name="img_height" value="120" />
						<param name="fallback" value="DefaultActorSolid.png" />
						<param name="art" value="$INFO[ListItem.Thumb]" />
						<param name="label2" value="$INFO[ListItem.Label2]" />
						<param name="label1_top" value="132" />
						<param name="label2_top" value="162" />
						<param name="label_width" value="86" />
						<param name="show_progress" value="false" />
						<param name="show_watched" value="false" />
						<param name="show_rating" value="false" />
						<param name="frame_left" value="2" />
						<param name="frame_top" value="-8" />
						<param name="frame_width" value="96" />
						<param name="frame_height" value="136" />
					</include>
				</control>

				<!-- Local library cast (id=51 — distinct from TMDb online cast id=50) -->
				<control type="panel" id="51">
					<scrolltime condition="Skin.HasSetting(touchmode)">0</scrolltime>
					<visible>String.IsEmpty(Window(Home).Property(TMDbHelper.ListItem.Monitor.TMDb_ID)) + String.IsEmpty(ListItem.UniqueID(tmdb))</visible>
					<top>186</top>
					<left>75</left>
					<right>75</right>
					<height>200</height>
					<onleft>51</onleft>
					<onright>51</onright>
					<onup>51</onup>
					<ondown>5000</ondown>
					<scrolltime>200</scrolltime>
					<onclick condition="!String.IsEmpty(Container(51).ListItem.Label)">Dialog.Close(MovieInformation)</onclick>
					<onclick condition="!String.IsEmpty(Container(51).ListItem.Label)">ActivateWindow(Videos,plugin://plugin.video.themoviedb.helper/?info=stars_in_both&amp;tmdb_type=person&amp;query=$ESCINFO[Container(51).ListItem.Label],return)</onclick>
					<orientation>horizontal</orientation>
					<include content="PosterCardLayout">
						<param name="card_width" value="100" />
						<param name="card_height" value="200" />
						<param name="img_width" value="80" />
						<param name="img_height" value="120" />
						<param name="fallback" value="DefaultActorSolid.png" />
						<param name="art" value="$INFO[ListItem.Thumb]" />
						<param name="label2" value="$INFO[ListItem.Label2]" />
						<param name="label1_top" value="132" />
						<param name="label2_top" value="162" />
						<param name="label_width" value="86" />
						<param name="show_progress" value="false" />
						<param name="show_watched" value="false" />
						<param name="show_rating" value="false" />
						<param name="frame_left" value="2" />
						<param name="frame_top" value="-8" />
						<param name="frame_width" value="96" />
						<param name="frame_height" value="136" />
					</include>
				</control>

				<!-- Cast navigation arrows -->
