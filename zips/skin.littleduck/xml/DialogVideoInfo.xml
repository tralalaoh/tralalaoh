					<control type="image">
						<left>2</left>
						<top>2</top>
						<width>346</width>
						<height>506</height>
						<aspectratio aligny="center">keep</aspectratio>
						<texture diffuse="masks/poster.png" fallback="DefaultVideo.png" background="true">$VAR[InfoDialogPosterVar]</texture>
