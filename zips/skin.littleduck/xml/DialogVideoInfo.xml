					<onclick condition="!String.IsEmpty(ListItem.Plot)">SetProperty(TextViewer_Text,$ESCINFO[ListItem.Plot],home)</onclick>
					<onclick condition="!String.IsEmpty(ListItem.Plot)">ActivateWindow(1102)</onclick>
					<!-- Navigate up to whichever cast panel is currently visible -->
					<onup condition="!String.IsEmpty(Window(Home).Property(TMDbHelper.ListItem.Monitor.TMDb_ID)) | !String.IsEmpty(ListItem.UniqueID(tmdb))">50</onup>
					<onup>51</onup>
					<onleft>138</onleft>
					<onright>4000</onright>
					<ondown>5000</ondown>
					<texturefocus colordiffuse="button_focus" border="21">masks/addons.png</texturefocus>
					<texturenofocus colordiffuse="button_focus2" border="21">masks/addons.png</texturenofocus>
				</control>
				<!-- Plot text (unfocused) -->
				<control type="textbox">
					<left>475</left>
					<top>448</top>
					<width>850</width>
					<height>470</height>
					<label fallback="19055">$INFO[ListItem.Plot]</label>
					<textcolor>unfocused_text</textcolor>
					<autoscroll delay="10000" time="5000" repeat="10000">Skin.HasSetting(AutoScroll)</autoscroll>
					<visible>!Control.HasFocus(138)</visible>
				</control>
				<!-- Plot text (focused) -->
				<control type="textbox">
					<left>475</left>
					<top>448</top>
					<width>850</width>
					<height>470</height>
					<label fallback="19055">$INFO[ListItem.Plot]</label>
					<textcolor>focused_text</textcolor>
					<autoscroll delay="10000" time="5000" repeat="10000">Skin.HasSetting(AutoScroll)</autoscroll>
					<visible>Control.HasFocus(138)</visible>
				</control>

				<!-- RIGHT: Detail info (crew circles + metadata rows) -->
				<control type="grouplist" id="4000">
					<scrolltime condition="Skin.HasSetting(touchmode)">0</scrolltime>
					<orientation>vertical</orientation>
					<left>1380</left>
					<top>430</top>
					<width>465</width>
					<height>506</height>
					<itemgap>4</itemgap>
					<!-- Director -->
					<include content="InfoDialogCrewCircle">
						<param name="image" value="$VAR[Image_DirectorIcon]" />
						<param name="name" value="$VAR[Label_Director_Display]" />
						<param name="role" value="$LOCALIZE[20339]" />
						<param name="visible" value="!String.IsEmpty(ListItem.Director) | !String.IsEmpty(Window(Home).Property(TMDbHelper.ListItem.Director.1.Name))" />
					</include>
					<!-- Writer -->
					<include content="InfoDialogCrewCircle">
						<param name="image" value="$VAR[Image_WriterIcon]" />
						<param name="name" value="$VAR[Label_Writer_Display]" />
						<param name="role" value="$LOCALIZE[20417]" />
						<param name="visible" value="!String.IsEmpty(ListItem.Writer) | !String.IsEmpty(Window(Home).Property(TMDbHelper.ListItem.Writer.1.Name))" />
					</include>
					<!-- Divider after crew -->
					<control type="group">
						<height>8</height>
						<visible>[!String.IsEmpty(ListItem.Director) | !String.IsEmpty(Window(Home).Property(TMDbHelper.ListItem.Director.1.Name))] | [!String.IsEmpty(ListItem.Writer) | !String.IsEmpty(Window(Home).Property(TMDbHelper.ListItem.Writer.1.Name))]</visible>
						<control type="image">
							<left>4</left>
							<top>3</top>
							<right>4</right>
							<height>2</height>
							<texture colordiffuse="20FFFFFF">colors/white.png</texture>
						</control>
					</control>
					<!-- Genre -->
					<include content="InfoDialogCompactRow">
						<param name="label" value="$LOCALIZE[515]" />
						<param name="value" value="$INFO[ListItem.Genre]" />
						<param name="visible" value="!String.IsEmpty(ListItem.Genre) + [String.IsEqual(ListItem.DBType,movie) | String.IsEqual(ListItem.DBType,tvshow) | String.IsEqual(ListItem.DBType,episode) | String.IsEqual(ListItem.DBType,musicvideo)]" />
					</include>
