					<onclick condition="!String.IsEmpty(Container(50).ListItem.Label)">ActivateWindow(Videos,plugin://plugin.video.themoviedb.helper/?info=stars_in_both&amp;tmdb_type=person&amp;query=$ESCINFO[Container(50).ListItem.Label],return)</onclick>
