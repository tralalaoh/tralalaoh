<?xml version="1.0" encoding="utf-8"?>
<!-- Combined Audio + Subtitle stream picker (single window, no modal conflict)     -->
<!-- Controlled by Window(home).Property(stream_type) = "audio" or "subtitle"       -->
<!-- OSD buttons: SetProperty(stream_type,audio,window(1111)) + ActivateWindow(1111) -->
<window type="dialog" id="1111">
	<defaultcontrol always="true">6000</defaultcontrol>
	<onload condition="String.IsEqual(Window(home).Property(stream_type),subtitle)">SetFocus(6001)</onload>
	<controls>

		<!-- Click-to-close background -->
		<control type="button">
			<left>0</left>
			<top>0</top>
			<width>100%</width>
			<height>100%</height>
			<texturefocus />
			<texturenofocus />
			<onclick>Action(Close)</onclick>
		</control>

		<!-- Light screen dimmer -->
		<control type="image">
			<left>0</left>
			<top>0</top>
			<width>100%</width>
			<height>100%</height>
			<texture colordiffuse="20000000">colors/black.png</texture>
			<animation effect="fade" start="0" end="100" time="200">WindowOpen</animation>
			<animation effect="fade" start="100" end="0" time="150">WindowClose</animation>
		</control>

		<!-- Dialog panel -->
		<control type="group">
			<centerleft>50%</centerleft>
			<centertop>50%</centertop>
			<width>900</width>
			<height>680</height>
			<animation effect="fade" start="0" end="100" time="200">WindowOpen</animation>
			<animation effect="fade" start="100" end="0" time="150">WindowClose</animation>

			<!-- Black semi-transparent panel background -->
			<control type="image">
				<texture colordiffuse="CC000000">masks/landscape.png</texture>
			</control>

			<!-- ── Header ── -->
			<!-- Audio title -->
			<control type="label">
				<left>30</left>
				<top>0</top>
				<width>750</width>
				<height>80</height>
				<font>font32_title</font>
				<aligny>center</aligny>
				<textcolor>unfocused_text</textcolor>
				<shadowcolor>black</shadowcolor>
				<label>[B]Audio stream[/B]</label>
				<visible>String.IsEqual(Window(home).Property(stream_type),audio)</visible>
			</control>
			<control type="image">
				<left>30</left>
				<top>26</top>
				<width>28</width>
				<height>28</height>
				<texture colordiffuse="60FFFFFF">osd/fullscreen/buttons/audio.png</texture>
				<visible>String.IsEqual(Window(home).Property(stream_type),audio)</visible>
			</control>

			<!-- Subtitle title -->
			<control type="label">
				<left>30</left>
				<top>0</top>
				<width>750</width>
				<height>80</height>
				<font>font32_title</font>
				<aligny>center</aligny>
				<textcolor>unfocused_text</textcolor>
				<shadowcolor>black</shadowcolor>
				<label>[B]Subtitles[/B]</label>
				<visible>String.IsEqual(Window(home).Property(stream_type),subtitle)</visible>
			</control>
			<control type="image">
				<left>30</left>
				<top>26</top>
				<width>28</width>
				<height>28</height>
				<texture colordiffuse="60FFFFFF">osd/fullscreen/buttons/settings-subtitle.png</texture>
				<visible>String.IsEqual(Window(home).Property(stream_type),subtitle)</visible>
			</control>

			<!-- Close button (X) top-right -->
			<control type="button" id="9">
				<right>15</right>
				<top>15</top>
				<width>50</width>
				<height>50</height>
				<label></label>
				<texturefocus colordiffuse="accent_color">osd/fullscreen/buttons/button-fo.png</texturefocus>
				<texturenofocus />
				<onclick>Action(Close)</onclick>
				<ondown>6000</ondown>
				<onleft>6000</onleft>
			</control>
			<control type="image">
				<right>26</right>
				<top>26</top>
				<width>28</width>
				<height>28</height>
				<texture colordiffuse="80FFFFFF">icons/back.png</texture>
			</control>

			<!-- Gold divider under header -->
			<control type="image">
				<left>20</left>
				<top>80</top>
				<right>20</right>
				<height>1</height>
				<texture colordiffuse="accent_color">colors/white.png</texture>
			</control>

			<!-- ── Audio stream panel ── -->
			<control type="panel" id="6000">
				<scrolltime condition="Skin.HasSetting(touchmode)">0</scrolltime>
				<left>0</left>
				<top>82</top>
				<width>900</width>
				<bottom>10</bottom>
				<orientation>vertical</orientation>
				<scrolltime tween="sine">200</scrolltime>
				<visible>String.IsEqual(Window(home).Property(stream_type),audio)</visible>
				<content>plugin://script.skinvariables/?info=get_player_streams&amp;stream_type=audio&amp;reload=$INFO[Window(1111).Property(UID)]</content>
				<onclick>RunScript(script.skinvariables,set_player_audiostream=$INFO[ListItem.Property(index)],reload_property=UID)</onclick>
				<onup>9</onup>

				<include content="StreamRowLayout">
					<param name="content_label" value="$INFO[ListItem.Label2]$INFO[ListItem.Property(codec),  ,]$INFO[ListItem.Property(channels),  , ch]$INFO[ListItem.Property(bitrate),  , bps]"/>
					<param name="panel_id" value="6000"/>
				</include>
			</control>

			<!-- ── Subtitle stream panel ── -->
			<control type="panel" id="6001">
				<scrolltime condition="Skin.HasSetting(touchmode)">0</scrolltime>
				<left>0</left>
				<top>82</top>
				<width>900</width>
				<bottom>10</bottom>
				<orientation>vertical</orientation>
				<scrolltime tween="sine">200</scrolltime>
				<visible>String.IsEqual(Window(home).Property(stream_type),subtitle)</visible>
				<content>plugin://script.skinvariables/?info=get_player_streams&amp;stream_type=subtitle&amp;reload=$INFO[Window(1111).Property(UID)]</content>
				<onclick>RunScript(script.skinvariables,set_player_subtitle=$INFO[ListItem.Property(index)],reload_property=UID)</onclick>
				<onup>9</onup>

				<include content="StreamRowLayout">
					<param name="content_label" value="$INFO[ListItem.Label2]$INFO[ListItem.Property(isforced),  (forced),]$INFO[ListItem.Property(isdefault),  (default),]"/>
					<param name="panel_id" value="6001"/>
					<param name="has_cc_badge" value="false"/>
				</include>
			</control>

		</control>
	</controls>
</window>
