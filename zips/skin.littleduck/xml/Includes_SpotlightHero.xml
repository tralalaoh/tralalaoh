<?xml version="1.0" encoding="UTF-8"?>
<includes>

	<!--
		SpotlightViewHero — reusable info header for all Spotlight contexts
		(views 505/507/508/510/511 and the Home spotlight panel).
		Edit this ONE file to change fonts, spacing, or layout everywhere.

		Layout params (have defaults — change here to restyle everywhere):
		  infoline_font       font for the star Rating | Year | MPAA line  (default: font27)
		  clearlogo_width     clearlogo image max width                     (default: 640)
		  plot_top            top offset of the browse plot textbox         (default: 300)
		  plot_height         height of the browse plot textbox             (default: 200)
		  rating_row_top      top offset of the horizontal title+chips bar  (default: 440)
		  panel_visible       outer group visible condition                 (default: true)
		  episode_container_id episode sublist container ID; 0 = disabled  (default: 0)

		Show/hide flags (pass false to suppress a section):
		  show_clearlogo      show the clearlogo image                      (default: true)
		  show_title          show the title fallback label                 (default: true)
		  show_infoline       show the star rating | year | mpaa line       (default: true)
		  show_ratings        show the vertical rating chips row            (default: true)
		  show_plot           show the browse plot textbox                  (default: true)
		  show_rating_row     show the horizontal title + chip bar          (default: false)

		Content params (required — what to display):
		  clearlogo_texture   texture expression for the clearlogo image
		  clearlogo_visible   condition when clearlogo is shown
		  title_label         fallback title (shown when no clearlogo)
		  title_visible       condition when title fallback is shown
		  infoline_label      star rating | year | mpaa | duration label
		  plot_label          plot/synopsis text
	-->
	<include name="SpotlightViewHero">
		<!-- Layout params -->
		<param name="infoline_font">font27</param>
		<param name="clearlogo_width">640</param>
		<param name="plot_top">300</param>
		<param name="plot_height">200</param>
		<param name="rating_row_top">440</param>
		<param name="panel_visible">true</param>
		<param name="episode_container_id">0</param>
		<!-- Show/hide flags -->
		<param name="show_clearlogo">true</param>
		<param name="show_title">true</param>
		<param name="show_infoline">true</param>
		<param name="show_ratings">true</param>
		<param name="show_plot">true</param>
		<param name="show_rating_row">false</param>
		<definition>
		<control type="group">
			<left>105</left>
			<top>50</top>
			<right>40</right>
			<animation effect="fade" start="0" end="100" time="400">WindowOpen</animation>
			<visible>$PARAM[panel_visible]</visible>

			<!-- ── CLEARLOGO (shown when available) ─────────────────── -->
			<control type="image">
				<left>0</left>
				<top>0</top>
				<width>$PARAM[clearlogo_width]</width>
				<height>140</height>
				<texture background="true">$PARAM[clearlogo_texture]</texture>
				<aspectratio align="left" aligny="center">keep</aspectratio>
				<visible>$PARAM[show_clearlogo] + $PARAM[clearlogo_visible]</visible>
			</control>

			<!-- ── TITLE FALLBACK when no clearlogo ──────────────────── -->
			<control type="label">
				<left>0</left>
				<top>0</top>
				<width>900</width>
				<height>140</height>
				<aligny>center</aligny>
				<font>font52_title</font>
				<textcolor>white</textcolor>
				<label>$PARAM[title_label]</label>
				<visible>$PARAM[show_title] + $PARAM[title_visible]</visible>
			</control>

			<!-- ── INFO LINE: star Rating | Year | MPAA | Duration | Ends ── -->
			<control type="label">
				<left>0</left>
				<top>152</top>
				<width>900</width>
				<height>36</height>
				<aligny>center</aligny>
				<font>$PARAM[infoline_font]</font>
				<textcolor>white</textcolor>
				<shadowcolor>text_shadow</shadowcolor>
				<label>$PARAM[infoline_label]</label>
				<visible>$PARAM[show_infoline] + [Integer.IsEqual($PARAM[episode_container_id],0) | !Control.HasFocus($PARAM[episode_container_id])]</visible>
			</control>

			<!-- ── EPISODE TITLE (accent, bold) when episode list has focus ── -->
			<control type="label">
				<left>0</left>
				<top>152</top>
				<width>630</width>
				<height>36</height>
				<aligny>center</aligny>
				<font>font25_title</font>
				<textcolor>accent_color</textcolor>
				<label>[B]$INFO[Container($PARAM[episode_container_id]).ListItem.Title][/B]</label>
				<visible>!Integer.IsEqual($PARAM[episode_container_id],0) + Control.HasFocus($PARAM[episode_container_id])</visible>
			</control>

			<!-- ── EPISODE METADATA: aired / runtime / endtime ────────── -->
			<control type="label">
				<left>0</left>
				<top>192</top>
				<width>900</width>
				<height>30</height>
				<aligny>center</aligny>
				<font>font32</font>
				<textcolor>white</textcolor>
				<shadowcolor>text_shadow</shadowcolor>
				<label>$INFO[Container($PARAM[episode_container_id]).ListItem.Aired, · ,]$INFO[Container($PARAM[episode_container_id]).ListItem.Duration(mins), · , mins]$INFO[Container($PARAM[episode_container_id]).ListItem.EndTime, · Ends ,]</label>
				<visible>!Integer.IsEqual($PARAM[episode_container_id],0) + Control.HasFocus($PARAM[episode_container_id])</visible>
			</control>

			<!-- ── VERTICAL RATINGS ROW: icon above score (Metacritic / RT / IMDb / Popularity / TMDb) ── -->
			<control type="grouplist">
				<left>0</left>
				<top>196</top>
				<width>950</width>
				<height>90</height>
				<orientation>horizontal</orientation>
				<itemgap>20</itemgap>
				<visible>$PARAM[show_ratings] + [!String.IsEmpty(Skin.String(mdblist_api_key)) | !String.IsEmpty(Skin.String(omdb_api_key))] + [Integer.IsEqual($PARAM[episode_container_id],0) | !Control.HasFocus($PARAM[episode_container_id])]</visible>
				<!-- Metacritic -->
				<include content="RatingChipVertical">
					<param name="width" value="60"/>
					<param name="image_width" value="60"/>
					<param name="label_max" value="60"/>
					<param name="visible" value="![String.IsEmpty(Window.Property(littleduck.metascore)) | Skin.HasSetting(Disable.MetacriticRating)]"/>
					<param name="texture" value="$INFO[Window.Property(littleduck.metascoreImage)]"/>
					<param name="label" value="$INFO[Window.Property(littleduck.metascore)]"/>
				</include>
				<!-- RT Critics -->
				<include content="RatingChipVertical">
					<param name="width" value="60"/>
					<param name="image_width" value="60"/>
					<param name="label_max" value="60"/>
					<param name="visible" value="![String.IsEmpty(Window.Property(littleduck.tomatoMeter)) | Skin.HasSetting(Disable.RTCRating)]"/>
					<param name="texture" value="$INFO[Window.Property(littleduck.tomatoImage)]"/>
					<param name="label" value="$INFO[Window.Property(littleduck.tomatoMeter)]"/>
				</include>
				<!-- RT Audience -->
				<include content="RatingChipVertical">
					<param name="width" value="60"/>
					<param name="image_width" value="60"/>
					<param name="label_max" value="60"/>
					<param name="visible" value="![String.IsEmpty(Window.Property(littleduck.tomatoUserMeter)) | Skin.HasSetting(Disable.RTARating)]"/>
					<param name="texture" value="$INFO[Window.Property(littleduck.tomatoUserImage)]"/>
					<param name="label" value="$INFO[Window.Property(littleduck.tomatoUserMeter)]"/>
				</include>
				<!-- IMDb -->
				<include content="RatingChipVertical">
					<param name="width" value="60"/>
					<param name="image_width" value="60"/>
					<param name="label_max" value="60"/>
					<param name="visible" value="![String.IsEmpty(Window.Property(littleduck.imdbRating)) | Skin.HasSetting(Disable.IMDbRating)]"/>
					<param name="texture" value="$INFO[Window.Property(littleduck.imdbImage)]"/>
					<param name="label" value="$INFO[Window.Property(littleduck.imdbRating)]"/>
				</include>
				<!-- Popularity -->
				<include content="RatingChipVertical">
					<param name="width" value="77"/>
					<param name="image_width" value="87"/>
					<param name="label_max" value="87"/>
					<param name="visible" value="![String.IsEmpty(Window.Property(littleduck.popularRating)) | Skin.HasSetting(Disable.IMDbPopularRating)]"/>
					<param name="texture" value="$INFO[Window.Property(littleduck.popularImage)]"/>
					<param name="label" value="$INFO[Window.Property(littleduck.popularRating)]"/>
				</include>
				<!-- TMDb -->
				<include content="RatingChipVertical">
					<param name="width" value="65"/>
					<param name="image_width" value="65"/>
					<param name="label_max" value="65"/>
					<param name="itemgap" value="8"/>
					<param name="image_height" value="33"/>
					<param name="visible" value="![String.IsEmpty(Window.Property(littleduck.tmdbRating)) | Skin.HasSetting(Disable.TMDbRating)]"/>
					<param name="texture" value="$INFO[Window.Property(littleduck.tmdbImage)]"/>
					<param name="label" value="$INFO[Window.Property(littleduck.tmdbRating)]"/>
				</include>
				<!-- Trakt -->
				<include content="RatingChipVertical">
					<param name="width" value="60"/>
					<param name="image_width" value="60"/>
					<param name="label_max" value="60"/>
					<param name="visible" value="![String.IsEmpty(Window.Property(littleduck.traktRating)) | Skin.HasSetting(Disable.TraktRating)]"/>
					<param name="texture" value="$INFO[Window.Property(littleduck.traktImage)]"/>
					<param name="label" value="$INFO[Window.Property(littleduck.traktRating)]"/>
				</include>
				<!-- Letterboxd -->
				<include content="RatingChipVertical">
					<param name="width" value="60"/>
					<param name="image_width" value="60"/>
					<param name="label_max" value="60"/>
					<param name="visible" value="![String.IsEmpty(Window.Property(littleduck.letterboxdRating)) | Skin.HasSetting(Disable.LetterboxdRating)]"/>
					<param name="texture" value="$INFO[Window.Property(littleduck.letterboxdImage)]"/>
					<param name="label" value="$INFO[Window.Property(littleduck.letterboxdRating)]"/>
				</include>
				<!-- Awards -->
				<include content="RatingChipVertical">
					<param name="width" value="65"/>
					<param name="image_width" value="60"/>
					<param name="label_max" value="65"/>
					<param name="visible" value="![String.IsEmpty(Window.Property(littleduck.awardWins)) | Skin.HasSetting(Disable.AwardWins)]"/>
					<param name="texture" value="$INFO[Window.Property(littleduck.awardImage)]"/>
					<param name="label" value="$INFO[Window.Property(littleduck.awardWins)]"/>
				</include>
				<!-- OMDb Votes -->
				<include content="RatingChipVertical">
					<param name="width" value="80"/>
					<param name="image_width" value="60"/>
					<param name="label_max" value="80"/>
					<param name="visible" value="![String.IsEmpty(Window.Property(littleduck.omdbVotes)) | Skin.HasSetting(Disable.OmdbVotes)]"/>
					<param name="texture" value="special://home/addons/skin.littleduck/resources/rating_images/user.png"/>
					<param name="label" value="$INFO[Window.Property(littleduck.omdbVotes)]"/>
				</include>
			</control>

			<!-- ── EPISODE PLOT (when episode sublist has focus) ──────── -->
			<control type="textbox">
				<left>0</left>
				<top>228</top>
				<width>1000</width>
				<height>200</height>
				<font>font12</font>
				<textcolor>unfocused_text</textcolor>
				<shadowcolor>text_shadow</shadowcolor>
				<autoscroll delay="10000" time="3000" repeat="10000">Skin.HasSetting(autoscroll)</autoscroll>
				<label>$INFO[Container($PARAM[episode_container_id]).ListItem.Plot]</label>
				<visible>!Integer.IsEqual($PARAM[episode_container_id],0) + Control.HasFocus($PARAM[episode_container_id])</visible>
			</control>

			<!-- ── BROWSE PLOT (main list has focus, or no episode mode) ── -->
			<control type="textbox">
				<left>0</left>
				<top>$PARAM[plot_top]</top>
				<width>1000</width>
				<height>$PARAM[plot_height]</height>
				<font>font12</font>
				<textcolor>unfocused_text</textcolor>
				<shadowcolor>text_shadow</shadowcolor>
				<autoscroll delay="10000" time="3000" repeat="10000">Skin.HasSetting(autoscroll)</autoscroll>
				<label>$PARAM[plot_label]</label>
				<visible>$PARAM[show_plot] + [Integer.IsEqual($PARAM[episode_container_id],0) | !Control.HasFocus($PARAM[episode_container_id])]</visible>
			</control>

			<!-- ── HORIZONTAL RATING ROW: title + inline chips (show_rating_row=true to enable) ── -->
			<control type="group">
				<left>0</left>
				<top>$PARAM[rating_row_top]</top>
				<right>-65</right>
				<height>50</height>
				<visible>$PARAM[show_rating_row]</visible>
				<control type="grouplist">
					<scrolltime condition="Skin.HasSetting(touchmode)">0</scrolltime>
					<left>0</left>
					<top>0</top>
					<width>1815</width>
					<height>50</height>
					<orientation>horizontal</orientation>
					<aligny>center</aligny>
					<itemgap>20</itemgap>
					<!-- Item title — auto-width up to 600px -->
					<control type="label">
						<width max="600">auto</width>
						<height>50</height>
						<aligny>center</aligny>
						<font>font32_title</font>
						<textcolor>accent_color</textcolor>
						<shadowcolor>text_shadow</shadowcolor>
						<label>[B]$PARAM[title_label][/B]</label>
					</control>
					<!-- Horizontal rating chips follow title -->
					<control type="grouplist">
						<scrolltime condition="Skin.HasSetting(touchmode)">0</scrolltime>
						<visible>![String.IsEmpty(Skin.String(mdblist_api_key)) | Skin.HasSetting(Disable.WidgetLabelRatings)]</visible>
						<orientation>horizontal</orientation>
						<aligny>center</aligny>
						<itemgap>20</itemgap>
						<!-- Metacritic -->
						<include content="RatingChip">
							<param name="width" value="100"/>
							<param name="image_width" value="35"/>
							<param name="label_max" value="57"/>
							<param name="visible" value="![String.IsEmpty(Window.Property(littleduck.metascore)) | Skin.HasSetting(Disable.MetacriticRating)]"/>
							<param name="texture" value="$INFO[Window.Property(littleduck.metascoreImage)]"/>
							<param name="label" value="$INFO[Window.Property(littleduck.metascore)]"/>
						</include>
						<!-- RT Critics -->
						<include content="RatingChip">
							<param name="width" value="100"/>
							<param name="image_width" value="35"/>
							<param name="label_max" value="57"/>
							<param name="visible" value="![String.IsEmpty(Window.Property(littleduck.tomatoMeter)) | Skin.HasSetting(Disable.RTCRating)]"/>
							<param name="texture" value="$INFO[Window.Property(littleduck.tomatoImage)]"/>
							<param name="label" value="$INFO[Window.Property(littleduck.tomatoMeter)]"/>
						</include>
						<!-- RT Audience -->
						<include content="RatingChip">
							<param name="width" value="100"/>
							<param name="image_width" value="35"/>
							<param name="label_max" value="59"/>
							<param name="itemgap" value="6"/>
							<param name="visible" value="![String.IsEmpty(Window.Property(littleduck.tomatoUserMeter)) | Skin.HasSetting(Disable.RTARating)]"/>
							<param name="texture" value="$INFO[Window.Property(littleduck.tomatoUserImage)]"/>
							<param name="label" value="$INFO[Window.Property(littleduck.tomatoUserMeter)]"/>
						</include>
						<!-- IMDb -->
						<include content="RatingChip">
							<param name="width" value="112"/>
							<param name="image_width" value="52"/>
							<param name="label_max" value="60"/>
							<param name="visible" value="![String.IsEmpty(Window.Property(littleduck.imdbRating)) | Skin.HasSetting(Disable.IMDbRating)]"/>
							<param name="texture" value="$INFO[Window.Property(littleduck.imdbImage)]"/>
							<param name="label" value="$INFO[Window.Property(littleduck.imdbRating)]"/>
						</include>
						<!-- Popularity -->
						<include content="RatingChip">
							<param name="width" value="130"/>
							<param name="image_width" value="25"/>
							<param name="label_max" value="90"/>
							<param name="itemgap" value="10"/>
							<param name="visible" value="![String.IsEmpty(Window.Property(littleduck.popularRating)) | Skin.HasSetting(Disable.IMDbPopularRating)]"/>
							<param name="texture" value="$INFO[Window.Property(littleduck.popularImage)]"/>
							<param name="label" value="$INFO[Window.Property(littleduck.popularRating)]"/>
						</include>
						<!-- TMDb -->
						<include content="RatingChip">
							<param name="width" value="93"/>
							<param name="image_width" value="36"/>
							<param name="label_max" value="60"/>
							<param name="visible" value="![String.IsEmpty(Window.Property(littleduck.tmdbRating)) | Skin.HasSetting(Disable.TMDbRating)]"/>
							<param name="texture" value="$INFO[Window.Property(littleduck.tmdbImage)]"/>
							<param name="label" value="$INFO[Window.Property(littleduck.tmdbRating)]"/>
						</include>
						<!-- Trakt -->
						<include content="RatingChip">
							<param name="width" value="100"/>
							<param name="image_width" value="28"/>
							<param name="label_max" value="62"/>
							<param name="visible" value="!String.IsEmpty(Window.Property(littleduck.traktRating)) + !Skin.HasSetting(Disable.TraktRating)"/>
							<param name="texture" value="$INFO[Window.Property(littleduck.traktImage)]"/>
							<param name="label" value="$INFO[Window.Property(littleduck.traktRating)]"/>
						</include>
						<!-- Letterboxd -->
						<include content="RatingChip">
							<param name="width" value="80"/>
							<param name="image_width" value="28"/>
							<param name="label_max" value="45"/>
							<param name="visible" value="!String.IsEmpty(Window.Property(littleduck.letterboxdRating)) + !Skin.HasSetting(Disable.LetterboxdRating)"/>
							<param name="texture" value="$INFO[Window.Property(littleduck.letterboxdImage)]"/>
							<param name="label" value="$INFO[Window.Property(littleduck.letterboxdRating)]"/>
						</include>
						<!-- Awards -->
						<include content="RatingChip">
							<param name="width" value="75"/>
							<param name="image_width" value="28"/>
							<param name="label_max" value="45"/>
							<param name="visible" value="!String.IsEmpty(Window.Property(littleduck.awardWins)) + !Skin.HasSetting(Disable.AwardWins)"/>
							<param name="texture" value="$INFO[Window.Property(littleduck.awardImage)]"/>
							<param name="label" value="$INFO[Window.Property(littleduck.awardWins)]"/>
						</include>
						<!-- OMDb Votes -->
						<include content="RatingChip">
							<param name="width" value="125"/>
							<param name="image_width" value="28"/>
							<param name="label_max" value="88"/>
							<param name="visible" value="!String.IsEmpty(Window.Property(littleduck.omdbVotes)) + !Skin.HasSetting(Disable.OmdbVotes)"/>
							<param name="texture" value="special://home/addons/skin.littleduck/resources/rating_images/user.png"/>
							<param name="label" value="$INFO[Window.Property(littleduck.omdbVotes)]"/>
						</include>
					</control>
				</control>
			</control>

		</control>
		</definition>
	</include>

</includes>
