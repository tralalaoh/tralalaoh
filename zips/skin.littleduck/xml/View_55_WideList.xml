<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include name="View_55_WideList">
		<param name="bottom_offset">list_bottom_offset</param>
		<definition>
			<control type="group">
				<include>OpenClose_Right</include>
				<visible>Control.IsVisible(55)</visible>
				<include>Visible_Right</include>

				<include>FanartDiffuseBackground</include>

				<!-- Large poster for the focused item - RIGHT side, outside the list -->
				<control type="image">
					<right>20</right>
					<top>list_top_offset</top>
					<bottom>list_bottom_offset</bottom>
					<width>480</width>
					<aspectratio>keep</aspectratio>
					<texture diffuse="masks/poster.png" background="true">$INFO[ListItem.Art(poster)]</texture>
				</control>

				<control type="fixedlist" id="55">
					<left>594</left>
					<top>list_top_offset</top>
					<bottom>$PARAM[bottom_offset]</bottom>
					<right>510</right>
					<height>83%</height>
					<scrolltime tween="cubic" easing="out">500</scrolltime>
					<orientation>vertical</orientation>
					<pagecontrol>531</pagecontrol>
					<movement>7</movement>
					<focusposition>6</focusposition>
					<onleft>9000</onleft>
					<onright>531</onright>
					<onup>804</onup>
					<ondown>55</ondown>
					<viewtype label="List">list</viewtype>
					<visible>$EXP[Exp_View_55]</visible>

					<!-- MEDIA: movies / tvshows / seasons / episodes / musicvideos / videos / games / playlists -->
					<texturefocus />
<texturenofocus />
<focusedlayout height="85" condition="Container.Content(tvshows) | Container.Content(seasons) | Container.Content(episodes) | Container.Content(movies) | Container.Content(musicvideos) | Container.Content(videos) | Container.Content(games) | Window.IsActive(videoplaylist) | Window.IsActive(musicplaylist)">
						<!-- Focus highlight strip -->
						<control type="image">
							<left>0</left>
							<right>0</right>
							<top>0</top>
							<bottom>0</bottom>
							<texture border="12" colordiffuse="00FFFFFF">masks/focus_pill.png</texture>
							<visible>Control.HasFocus(55)</visible>
						</control>
						<!-- Progress ring (resumable) — black when focused -->
						<control type="image">
							<left>35</left>
							<centertop>50%</centertop>
							<width>37</width>
							<height>37</height>
							<texture colordiffuse="FF000000">$INFO[ListItem.PercentPlayed,indicator/progress/p,.png]</texture>
							<aspectratio align="center" aligny="center">keep</aspectratio>
							<visible>ListItem.IsResumable + !ListItem.IsPlaying</visible>
						</control>
						<!-- Watched checkmark (fully watched, not resuming) — black when focused -->
						<control type="image">
							<left>41</left>
							<centertop>50%</centertop>
							<width>24</width>
							<height>24</height>
							<texture colordiffuse="FF000000">indicator/checkmark.png</texture>
							<aspectratio align="center" aligny="center">keep</aspectratio>
							<visible>Integer.IsGreater(ListItem.Playcount,0) + !ListItem.IsResumable + !ListItem.IsPlaying</visible>
						</control>
						<control type="label">
							<left>105</left>
							<top>0</top>
							<bottom>0</bottom>
							<right>290</right>
							<aligny>center</aligny>
							<scroll>true</scroll>
							<scrollspeed>160</scrollspeed>
							<font>font32_title</font>
							<textcolor>focused_text</textcolor>
							<label>$VAR[ListLabelVar]</label>
							<shadowcolor>text_shadow</shadowcolor>
						</control>
						<!-- Compact codec flags: resolution, audio codec, channels -->
						<control type="grouplist">
							<scrolltime condition="Skin.HasSetting(touchmode)">0</scrolltime>
							<right>120</right>
							<centertop>50%</centertop>
							<orientation>horizontal</orientation>
							<align>right</align>
							<itemgap>4</itemgap>
							<visible>!String.IsEqual(ListItem.DBtype,tvshow) + !String.IsEqual(ListItem.DbType,season)</visible>
							<control type="image">
								<texture background="true">$INFO[ListItem.VideoResolution,flags/color/resolution/,.png]</texture>
								<aspectratio>keep</aspectratio>
								<height>26</height>
								<width>38</width>
								<visible>!String.IsEmpty(ListItem.VideoResolution)</visible>
							</control>
							<control type="image">
								<texture background="true">$INFO[ListItem.AudioCodec,flags/color/audio/,.png]</texture>
								<aspectratio>keep</aspectratio>
								<height>26</height>
								<width>38</width>
								<visible>!String.IsEmpty(ListItem.AudioCodec)</visible>
							</control>
							<control type="image">
								<texture background="true">$INFO[ListItem.AudioChannels,flags/color/channels/,.png]</texture>
								<aspectratio>keep</aspectratio>
								<height>26</height>
								<width>38</width>
								<visible>!String.IsEmpty(ListItem.AudioChannels)</visible>
							</control>
						</control>
						<control type="label">
							<left>105</left>
							<top>0</top>
							<bottom>0</bottom>
							<right>40</right>
							<align>right</align>
							<aligny>center</aligny>
							<font>font32_title</font>
							<textcolor>focused_text</textcolor>
							<label>$INFO[ListItem.Rating]</label>
							<visible>!String.IsEqual(ListItem.DBtype,tvshow) + !String.IsEqual(ListItem.DbType,season)</visible>
							<shadowcolor>text_shadow</shadowcolor>
						</control>
						<control type="label">
							<left>105</left>
							<top>0</top>
							<bottom>0</bottom>
							<right>40</right>
							<align>right</align>
							<aligny>center</aligny>
							<font>font32_title</font>
							<textcolor>focused_text</textcolor>
							<label>$INFO[ListItem.Property(WatchedEpisodes)]$INFO[ListItem.Property(TotalEpisodes), / ,]</label>
							<visible>String.IsEqual(ListItem.DbType,season)</visible>
							<shadowcolor>text_shadow</shadowcolor>
						</control>
						<control type="group">
							<visible>String.IsEqual(ListItem.DBtype,tvshow)</visible>
							<control type="label">
								<width>180</width>
								<top>0</top>
								<bottom>0</bottom>
								<right>136</right>
								<align>right</align>
								<aligny>center</aligny>
								<font>font32_title</font>
								<textcolor>focused_text</textcolor>
								<label>$INFO[ListItem.Property(WatchedEpisodes)]$INFO[ListItem.Property(TotalEpisodes), / ,]</label>
							</control>
							<control type="label">
								<width>120</width>
								<top>0</top>
								<bottom>0</bottom>
								<right>40</right>
								<align>right</align>
								<aligny>center</aligny>
								<font>font32_title</font>
								<textcolor>focused_text</textcolor>
								<label>  •  $INFO[ListItem.Rating]</label>
							</control>
							<shadowcolor>text_shadow</shadowcolor>
						</control>
					</focusedlayout>

					<itemlayout height="list_item_height" condition="Container.Content(tvshows) | Container.Content(seasons) | Container.Content(episodes) | Container.Content(movies) | Container.Content(musicvideos) | Container.Content(videos) | Container.Content(games) | Window.IsActive(videoplaylist) | Window.IsActive(musicplaylist)">
						<!-- Progress ring (resumable) -->
						<control type="image">
							<left>35</left>
							<centertop>50%</centertop>
							<width>37</width>
							<height>37</height>
							<texture colordiffuse="accent_color">$INFO[ListItem.PercentPlayed,indicator/progress/p,.png]</texture>
							<aspectratio align="center" aligny="center">keep</aspectratio>
							<visible>ListItem.IsResumable + !ListItem.IsPlaying</visible>
						</control>
						<!-- Watched checkmark (fully watched, not resuming) -->
						<control type="image">
							<left>41</left>
							<centertop>50%</centertop>
							<width>24</width>
							<height>24</height>
							<texture colordiffuse="FF66BB6A">indicator/checkmark.png</texture>
							<aspectratio align="center" aligny="center">keep</aspectratio>
							<visible>Integer.IsGreater(ListItem.Playcount,0) + !ListItem.IsResumable + !ListItem.IsPlaying</visible>
						</control>
						<control type="label">
							<left>105</left>
							<top>0</top>
							<bottom>0</bottom>
							<right>40</right>
							<aligny>center</aligny>
							<font>font32</font>
							<textcolor>unfocused_text</textcolor>
							<label>$VAR[ListLabelVar]</label>
							<shadowcolor>text_shadow</shadowcolor>
						</control>
						<control type="label">
							<left>105</left>
							<top>0</top>
							<bottom>0</bottom>
							<right>40</right>
							<align>right</align>
							<aligny>center</aligny>
							<font>font32</font>
							<textcolor>unfocused_text</textcolor>
							<label>$INFO[ListItem.Rating]</label>
							<visible>!String.IsEqual(ListItem.DBtype,tvshow) + !String.IsEqual(ListItem.DbType,season)</visible>
							<shadowcolor>text_shadow</shadowcolor>
						</control>
						<control type="label">
							<left>105</left>
							<top>0</top>
							<bottom>0</bottom>
							<right>40</right>
							<align>right</align>
							<aligny>center</aligny>
							<font>font32</font>
							<textcolor>unfocused_text</textcolor>
							<label>$INFO[ListItem.Property(WatchedEpisodes)]$INFO[ListItem.Property(TotalEpisodes), / ,]</label>
							<visible>String.IsEqual(ListItem.DbType,season)</visible>
							<shadowcolor>text_shadow</shadowcolor>
						</control>
						<control type="group">
							<visible>String.IsEqual(ListItem.DBtype,tvshow)</visible>
							<control type="label">
								<width>180</width>
								<top>0</top>
								<bottom>0</bottom>
								<right>125</right>
								<align>right</align>
								<aligny>center</aligny>
								<textcolor>unfocused_text</textcolor>
								<label>$INFO[ListItem.Property(WatchedEpisodes)]$INFO[ListItem.Property(TotalEpisodes), / ,]</label>
							</control>
							<control type="label">
								<width>100</width>
								<top>0</top>
								<bottom>0</bottom>
								<right>40</right>
								<align>right</align>
								<aligny>center</aligny>
								<textcolor>unfocused_text</textcolor>
								<label>  •  $INFO[ListItem.Rating]</label>
							</control>
							<shadowcolor>text_shadow</shadowcolor>
						</control>
					</itemlayout>

					<!-- GENERIC (non-media, non-songs, non-addons, non-playlists) -->
					<focusedlayout height="85" condition="!Container.Content(songs) + !Container.Content(addons) + !Container.Content(playlists) + !Container.Content() + !Container.Content(tvshows) + !Container.Content(seasons) + !Container.Content(episodes) + !Container.Content(movies) + !Container.Content(musicvideos) + !Container.Content(videos)+ !Container.Content(favourites)">
						<control type="image">
							<left>0</left>
							<right>0</right>
							<top>0</top>
							<bottom>0</bottom>
							<texture border="12" colordiffuse="00FFFFFF">masks/focus_pill.png</texture>
							<visible>Control.HasFocus(55)</visible>
						</control>
						<control type="image">
							<left>35</left>
							<centertop>50%</centertop>
							<width>32</width>
							<height>32</height>
							<texture>$VAR[ListWatchedIconVar]</texture>
						</control>
						<control type="label">
							<left>105</left>
							<top>0</top>
							<bottom>0</bottom>
							<right>40</right>
							<aligny>center</aligny>
							<scroll>true</scroll>
							<font>font32_title</font>
							<textcolor>focused_text</textcolor>
							<label>$INFO[ListItem.Label]</label>
							<shadowcolor>text_shadow</shadowcolor>
						</control>
						<control type="label">
							<left>105</left>
							<top>0</top>
							<bottom>0</bottom>
							<right>40</right>
							<align>right</align>
							<aligny>center</aligny>
							<textcolor>focused_text</textcolor>
							<label>$VAR[ListLabel2Var]</label>
							<shadowcolor>text_shadow</shadowcolor>
						</control>
					</focusedlayout>
					<itemlayout height="list_item_height" condition="!Container.Content(songs) + !Container.Content(addons) + !Container.Content(playlists) + !Container.Content() + !Container.Content(tvshows) + !Container.Content(seasons) + !Container.Content(episodes) + !Container.Content(movies) + !Container.Content(musicvideos) + !Container.Content(videos) + !Container.Content(favourites)">
						<control type="image">
							<left>35</left>
							<centertop>50%</centertop>
							<width>32</width>
							<height>32</height>
							<texture colordiffuse="grey">$VAR[ListWatchedIconVar]</texture>
						</control>
						<control type="label">
							<left>105</left>
							<top>0</top>
							<bottom>0</bottom>
							<right>40</right>
							<aligny>center</aligny>
							<font>font32</font>
							<textcolor>unfocused_text</textcolor>
							<label>$VAR[ListLabelVar]</label>
							<shadowcolor>text_shadow</shadowcolor>
						</control>
						<control type="label">
							<left>105</left>
							<top>0</top>
							<bottom>0</bottom>
							<right>40</right>
							<align>right</align>
							<aligny>center</aligny>
							<font>font32</font>
							<textcolor>unfocused_text</textcolor>
							<label>$VAR[ListLabel2Var]</label>
							<shadowcolor>text_shadow</shadowcolor>
						</control>
					</itemlayout>

					<!-- PLAYLISTS / FAVOURITES / EMPTY -->
					<focusedlayout height="85" top="200" condition="Container.Content(playlists) | Container.Content(favourites) | Container.Content()">
						<control type="image">
							<left>0</left>
							<right>0</right>
							<top>0</top>
							<bottom>0</bottom>
							<texture border="12" colordiffuse="00FFFFFF">masks/focus_pill.png</texture>
							<visible>Control.HasFocus(55)</visible>
						</control>
						<control type="image">
							<left>20</left>
							<centertop>50%</centertop>
							<height>60</height>
							<width>60</width>
							<bottom>10</bottom>
							<aspectratio>keep</aspectratio>
							<texture>$INFO[ListItem.Icon]</texture>
						</control>
						<control type="label">
							<left>105</left>
							<top>0</top>
							<bottom>0</bottom>
							<right>40</right>
							<aligny>center</aligny>
							<scroll>true</scroll>
							<font>font32_title</font>
							<textcolor>focused_text</textcolor>
							<label>$INFO[ListItem.Label]</label>
							<shadowcolor>text_shadow</shadowcolor>
						</control>
					</focusedlayout>
					<itemlayout height="list_item_height" condition="Container.Content(playlists) | Container.Content(favourites) | Container.Content()">
						<control type="image">
							<left>20</left>
							<centertop>50%</centertop>
							<height>60</height>
							<width>60</width>
							<bottom>10</bottom>
							<aspectratio>keep</aspectratio>
							<texture colordiffuse="grey">$INFO[ListItem.Icon]</texture>
						</control>
						<control type="label">
							<left>105</left>
							<top>0</top>
							<bottom>0</bottom>
							<right>40</right>
							<aligny>center</aligny>
							<textcolor>unfocused_text</textcolor>
							<label>$INFO[ListItem.Label]</label>
							<shadowcolor>text_shadow</shadowcolor>
						</control>
					</itemlayout>

					<include condition="Window.IsActive(music)">SongsListLayout</include>
					<include>AddonsListLayout</include>
				</control>
			</control>
		</definition>
	</include>
	<include name="SongsListLayout">
		<focusedlayout height="list_item_height" condition="Container.Content(songs)">
			<control type="image">
				<left>0</left>
				<right>0</right>
				<texture border="12" colordiffuse="00FFFFFF">masks/focus_pill.png</texture>
				<visible>Control.hasFocus(55)</visible>
			</control>
			<control type="label">
				<left>35</left>
				<right>40</right>
				<aligny>center</aligny>
				<scroll>true</scroll>
				<label>$VAR[ListLabelVar]</label>
				<shadowcolor>text_shadow</shadowcolor>
			</control>
			<control type="label">
				<left>35</left>
				<right>40</right>
				<align>right</align>
				<aligny>center</aligny>
				<label>$VAR[ListLabel2Var]</label>
				<shadowcolor>text_shadow</shadowcolor>
			</control>
		</focusedlayout>
		<itemlayout height="list_item_height" condition="Container.Content(songs)">
			<control type="label">
				<left>35</left>
				<right>40</right>
				<aligny>center</aligny>
				<label>$VAR[ListLabelVar]</label>
				<shadowcolor>text_shadow</shadowcolor>
			</control>
			<control type="label">
				<left>35</left>
				<right>40</right>
				<align>right</align>
				<aligny>center</aligny>
				<label>$VAR[ListLabel2Var]</label>
				<textcolor>grey</textcolor>
				<shadowcolor>text_shadow</shadowcolor>
			</control>
		</itemlayout>
	</include>
	<include name="AddonsListLayout">
		<focusedlayout height="85" condition="Container.Content(addons)">
			<control type="image">
				<left>20</left>
				<width>37</width>
				<height>37</height>
				<centertop>50%</centertop>
				<texture>$VAR[AddonsListIconVar]</texture>
			</control>
			<control type="label">
				<left>75</left>
				<right>40</right>
				<aligny>center</aligny>
				<scroll>true</scroll>
				<font>font52_title</font>
				<label>$INFO[ListItem.Label]</label>
			</control>
			<control type="label">
				<left>75</left>
				<right>90</right>
				<align>right</align>
				<aligny>center</aligny>
				<font>font32_title</font>
				<label>$VAR[AddonsLabel2Var]</label>
				<scroll>true</scroll>
			</control>
			<control type="image">
				<right>40</right>
				<centertop>50%</centertop>
				<width>37</width>
				<height>37</height>
				<texture>$VAR[AddonsOriginVar]</texture>
				<visible>!ListItem.IsFolder</visible>
			</control>
		</focusedlayout>
		<itemlayout height="list_item_height" condition="Container.Content(addons)">
			<control type="image">
				<left>20</left>
				<width>37</width>
				<height>37</height>
				<centertop>50%</centertop>
				<texture>$VAR[AddonsListIconVar]</texture>
			</control>
			<control type="label">
				<left>75</left>
				<right>40</right>
				<aligny>center</aligny>
				<textcolor>unfocused_text</textcolor>
				<label>$INFO[ListItem.Label]</label>
			</control>
			<control type="label">
				<left>75</left>
				<right>90</right>
				<align>right</align>
				<aligny>center</aligny>
				<font>font27</font>
				<label>$VAR[AddonsLabel2Var]</label>
				<textcolor>unfocused_text</textcolor>
				<shadowcolor>text_shadow</shadowcolor>
			</control>
			<control type="image">
				<right>40</right>
				<centertop>50%</centertop>
				<width>37</width>
				<height>37</height>
				<texture>$VAR[AddonsOriginVar]</texture>
				<visible>!ListItem.IsFolder</visible>
			</control>
		</itemlayout>
	</include>
</includes>
