<?xml version="1.0" encoding="UTF-8"?>
<includes>

	<!-- ── Audio / Subtitle stream picker ── -->
	<!-- Row layout: [UPPER ISO code] | [Label2 codec]   [CC badge] [○/✓] [Flag]  -->
	<!-- Flag path built from ListItem.Label (ISO 639-2 code e.g. "eng", "fre")   -->
	<include name="AudioSubStreamLayout">
		<control type="group">
			<centerleft>50%</centerleft>
			<centertop>50%</centertop>
			<width>800</width>
			<height>720</height>

			<!-- Dark overlay + click-to-close background -->
			<control type="image">
				<left>-2000</left>
				<top>-2000</top>
				<width>6000</width>
				<height>6000</height>
				<texture colordiffuse="80000000">colors/black.png</texture>
				<animation effect="fade" start="0" end="100" time="250">WindowOpen</animation>
				<animation effect="fade" start="100" end="0" time="200">WindowClose</animation>
			</control>
			<control type="button">
				<left>-2000</left>
				<top>-2000</top>
				<width>6000</width>
				<height>6000</height>
				<texturefocus />
				<texturenofocus />
				<onclick>Action(Close)</onclick>
			</control>

			<!-- Dialog panel -->
			<control type="group">
				<width>800</width>
				<height>720</height>
				<animation effect="fade" start="0" end="100" time="200">WindowOpen</animation>
				<animation effect="fade" start="100" end="0" time="150">WindowClose</animation>

				<!-- Panel background -->
				<control type="image">
					<texture colordiffuse="dialog_bg">masks/landscape.png</texture>
				</control>
				<control type="image">
					<left>-2</left>
					<top>-2</top>
					<right>-2</right>
					<bottom>-2</bottom>
					<texture colordiffuse="22FFFFFF">masks/landscape.png</texture>
				</control>

				<!-- Header: title (set by Kodi via id=1) -->
				<control type="label" id="1">
					<left>30</left>
					<top>0</top>
					<width>650</width>
					<height>80</height>
					<font>font32_title</font>
					<aligny>center</aligny>
					<textcolor>unfocused_text</textcolor>
					<shadowcolor>black</shadowcolor>
				</control>

				<!-- Header icon: speaker for audio, CC for subtitles -->
				<control type="image">
					<right>25</right>
					<top>22</top>
					<width>36</width>
					<height>36</height>
					<texture colordiffuse="grey">osd/fullscreen/buttons/audio.png</texture>
					<visible>Window.IsActive(osdaudiosettings)</visible>
				</control>
				<control type="image">
					<right>25</right>
					<top>22</top>
					<width>36</width>
					<height>36</height>
					<texture colordiffuse="grey">osd/fullscreen/buttons/settings-subtitle.png</texture>
					<visible>Window.IsActive(osdsubtitlesettings)</visible>
				</control>

				<!-- Divider under header -->
				<control type="image">
					<left>20</left>
					<top>80</top>
					<right>20</right>
					<height>1</height>
					<texture colordiffuse="22FFFFFF">colors/white.png</texture>
				</control>

				<!-- Stream list -->
				<control type="list" id="3">
					<scrolltime condition="Skin.HasSetting(touchmode)">0</scrolltime>
					<left>0</left>
					<top>82</top>
					<width>800</width>
					<bottom>10</bottom>
					<onleft>3</onleft>
					<onright>3</onright>
					<onup>3</onup>
					<ondown>3</ondown>
					<scrolltime>200</scrolltime>

					<!-- ── Unfocused row ── -->
					<texturefocus />
					<texturenofocus />
					<itemlayout width="800" height="90">
						<!-- Row divider bottom -->
						<control type="image">
							<left>20</left>
							<top>89</top>
							<right>20</right>
							<height>1</height>
							<texture colordiffuse="18FFFFFF">colors/white.png</texture>
						</control>
						<!-- ISO code uppercase -->
						<control type="label">
							<left>30</left>
							<top>0</top>
							<width>90</width>
							<height>90</height>
							<aligny>center</aligny>
							<font>font14</font>
							<textcolor>unfocused_text</textcolor>
							<label>[UPPERCASE]$INFO[ListItem.Label][/UPPERCASE]</label>
						</control>
						<!-- Pipe separator -->
						<control type="label">
							<left>120</left>
							<top>0</top>
							<width>20</width>
							<height>90</height>
							<aligny>center</aligny>
							<font>font14</font>
							<textcolor>grey</textcolor>
							<label>|</label>
						</control>
						<!-- Language / codec description -->
						<control type="label">
							<left>148</left>
							<top>0</top>
							<right>215</right>
							<height>90</height>
							<aligny>center</aligny>
							<font>font14</font>
							<textcolor>unfocused_text</textcolor>
							<label>$INFO[ListItem.Label2]</label>
						</control>
						<!-- CC badge -->
						<control type="image">
							<right>175</right>
							<top>29</top>
							<width>50</width>
							<height>32</height>
							<texture colordiffuse="60FFFFFF">flags/color/language/scc.png</texture>
							<aspectratio>keep</aspectratio>
						</control>
						<!-- Selection indicator: circle (unselected) -->
						<control type="image">
							<right>115</right>
							<top>27</top>
							<width>36</width>
							<height>36</height>
							<texture colordiffuse="60FFFFFF">lists/circle-fo.png</texture>
							<visible>!ListItem.IsSelected</visible>
						</control>
						<!-- Selection indicator: checkmark (selected) -->
						<control type="image">
							<right>115</right>
							<top>27</top>
							<width>36</width>
							<height>36</height>
							<texture colordiffuse="accent_color">indicator/checkmark.png</texture>
							<visible>ListItem.IsSelected</visible>
						</control>
						<!-- Country flag -->
						<control type="image">
							<right>20</right>
							<top>18</top>
							<width>80</width>
							<height>54</height>
							<texture colordiffuse="C0FFFFFF">$INFO[ListItem.Label,flags/color/language/,.png]</texture>
							<aspectratio>keep</aspectratio>
						</control>
					</itemlayout>

					<!-- ── Focused row ── -->
					<focusedlayout width="800" height="90">
						<!-- Focus highlight -->
						<control type="image">
							<left>4</left>
							<top>0</top>
							<right>0</right>
							<height>90</height>
							<texture colordiffuse="18FFFFFF">colors/white.png</texture>
							<visible>Control.HasFocus(3)</visible>
						</control>
						<!-- Gold left accent bar -->
						<control type="image">
							<left>0</left>
							<top>5</top>
							<width>4</width>
							<height>80</height>
							<texture colordiffuse="accent_color">colors/white.png</texture>
							<visible>Control.HasFocus(3)</visible>
						</control>
						<!-- Row divider bottom -->
						<control type="image">
							<left>20</left>
							<top>89</top>
							<right>20</right>
							<height>1</height>
							<texture colordiffuse="18FFFFFF">colors/white.png</texture>
						</control>
						<!-- ISO code uppercase (gold when focused) -->
						<control type="label">
							<left>30</left>
							<top>0</top>
							<width>90</width>
							<height>90</height>
							<aligny>center</aligny>
							<font>font14</font>
							<textcolor>accent_color</textcolor>
							<label>[B][UPPERCASE]$INFO[ListItem.Label][/UPPERCASE][/B]</label>
						</control>
						<!-- Pipe separator -->
						<control type="label">
							<left>120</left>
							<top>0</top>
							<width>20</width>
							<height>90</height>
							<aligny>center</aligny>
							<font>font14</font>
							<textcolor>grey</textcolor>
							<label>|</label>
						</control>
						<!-- Language / codec description -->
						<control type="label">
							<left>148</left>
							<top>0</top>
							<right>215</right>
							<height>90</height>
							<aligny>center</aligny>
							<font>font14</font>
							<textcolor>unfocused_text</textcolor>
							<label>$INFO[ListItem.Label2]</label>
						</control>
						<!-- CC badge (brighter when focused) -->
						<control type="image">
							<right>175</right>
							<top>29</top>
							<width>50</width>
							<height>32</height>
							<texture colordiffuse="A0FFFFFF">flags/color/language/scc.png</texture>
							<aspectratio>keep</aspectratio>
						</control>
						<!-- Selection indicator: circle (unselected) -->
						<control type="image">
							<right>115</right>
							<top>27</top>
							<width>36</width>
							<height>36</height>
							<texture colordiffuse="A0FFFFFF">lists/circle-fo.png</texture>
							<visible>!ListItem.IsSelected</visible>
						</control>
						<!-- Selection indicator: checkmark (selected) -->
						<control type="image">
							<right>115</right>
							<top>27</top>
							<width>36</width>
							<height>36</height>
							<texture colordiffuse="accent_color">indicator/checkmark.png</texture>
							<visible>ListItem.IsSelected</visible>
						</control>
						<!-- Country flag (full opacity when focused) -->
						<control type="image">
							<right>20</right>
							<top>18</top>
							<width>80</width>
							<height>54</height>
							<texture>$INFO[ListItem.Label,flags/color/language/,.png]</texture>
							<aspectratio>keep</aspectratio>
						</control>
					</focusedlayout>
				</control>
			</control>

			<!-- Hidden cancel button (required by Kodi dialog system) -->
			<control type="button" id="7">
				<include>HiddenObject</include>
				<onclick>Action(Close)</onclick>
			</control>
		</control>
	</include>

