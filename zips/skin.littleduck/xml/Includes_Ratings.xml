<?xml version="1.0" encoding="UTF-8"?>
<includes>

	<!-- ═══════════════════════════════════════════════════════════════
	     Includes_Ratings.xml
	     All rating display components.
	
	     Includes defined here:
	       RatingChip        — icon + score label (used in widget category bars
	                           and the spotlight hero rating strip)
	       RatingsInfoPanel  — full multi-source rating panel (DialogVideoInfo,
	                           ExtraInfo, spotlight detail overlays)
	
	     NOTE: $VAR[] is illegal inside <visible>.  All conditions that control
	     chip/panel visibility are passed via $PARAM[visible] or hardcoded per
	     chip because they reference window properties that change per-item.
	═══════════════════════════════════════════════════════════════ -->

	<include name="RatingChip">
		<param name="itemgap">8</param>
		<param name="label_max">60</param>
		<param name="image_top">0</param>		<!-- 0 for most contexts; 45 for widget label bar -->
		<definition>
			<control type="grouplist">
				<scrolltime condition="Skin.HasSetting(touchmode)">0</scrolltime>
				<width>$PARAM[width]</width>
				<orientation>horizontal</orientation>
				<itemgap>$PARAM[itemgap]</itemgap>
				<align>left</align>
				<visible>$PARAM[visible]</visible>
				<control type="image">
					<top>$PARAM[image_top]</top>
					<width>$PARAM[image_width]</width>
					<aspectratio>keep</aspectratio>
					<align>left</align>
					<aligny>center</aligny>
					<texture>$PARAM[texture]</texture>
				</control>
				<control type="label">
					<width max="$PARAM[label_max]">auto</width>
					<height>32</height>
					<align>left</align>
					<label>$PARAM[label]</label>
				</control>
			</control>
		</definition>
	</include>

	<include name="RatingsInfoPanel">
		<param name="left">30</param>
		<param name="width">525</param>
		<param name="top">346</param>
		<param name="ratings_spacing">25</param>
		<param name="height_noalt">375</param>
		<param name="height_alt_movie">250</param>
		<param name="height_alt_tvshow">170</param>
		<!-- set false to hide verbose metadata text (hero-style panels use compact infoline instead) -->
		<param name="show_infopanel_top">true</param>
		<definition>
		<control type="grouplist">
			<scrolltime condition="Skin.HasSetting(touchmode)">0</scrolltime>
			<left>$PARAM[left]</left>
			<width>$PARAM[width]</width>
			<top>$PARAM[top]</top>
			<orientation>vertical</orientation>
			<itemgap>13</itemgap>
			<control type="textbox">
				<height>auto</height>
				<font>font36_title</font>
				<label>Season $INFO[ListItem.Season], Episode $INFO[ListItem.Episode]</label>
				<textcolor>unfocused_text</textcolor>
				<visible>String.IsEqual(ListItem.DbType,episode)</visible>
			</control>
			<control type="textbox">
				<height>auto</height>
				<label>$VAR[InfoPanelTop]</label>
				<textcolor>unfocused_text</textcolor>
				<visible>$PARAM[show_infopanel_top]</visible>
			</control>
			<!-- Row 1: Metacritic · RT Critics · RT Audience · IMDb · Popularity
			     Row 2: TMDb · Trakt · Letterboxd · Awards · Votes
			     Each chip is a <group> — invisible chips collapse to zero width in the
			     grouplist so visible chips pack left with no gaps within each row.
			     Row 2 hides entirely when all 5 of its chips are N/A. -->
			<control type="grouplist">
				<scrolltime condition="Skin.HasSetting(touchmode)">0</scrolltime>
				<height>90</height>
				<orientation>horizontal</orientation>
				<itemgap>$PARAM[ratings_spacing]</itemgap>
				<visible>[String.IsEqual(ListItem.DBtype,movie) | String.IsEqual(ListItem.DBtype,tvshow) | String.IsEqual(ListItem.DBtype,season) | String.IsEqual(ListItem.DBtype,episode) | Container.Content(movies) | Container.Content(tvshows) | Container.Content(seasons) | Container.Content(episodes)]</visible>
				<control type="group">
					<width>60</width>
					<visible>![String.IsEmpty(Window.Property(littleduck.metascore)) | Skin.HasSetting(Disable.MetacriticRating)]</visible>
					<control type="image">
						<width>60</width><height>36</height>
						<aspectratio>keep</aspectratio><align>center</align><aligny>center</aligny>
						<texture>$INFO[Window.Property(littleduck.metascoreImage)]</texture>
					</control>
					<control type="label">
						<top>41</top><width>60</width><height>42</height>
						<align>center</align><aligny>center</aligny>
						<label>$INFO[Window.Property(littleduck.metascore)]</label>
						<textcolor>unfocused_text</textcolor>
					</control>
				</control>
				<control type="group">
					<width>60</width>
					<visible>![String.IsEmpty(Window.Property(littleduck.tomatoMeter)) | Skin.HasSetting(Disable.RTCRating)]</visible>
					<control type="image">
						<width>60</width><height>36</height>
						<aspectratio>keep</aspectratio><align>center</align><aligny>center</aligny>
						<texture>$INFO[Window.Property(littleduck.tomatoImage)]</texture>
					</control>
					<control type="label">
						<top>41</top><width>60</width><height>42</height>
						<align>center</align><aligny>center</aligny>
						<label>$INFO[Window.Property(littleduck.tomatoMeter)]</label>
						<textcolor>unfocused_text</textcolor>
					</control>
				</control>
				<control type="group">
					<width>60</width>
					<visible>![String.IsEmpty(Window.Property(littleduck.tomatoUserMeter)) | Skin.HasSetting(Disable.RTARating)]</visible>
					<control type="image">
						<width>60</width><height>36</height>
						<aspectratio>keep</aspectratio><align>center</align><aligny>center</aligny>
						<texture>$INFO[Window.Property(littleduck.tomatoUserImage)]</texture>
					</control>
					<control type="label">
						<top>41</top><width>60</width><height>42</height>
						<align>center</align><aligny>center</aligny>
						<label>$INFO[Window.Property(littleduck.tomatoUserMeter)]</label>
						<textcolor>unfocused_text</textcolor>
					</control>
				</control>
				<control type="group">
					<width>60</width>
					<visible>![String.IsEmpty(Window.Property(littleduck.imdbRating)) | Skin.HasSetting(Disable.IMDbRating)]</visible>
					<control type="image">
						<width>60</width><height>36</height>
						<aspectratio>keep</aspectratio><align>center</align><aligny>center</aligny>
						<texture>$INFO[Window.Property(littleduck.imdbImage)]</texture>
					</control>
					<control type="label">
						<top>41</top><width>60</width><height>42</height>
						<align>center</align><aligny>center</aligny>
						<label>$INFO[Window.Property(littleduck.imdbRating)]</label>
						<textcolor>unfocused_text</textcolor>
					</control>
				</control>
				<control type="group">
					<width>87</width>
					<visible>![String.IsEmpty(Window.Property(littleduck.popularRating)) | Skin.HasSetting(Disable.IMDbPopularRating)]</visible>
					<control type="image">
						<width>87</width><height>36</height>
						<aspectratio>keep</aspectratio><align>center</align><aligny>center</aligny>
						<texture>$INFO[Window.Property(littleduck.popularImage)]</texture>
					</control>
					<control type="label">
						<top>41</top><width>87</width><height>42</height>
						<align>center</align><aligny>center</aligny>
						<label>$INFO[Window.Property(littleduck.popularRating)]</label>
						<textcolor>unfocused_text</textcolor>
					</control>
				</control>
			</control>
			<control type="grouplist">
				<scrolltime condition="Skin.HasSetting(touchmode)">0</scrolltime>
				<height>90</height>
				<orientation>horizontal</orientation>
				<itemgap>$PARAM[ratings_spacing]</itemgap>
				<visible>[String.IsEqual(ListItem.DBtype,movie) | String.IsEqual(ListItem.DBtype,tvshow) | String.IsEqual(ListItem.DBtype,season) | String.IsEqual(ListItem.DBtype,episode) | Container.Content(movies) | Container.Content(tvshows) | Container.Content(seasons) | Container.Content(episodes)] + ![[String.IsEmpty(Window.Property(littleduck.tmdbRating)) | Skin.HasSetting(Disable.TMDbRating)] + [String.IsEmpty(Window.Property(littleduck.traktRating)) | Skin.HasSetting(Disable.TraktRating)] + [String.IsEmpty(Window.Property(littleduck.letterboxdRating)) | Skin.HasSetting(Disable.LetterboxdRating)] + [String.IsEmpty(Window.Property(littleduck.awardWins)) | Skin.HasSetting(Disable.AwardWins)] + String.IsEmpty(Window.Property(littleduck.omdbVotes))]</visible>
				<control type="group">
					<width>65</width>
					<visible>![String.IsEmpty(Window.Property(littleduck.tmdbRating)) | Skin.HasSetting(Disable.TMDbRating)]</visible>
					<control type="image">
						<width>65</width><height>33</height>
						<aspectratio>keep</aspectratio><align>center</align><aligny>center</aligny>
						<texture>$INFO[Window.Property(littleduck.tmdbImage)]</texture>
					</control>
					<control type="label">
						<top>41</top><width>65</width><height>42</height>
						<align>center</align><aligny>center</aligny>
						<label>$INFO[Window.Property(littleduck.tmdbRating)]</label>
						<textcolor>unfocused_text</textcolor>
					</control>
				</control>
				<control type="group">
					<width>60</width>
					<visible>![String.IsEmpty(Window.Property(littleduck.traktRating)) | Skin.HasSetting(Disable.TraktRating)]</visible>
					<control type="image">
						<width>60</width><height>36</height>
						<aspectratio>keep</aspectratio><align>center</align><aligny>center</aligny>
						<texture>$INFO[Window.Property(littleduck.traktImage)]</texture>
					</control>
					<control type="label">
						<top>41</top><width>60</width><height>42</height>
						<align>center</align><aligny>center</aligny>
						<label>$INFO[Window.Property(littleduck.traktRating)]</label>
						<textcolor>unfocused_text</textcolor>
					</control>
				</control>
				<control type="group">
					<width>60</width>
					<visible>![String.IsEmpty(Window.Property(littleduck.letterboxdRating)) | Skin.HasSetting(Disable.LetterboxdRating)]</visible>
					<control type="image">
						<width>60</width><height>36</height>
						<aspectratio>keep</aspectratio><align>center</align><aligny>center</aligny>
						<texture>$INFO[Window.Property(littleduck.letterboxdImage)]</texture>
					</control>
					<control type="label">
						<top>41</top><width>60</width><height>42</height>
						<align>center</align><aligny>center</aligny>
						<label>$INFO[Window.Property(littleduck.letterboxdRating)]</label>
						<textcolor>unfocused_text</textcolor>
					</control>
				</control>
				<control type="group">
					<width>60</width>
					<visible>![String.IsEmpty(Window.Property(littleduck.awardWins)) | Skin.HasSetting(Disable.AwardWins)]</visible>
					<control type="image">
						<width>60</width><height>36</height>
						<aspectratio>keep</aspectratio><align>center</align><aligny>center</aligny>
						<texture>$INFO[Window.Property(littleduck.awardImage)]</texture>
					</control>
					<control type="label">
						<top>41</top><width>60</width><height>42</height>
						<align>center</align><aligny>center</aligny>
						<label>$INFO[Window.Property(littleduck.awardWins)]</label>
						<textcolor>unfocused_text</textcolor>
					</control>
				</control>
				<control type="group">
					<width>80</width>
					<visible>!String.IsEmpty(Window.Property(littleduck.omdbVotes))</visible>
					<control type="image">
						<width>60</width><height>36</height>
						<aspectratio>keep</aspectratio><align>center</align><aligny>center</aligny>
						<texture>special://home/addons/skin.littleduck/resources/rating_images/user.png</texture>
					</control>
					<control type="label">
						<top>41</top><width>80</width><height>42</height>
						<align>center</align><aligny>center</aligny>
						<label>$INFO[Window.Property(littleduck.omdbVotes)]</label>
						<textcolor>unfocused_text</textcolor>
					</control>
				</control>
			</control>
			<control type="textbox">
				<height max="$PARAM[height_noalt]">auto</height>
				<bottom>70</bottom>
				<label>$VAR[InfoPanelBottom]</label>
				<textcolor>unfocused_text</textcolor>
				<autoscroll delay="7000" time="2000" repeat="7000">Skin.HasSetting(autoscroll)</autoscroll>
				<visible>!Skin.HasSetting(Enable.AlternateInfo)</visible>
			</control>
			<control type="textbox">
				<height max="$PARAM[height_alt_movie]">auto</height>
				<bottom>70</bottom>
				<label>$VAR[InfoPanelBottom]</label>
				<textcolor>unfocused_text</textcolor>
				<autoscroll delay="5000" time="2000" repeat="5000">Skin.HasSetting(autoscroll)</autoscroll>
				<visible>Skin.HasSetting(Enable.AlternateInfo) + [String.IsEqual(ListItem.DBtype,movie) | String.IsEqual(ListItem.DBtype,episode) | String.IsEqual(ListItem.DBtype,season)]</visible>
			</control>
			<control type="textbox">
				<height max="$PARAM[height_alt_tvshow]">auto</height>
				<bottom>70</bottom>
				<label>$VAR[InfoPanelBottom]</label>
				<textcolor>unfocused_text</textcolor>
				<autoscroll delay="5000" time="2000" repeat="5000">Skin.HasSetting(autoscroll)</autoscroll>
				<visible>Skin.HasSetting(Enable.AlternateInfo) + String.IsEqual(ListItem.DBtype,tvshow)</visible>
			</control>
		</control>
		</definition>
	</include>

	<!-- ═══════════════════════════════════════════════════════════════
	     RatingChipVertical — vertical variant: icon above score label.
	     Used in Spotlight hero rating strip and List view info panels.
	     Required params : width, image_width, visible, texture, label
	     Optional params : itemgap (default 5), label_max (default 60),
	                       image_height (default 36)
	═══════════════════════════════════════════════════════════════ -->
	<include name="RatingChipVertical">
		<param name="itemgap">5</param>
		<param name="label_max">60</param>
		<param name="image_height">36</param>
		<definition>
			<control type="grouplist">
				<width>$PARAM[width]</width>
				<orientation>vertical</orientation>
				<itemgap>$PARAM[itemgap]</itemgap>
				<align>center</align>
				<visible>$PARAM[visible]</visible>
				<control type="image">
					<width>$PARAM[image_width]</width>
					<height>$PARAM[image_height]</height>
					<aspectratio>keep</aspectratio>
					<align>center</align>
					<aligny>center</aligny>
					<texture>$PARAM[texture]</texture>
				</control>
				<control type="label">
					<width max="$PARAM[label_max]">auto</width>
					<height>42</height>
					<align>center</align>
					<aligny>center</aligny>
					<label>$PARAM[label]</label>
					<textcolor>unfocused_text</textcolor>
				</control>
			</control>
		</definition>
	</include>

</includes>
