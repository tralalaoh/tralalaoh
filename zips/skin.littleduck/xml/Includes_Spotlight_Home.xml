<?xml version="1.0" encoding="UTF-8"?>
<includes>

	<!--
		Spotlight Home Layout for skin.littleduck
		Inspired by Cosmic skin's vertical layout.
		Shows a fullscreen fanart hero with title/meta/plot/studio on the left,
		and a poster widget row at the bottom.
		Toggle via SkinSettings > Home > Home Layout.
	-->

	<include name="Spotlight_Main">
		<control type="group">
			<include>OpenClose_Fade</include>
			<animation effect="fade" start="0" end="100" time="400">WindowOpen</animation>
			<animation effect="fade" start="100" end="0" time="200">WindowClose</animation>

			<!-- ============================================================ -->
			<!-- FANART: Top-right 65%w x 55%h region                        -->
			<!-- ============================================================ -->
			<control type="multiimage">
				<depth>DepthBackground</depth>
				<left>672</left>
				<top>0</top>
				<right>0</right>
				<bottom>380</bottom>
				<aspectratio align="right" aligny="top">scale</aspectratio>
				<fadetime>600</fadetime>
				<animation effect="fade" start="0" end="100" time="400">WindowOpen</animation>
				<animation effect="fade" time="400">VisibleChange</animation>
				<imagepath background="true" colordiffuse="$VAR[BackgroundBrightnessVar]">$VAR[HomeFanartVar]</imagepath>
				<visible>!Player.HasMedia</visible>
			</control>

			<!-- ============================================================ -->
			<!-- LEFT VIGNETTE: dark at fanart left edge (x=672), fades       -->
			<!-- right into the fanart                                        -->
			<!-- ============================================================ -->
			<control type="image">
				<left>0</left>
				<top>0</top>
				<width>100%</width>
				<height>100%</height>
				<aspectratio>stretch</aspectratio>
				<texture>overlays/fanart_overlay.png</texture>
			</control>

			<!-- ============================================================ -->
			<!-- BOTTOM GRADIENT: fades up into fanart bottom (y=700) and     -->
			<!-- covers widget rows below                                     -->
			<!-- ============================================================ -->
			<control type="image">
				<left>0</left>
				<top>430</top>
				<width>100%</width>
				<bottom>0</bottom>
				<aspectratio>stretch</aspectratio>
				<texture>overlays/gradient-bottom.png</texture>
			</control>

			<!-- ============================================================ -->
			<!-- STUDIO LOGO: coloured logo top-right, below clock, over fanart -->
			<!-- ============================================================ -->
			<control type="image">
				<right>25</right>
				<top>82</top>
				<width>200</width>
				<height>55</height>
				<aspectratio aligny="center" align="right">keep</aspectratio>
				<texture fallback="">$VAR[SpotlightStudioLogo]</texture>
				<visible>[String.IsEqual(Container(9000).ListItem.Property(id),custom1) | String.IsEqual(Container(9000).ListItem.Property(id),movies) | String.IsEqual(Container(9000).ListItem.Property(id),tvshows) | String.IsEqual(Container(9000).ListItem.Property(id),custom2) | String.IsEqual(Container(9000).ListItem.Property(id),custom3)] + [!String.IsEmpty(Window(Home).Property(TMDbHelper.ListItem.Network.1.Name)) | !String.IsEmpty(Window(Home).Property(TMDbHelper.ListItem.Studio.1.Name)) | !String.IsEmpty(ListItem.Studio)] + String.IsEmpty(Window(Home).Property(spotlight.fav_active))</visible>
				<animation effect="fade" time="400">VisibleChange</animation>
			</control>

			<!-- ============================================================ -->
			<!-- SIDEBAR: Static vertical icon-only menu                      -->
			<!-- Top (fixedlist 9000): Search, Home, Films, TV, Anime,        -->
			<!--   Lists, Favourites                                           -->
			<!-- Bottom (buttons): Settings (9008), Power (9009)              -->
			<!-- ============================================================ -->
			<control type="group">
				<depth>DepthContentPanel</depth>
				<include>OpenClose_Left</include>

				<!-- Top nav items: Home, Films, TV, Anime, Lists — vertically centered -->
				<!-- Side nav pill background — 6 items × 90px = 540px, centered (top=270 = (1080-540)/2) -->
				<control type="image">
					<left>5</left>
					<top>270</top>
					<width>85</width>
					<height>540</height>
					<aspectratio>stretch</aspectratio>
					<texture colordiffuse="B214121A">masks/v_pill_bar.png</texture>
				</control>
				<control type="fixedlist" id="9000">
					<left>5</left>
					<top>270</top>
					<width>85</width>
					<height>540</height>
					<movement>8</movement>
					<focusposition>1</focusposition>
					<onfocus>ClearProperty(listposition,home)</onfocus>
					<onfocus>ClearProperty(spotlight.fav_active,home)</onfocus>
					<ondown>9000</ondown>
					<onup>808</onup>
					<onright condition="String.IsEqual(Container(9000).ListItem.Property(id),custom1)">39061</onright>
					<onright condition="String.IsEqual(Container(9000).ListItem.Property(id),movies)">38061</onright>
					<onright condition="String.IsEqual(Container(9000).ListItem.Property(id),tvshows)">37061</onright>
					<onright condition="String.IsEqual(Container(9000).ListItem.Property(id),custom2)">36061</onright>
					<onright condition="String.IsEqual(Container(9000).ListItem.Property(id),custom3)">35061</onright>
					<onright condition="String.IsEqual(Container(9000).ListItem.Property(id),music)">49100</onright>
					<onright condition="String.IsEqual(Container(9000).ListItem.Property(id),addons)">49200</onright>
					<onright condition="String.IsEqual(Container(9000).ListItem.Property(id),videos)">49300</onright>
					<onright condition="String.IsEqual(Container(9000).ListItem.Property(id),livetv)">49400</onright>
					<onright condition="String.IsEqual(Container(9000).ListItem.Property(id),radio)">49500</onright>
					<onright condition="String.IsEqual(Container(9000).ListItem.Property(id),pictures)">49600</onright>
					<onright condition="String.IsEqual(Container(9000).ListItem.Property(id),musicvideos)">49700</onright>
					<onright condition="String.IsEqual(Container(9000).ListItem.Property(id),games)">49800</onright>
					<onright>9000</onright>
					<scrolltime tween="cubic" easing="out">500</scrolltime>
					<texturefocus />
					<texturenofocus />
					<focusedlayout height="90">
						<!-- Icon full brightness when focused — no circle -->
						<control type="image">
							<include>FocusBounce</include>
							<left>18</left>
							<top>20</top>
							<width>50</width>
							<height>50</height>
							<aspectratio>keep</aspectratio>
							<texture colordiffuse="FFFFFFFF">$INFO[ListItem.Thumb]</texture>
						</control>
					</focusedlayout>
					<itemlayout height="90">
						<!-- Dimmed when unfocused -->
						<control type="image">
							<left>18</left>
							<top>20</top>
							<width>50</width>
							<height>50</height>
							<aspectratio>keep</aspectratio>
							<texture colordiffuse="40FFFFFF">$INFO[ListItem.Thumb]</texture>
						</control>
					</itemlayout>
					<content>
						<!-- 1. HOME (CUSTOM 1) -->
						<item>
							<label>$LOCALIZE[10000]</label>
							<onclick condition="Skin.HasSetting(touchmode)">Action(MoveRight)</onclick>
							<onclick condition="!Skin.HasSetting(touchmode)">ActivateWindow(Videos,plugin://plugin.video.rabitewatch/,return)</onclick>
							<property name="menu_id">$NUMBER[23000]</property>
							<thumb>$INFO[Skin.String(menu.custom1.icon)]</thumb>
							<property name="id">custom1</property>
						</item>
						<!-- 2. FILMS (MOVIES) -->
						<item>
							<label>$LOCALIZE[342]</label>
							<onclick condition="Skin.HasSetting(touchmode)">Action(MoveRight)</onclick>
							<onclick condition="!Skin.HasSetting(touchmode)">ActivateWindow(Videos,plugin://plugin.video.themoviedb.helper/?info=popular&amp;tmdb_type=movie,return)</onclick>
							<property name="menu_id">$NUMBER[19000]</property>
							<thumb>$INFO[Skin.String(menu.movies.icon)]</thumb>
							<property name="id">movies</property>
							<visible>!Skin.HasSetting(HomeMenuNoMovieButton)</visible>
						</item>
						<!-- 3. TV SHOWS -->
						<item>
							<label>$LOCALIZE[20343]</label>
							<onclick condition="Skin.HasSetting(touchmode)">Action(MoveRight)</onclick>
							<onclick condition="!Skin.HasSetting(touchmode)">ActivateWindow(Videos,plugin://plugin.video.themoviedb.helper/?info=popular&amp;tmdb_type=tv,return)</onclick>
							<property name="menu_id">$NUMBER[22000]</property>
							<thumb>$INFO[Skin.String(menu.tvshows.icon)]</thumb>
							<property name="id">tvshows</property>
							<visible>!Skin.HasSetting(HomeMenuNoTVShowsButton)</visible>
						</item>
						<!-- 4. ANIME (CUSTOM 2) -->
						<item>
							<label>Anime</label>
							<onclick condition="Skin.HasSetting(touchmode)">Action(MoveRight)</onclick>
							<onclick condition="!Skin.HasSetting(touchmode)">ActivateWindow(Videos,plugin://plugin.video.themoviedb.helper/?info=trakt_trending&amp;genres=anime&amp;tmdb_type=tv,return)</onclick>
							<property name="menu_id">$NUMBER[24000]</property>
							<thumb>$INFO[Skin.String(menu.custom2.icon)]</thumb>
							<property name="id">custom2</property>
							<visible>!Skin.HasSetting(HomeMenuNoCustom2Button)</visible>
						</item>
						<!-- 5. LISTS (CUSTOM 3) -->
						<item>
							<label>Lists</label>
							<onclick condition="Skin.HasSetting(touchmode)">Action(MoveRight)</onclick>
							<onclick condition="!Skin.HasSetting(touchmode)">ActivateWindow(Videos,plugin://plugin.video.themoviedb.helper/?info=trakt_watchlist&amp;tmdb_type=movie,return)</onclick>
							<property name="menu_id">$NUMBER[25000]</property>
							<thumb>$INFO[Skin.String(menu.custom3.icon)]</thumb>
							<property name="id">custom3</property>
							<visible>!Skin.HasSetting(HomeMenuNoCustom3Button)</visible>
						</item>
						<!-- 6. MUSIC -->
						<item>
							<label>$LOCALIZE[2]</label>
							<onclick condition="Skin.HasSetting(touchmode)">Action(MoveRight)</onclick>
							<onclick condition="!Skin.HasSetting(touchmode)">ActivateWindow(Music,root,return)</onclick>
							<property name="menu_id">$NUMBER[7000]</property>
							<thumb>$INFO[Skin.String(menu.music.icon)]</thumb>
							<property name="id">music</property>
							<visible>!Skin.HasSetting(HomeMenuNoMusicButton)</visible>
						</item>
						<!-- 7. MUSIC VIDEOS -->
						<item>
							<label>$LOCALIZE[20389]</label>
							<onclick condition="Skin.HasSetting(touchmode)">Action(MoveRight)</onclick>
							<onclick condition="!Skin.HasSetting(touchmode)">ActivateWindow(Videos,musicvideos,return)</onclick>
							<property name="menu_id">$NUMBER[16000]</property>
							<thumb>$INFO[Skin.String(menu.musicvideos.icon)]</thumb>
							<property name="id">musicvideos</property>
							<visible>!Skin.HasSetting(HomeMenuNoMusicVideoButton)</visible>
						</item>
						<!-- 8. LIVE TV -->
						<item>
							<label>Live TV</label>
							<onclick condition="Skin.HasSetting(touchmode)">Action(MoveRight)</onclick>
							<onclick condition="!Skin.HasSetting(touchmode)">ActivateWindow(TVGuide)</onclick>
							<property name="menu_id">$NUMBER[12000]</property>
							<thumb>$INFO[Skin.String(menu.livetv.icon)]</thumb>
							<property name="id">livetv</property>
							<visible>!Skin.HasSetting(HomeMenuNoTVButton)</visible>
						</item>
						<!-- 9. RADIO -->
						<item>
							<label>$LOCALIZE[19021]</label>
							<onclick condition="Skin.HasSetting(touchmode)">Action(MoveRight)</onclick>
							<onclick condition="!Skin.HasSetting(touchmode)">ActivateWindow(RadioChannels)</onclick>
							<property name="menu_id">$NUMBER[13000]</property>
							<thumb>$INFO[Skin.String(menu.radio.icon)]</thumb>
							<property name="id">radio</property>
							<visible>!Skin.HasSetting(HomeMenuNoRadioButton)</visible>
						</item>
						<!-- 10. ADDONS -->
						<item>
							<label>$LOCALIZE[24001]</label>
							<onclick condition="Skin.HasSetting(touchmode)">Action(MoveRight)</onclick>
							<onclick condition="!Skin.HasSetting(touchmode)">ActivateWindow(programs,addons://user/,return)</onclick>
							<property name="menu_id">$NUMBER[8000]</property>
							<thumb>$INFO[Skin.String(menu.addons.icon)]</thumb>
							<property name="id">addons</property>
							<visible>!Skin.HasSetting(HomeMenuNoProgramsButton)</visible>
						</item>
						<!-- 11. PICTURES -->
						<item>
							<label>$LOCALIZE[1]</label>
							<onclick condition="Skin.HasSetting(touchmode)">Action(MoveRight)</onclick>
							<onclick condition="!Skin.HasSetting(touchmode)">ActivateWindow(Pictures)</onclick>
							<property name="menu_id">$NUMBER[4000]</property>
							<thumb>$INFO[Skin.String(menu.pictures.icon)]</thumb>
							<property name="id">pictures</property>
							<visible>!Skin.HasSetting(HomeMenuNoPicturesButton)</visible>
						</item>
						<!-- 12. VIDEOS -->
						<item>
							<label>$LOCALIZE[3]</label>
							<onclick condition="Skin.HasSetting(touchmode)">Action(MoveRight)</onclick>
							<onclick condition="!Skin.HasSetting(touchmode)">ActivateWindow(Videos,root)</onclick>
							<property name="menu_id">$NUMBER[11000]</property>
							<thumb>$INFO[Skin.String(menu.videos.icon)]</thumb>
							<property name="id">videos</property>
							<visible>!Skin.HasSetting(HomeMenuNoVideosButton)</visible>
						</item>
						<!-- 13. WEATHER -->
						<item>
							<label>$LOCALIZE[8]</label>
							<onclick condition="Skin.HasSetting(touchmode)">Action(MoveRight)</onclick>
							<onclick condition="!Skin.HasSetting(touchmode) + !String.IsEmpty(Weather.Plugin)">ActivateWindow(Weather)</onclick>
							<onclick condition="!Skin.HasSetting(touchmode) + String.IsEmpty(Weather.Plugin)">ReplaceWindow(servicesettings,weather)</onclick>
							<property name="menu_id">$NUMBER[15000]</property>
							<thumb>$INFO[Skin.String(menu.weather.icon)]</thumb>
							<property name="id">weather</property>
							<visible>!Skin.HasSetting(HomeMenuNoWeatherButton)</visible>
						</item>
						<!-- 14. GAMES -->
						<item>
							<label>$LOCALIZE[15016]</label>
							<onclick condition="Skin.HasSetting(touchmode)">Action(MoveRight)</onclick>
							<onclick condition="!Skin.HasSetting(touchmode)">ActivateWindow(Games)</onclick>
							<property name="menu_id">$NUMBER[17000]</property>
							<thumb>$INFO[Skin.String(menu.games.icon)]</thumb>
							<property name="id">games</property>
							<visible>System.GetBool(gamesgeneral.enable) + !Skin.HasSetting(HomeMenuNoGamesButton)</visible>
						</item>
					</content>
				</control>




			</control>
			<!-- ============================================================ -->
			<!-- HERO INFO PANEL — driven by SpotlightViewHero include         -->
			<!-- Edit Includes_SpotlightHero.xml to change fonts/spacing       -->
			<!-- ============================================================ -->
			<include content="SpotlightViewHero">
				<param name="clearlogo_texture" value="$VAR[SpotlightClearLogo]"/>
				<param name="clearlogo_visible" value="[String.IsEqual(Container(9000).ListItem.Property(id),custom1) + [!String.IsEmpty(Container(39100).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39110).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39121).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39151).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39161).ListItem.Art(clearlogo))]] | [String.IsEqual(Container(9000).ListItem.Property(id),movies) + [!String.IsEmpty(Container(39200).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39210).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39221).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39251).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39261).ListItem.Art(clearlogo))]] | [String.IsEqual(Container(9000).ListItem.Property(id),tvshows) + [!String.IsEmpty(Container(39300).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39310).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39321).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39351).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39361).ListItem.Art(clearlogo))]] | [String.IsEqual(Container(9000).ListItem.Property(id),custom2) + [!String.IsEmpty(Container(39400).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39410).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39421).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39451).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39461).ListItem.Art(clearlogo))]] | [String.IsEqual(Container(9000).ListItem.Property(id),custom3) + [!String.IsEmpty(Container(39500).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39510).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39521).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39551).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39561).ListItem.Art(clearlogo))]]"/>
				<param name="title_label"       value="$VAR[SpotlightTitle]"/>
				<param name="title_visible"     value="![[String.IsEqual(Container(9000).ListItem.Property(id),custom1) + [!String.IsEmpty(Container(39100).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39110).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39121).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39151).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39161).ListItem.Art(clearlogo))]] | [String.IsEqual(Container(9000).ListItem.Property(id),movies) + [!String.IsEmpty(Container(39200).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39210).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39221).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39251).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39261).ListItem.Art(clearlogo))]] | [String.IsEqual(Container(9000).ListItem.Property(id),tvshows) + [!String.IsEmpty(Container(39300).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39310).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39321).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39351).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39361).ListItem.Art(clearlogo))]] | [String.IsEqual(Container(9000).ListItem.Property(id),custom2) + [!String.IsEmpty(Container(39400).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39410).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39421).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39451).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39461).ListItem.Art(clearlogo))]] | [String.IsEqual(Container(9000).ListItem.Property(id),custom3) + [!String.IsEmpty(Container(39500).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39510).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39521).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39551).ListItem.Art(clearlogo)) | !String.IsEmpty(Container(39561).ListItem.Art(clearlogo))]]]"/>
				<param name="infoline_label"    value="$VAR[SpotlightInfoLine]"/>
				<param name="plot_label"        value="$VAR[SpotlightPlot]"/>
				<param name="panel_visible"     value="[String.IsEqual(Container(9000).ListItem.Property(id),custom1) | String.IsEqual(Container(9000).ListItem.Property(id),movies) | String.IsEqual(Container(9000).ListItem.Property(id),tvshows) | String.IsEqual(Container(9000).ListItem.Property(id),custom2) | String.IsEqual(Container(9000).ListItem.Property(id),custom3)] + String.IsEmpty(Window(Home).Property(spotlight.fav_active))"/>
				<!-- Home spotlight layout overrides: no vertical chips row; plot fills freed space; title+rating row at bottom -->
				<param name="show_ratings"      value="false"/>
				<param name="plot_top"          value="200"/>
				<param name="plot_height"       value="225"/>
				<param name="show_rating_row"   value="true"/>
			</include>


			<!-- ============================================================ -->
			<!-- SPOTLIGHT WIDGET ROWS (one per supported section)             -->
			<!-- ============================================================ -->
			<control type="group">
				<left>105</left>
				<top>490</top>
				<right>0</right>
				<bottom>0</bottom>

				<!-- CUSTOM 1 / HOME section -->
				<control type="group">
					<visible>String.IsEqual(Container(9000).ListItem.Property(id),custom1) + String.IsEmpty(Window(Home).Property(spotlight.fav_active))</visible>
					<include content="Custom1SpotlightTabs" />
					<include content="SpotlightDynamicList">
						<param name="list_id" value="39100"/>
						<param name="landscapeinfo_id" value="39121"/>
						<param name="walll_id" value="39151"/>
						<param name="wallp_id" value="39161"/>
						<param name="landscape_id" value="39110"/>
						<param name="type_prop" value="spotlight.custom1.type"/>
						<param name="tab_up_id" value="39061"/>
						<param name="content_prop" value="spotlight.custom1.path"/>
						<param name="tab_prop" value="spotlight.custom1.tab"/>
						<param name="tab2_id" value="39062"/>
						<param name="tab3_id" value="39063"/>
						<param name="tab4_id" value="39064"/>
						<param name="tab5_id" value="39065"/>
						<param name="widget_target" value="videos"/>
					</include>
				</control>

				<!-- MOVIES section -->
				<control type="group">
					<visible>String.IsEqual(Container(9000).ListItem.Property(id),movies) + String.IsEmpty(Window(Home).Property(spotlight.fav_active))</visible>
					<include content="MovieSpotlightTabs" />
					<include content="SpotlightDynamicList">
						<param name="list_id" value="39200"/>
						<param name="landscapeinfo_id" value="39221"/>
						<param name="walll_id" value="39251"/>
						<param name="wallp_id" value="39261"/>
						<param name="landscape_id" value="39210"/>
						<param name="type_prop" value="spotlight.movie.type"/>
						<param name="tab_up_id" value="38061"/>
						<param name="content_prop" value="spotlight.movie.path"/>
						<param name="tab_prop" value="spotlight.movie.tab"/>
						<param name="tab2_id" value="38062"/>
						<param name="tab3_id" value="38063"/>
						<param name="tab4_id" value="38064"/>
						<param name="tab5_id" value="38065"/>
						<param name="widget_target" value="videos"/>
					</include>
				</control>

				<!-- TVSHOWS section -->
				<control type="group">
					<visible>String.IsEqual(Container(9000).ListItem.Property(id),tvshows) + String.IsEmpty(Window(Home).Property(spotlight.fav_active))</visible>
					<include content="TVShowSpotlightTabs" />
					<include content="SpotlightDynamicList">
						<param name="list_id" value="39300"/>
						<param name="landscapeinfo_id" value="39321"/>
						<param name="walll_id" value="39351"/>
						<param name="wallp_id" value="39361"/>
						<param name="landscape_id" value="39310"/>
						<param name="type_prop" value="spotlight.tvshow.type"/>
						<param name="tab_up_id" value="37061"/>
						<param name="content_prop" value="spotlight.tvshow.path"/>
						<param name="tab_prop" value="spotlight.tvshow.tab"/>
						<param name="tab2_id" value="37062"/>
						<param name="tab3_id" value="37063"/>
						<param name="tab4_id" value="37064"/>
						<param name="tab5_id" value="37065"/>
						<param name="widget_target" value="videos"/>
					</include>
				</control>

				<!-- CUSTOM 2 / ANIME section -->
				<control type="group">
					<visible>String.IsEqual(Container(9000).ListItem.Property(id),custom2) + String.IsEmpty(Window(Home).Property(spotlight.fav_active))</visible>
					<include content="Custom2SpotlightTabs" />
					<include content="SpotlightDynamicList">
						<param name="list_id" value="39400"/>
						<param name="landscapeinfo_id" value="39421"/>
