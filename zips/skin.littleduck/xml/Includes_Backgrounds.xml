<?xml version="1.0" encoding="UTF-8"?>
<includes>

	<!-- ═══════════════════════════════════════════════════════════════
	     Includes_Backgrounds.xml
	     Background overlays, tinted images, and ambient animations.
	
	     Includes defined here:
	       ColoredBackgroundImages     — tinted fanart / colour overlay stack
	       DefaultBackground           — full-window default bg (fanart + colour)
	       RainDropAnimationBackground — ambient raindrop particle effect
	
	     All three are purely visual — no navigation, no focus, no content paths.
	═══════════════════════════════════════════════════════════════ -->

	<include name="ColoredBackgroundImages">
		<control type="image">
			<visible>[Skin.HasSetting(no_fanart) | String.IsEmpty(Listitem.Art(fanart))] + !Player.HasMedia + !Skin.HasSetting(TrailerPlaying)</visible>
			<depth>DepthBackground</depth>
			<include>FullScreenDimensions</include>
			<aspectratio>scale</aspectratio>
			<texture colordiffuse="$VAR[BackgroundBrightnessVar]" fallback="special://skin/extras/backgrounds/redblur.jpg">$VAR[CustomBackgroundImage]</texture>
		</control>
		<control type="image">
			<visible>Player.HasMedia + !Skin.HasSetting(TrailerPlaying)</visible>
			<depth>DepthBackground</depth>
			<include>FullScreenDimensions</include>
			<aspectratio>scale</aspectratio>
			<texture colordiffuse="CC141414" fallback="special://skin/extras/backgrounds/redblur.jpg">$VAR[CustomBackgroundImage]</texture>
		</control>
	</include>

	<include name="DefaultBackground">
		<definition>
			<control type="videowindow">
				<depth>DepthBackground</depth>
				<include>FullScreenDimensions</include>
				<visible>Player.HasVideo</visible>
				<visible>!Slideshow.IsActive</visible>
			</control>
			<control type="visualisation">
				<include>FullScreenDimensions</include>
				<visible>!Slideshow.IsActive</visible>
				<visible>Player.HasAudio + String.IsEmpty(Window(Videos).Property(PlayingBackgroundMedia)) + Visualisation.Enabled</visible>
			</control>
			<control type="group">
				<include>FullScreenDimensions</include>
				<animation effect="zoom" center="auto" end="102,102" time="0" condition="Integer.IsGreater(System.StereoscopicMode,0)">conditional</animation>
				<control type="group">
					<animation effect="fade" start="100" end="bg_alpha" time="0" condition="!Control.IsVisible(31111)">Conditional</animation>
					<animation effect="fade" start="0" end="100" time="300" condition="Window.Previous(fullscreenvideo) | Window.Previous(FullscreenGame) | Window.Previous(startup)">WindowOpen</animation>
					<include>ColoredBackgroundImages</include>
					<include>RainDropAnimationBackground</include>
				</control>
				<control type="group" id="31111">
					<visible>![Window.IsActive(Home) | Window.IsActive(1121)] + [![Player.HasVideo | [Player.HasAudio + Visualisation.Enabled + !String.IsEmpty(Visualisation.Name)]] | !String.IsEmpty(Window(Videos).Property(PlayingBackgroundMedia))]</visible>
					<depth>DepthBackground</depth>
					<animation effect="fade" start="0" end="100" time="400">WindowOpen</animation>
					<animation effect="fade" start="100" end="0" time="300">WindowClose</animation>
					<animation effect="fade" time="400">VisibleChange</animation>
					<control type="image" id="32111">
						<include>FullScreenDimensions</include>
						<aspectratio>scale</aspectratio>
						<fadetime>400</fadetime>
						<animation effect="fade" time="400">VisibleChange</animation>
						<texture background="true" colordiffuse="$VAR[FanartBrightnessVar]">$VAR[MediaFanartVar]</texture>
						<visible>!Control.IsVisible(502) | $EXP[infodialog_active]</visible>
					</control>
					<control type="image">
						<left>-3</left>
						<top>0</top>
						<right>1193</right>
						<height>100%</height>
						<aspectratio aligny="center">scale</aspectratio>
						<fadetime>400</fadetime>
						<include>OpenClose_Left</include>
						<animation effect="fade" time="400">VisibleChange</animation>
						<texture background="true" colordiffuse="$VAR[FanartBrightnessVar]">$VAR[PosterVar]</texture>
						<visible>!Control.IsVisible(32111)</visible>
					</control>
				</control>
			</control>
		</definition>
	</include>

	<include name="RainDropAnimationBackground">
		<control type="group">
			<visible>Skin.HasSetting(HideRainDrops) + ![Player.HasVideo + Player.HasAudio] + Skin.HasSetting(no_fanart)</visible>
			<include>VisibleFadeEffect</include>
			<control type="image">
				<description>Raindrop 9 animation</description>
				<left>1600</left>
				<top>400</top>
				<width>128</width>
				<height>128</height>
				<texture colordiffuse="dimgrey" background="true">rain-drop.png</texture>
				<animation type="conditional" reversible="false" loop="true" condition="true">
					<effect type="fade" delay="2000" start="0" end="100" time="200"/>
					<effect type="fade" delay="2500" start="100" end="0" time="500"/>
					<effect type="zoom" delay="2000" start="30" end="500" time="1000" center="auto" tween="quadratic"/>
				</animation>
			</control>
			<control type="image">
				<description>Raindrop 1 animation</description>
				<left>250</left>
				<top>200</top>
				<width>128</width>
				<height>128</height>
				<texture colordiffuse="dimgrey" background="true">rain-drop.png</texture>
				<animation type="conditional" reversible="false" loop="true" condition="true">
					<effect type="fade" start="0" end="100" time="200"/>
					<effect type="fade" start="100" end="0" delay="2500" time="1000"/>
					<effect type="zoom" center="auto" start="30" end="1500" delay="0" time="3500" tween="quadratic"/>
				</animation>
			</control>
			<control type="image">
				<description>Raindrop 2 animation</description>
				<left>700</left>
				<top>130</top>
				<width>128</width>
				<height>128</height>
				<texture colordiffuse="dimgrey" background="true">rain-drop.png</texture>
				<animation type="conditional" reversible="false" loop="true" condition="true">
					<effect type="fade" delay="400" start="0" end="100" time="200"/>
					<effect type="fade" delay="1000" start="100" end="0" time="1600"/>
					<effect type="zoom" delay="400" start="30" end="700" time="3000" center="auto" tween="quadratic"/>
				</animation>
			</control>
			<control type="image">
				<description>Raindrop 3 animation</description>
				<left>300</left>
				<top>700</top>
				<width>128</width>
				<height>128</height>
				<texture colordiffuse="dimgrey" background="true">rain-drop.png</texture>
				<animation type="conditional" reversible="false" loop="true" condition="true">
					<effect type="fade" delay="800" start="0" end="100" time="200"/>
					<effect type="fade" delay="2400" start="100" end="0" time="2000"/>
					<effect type="zoom" delay="800" start="30" end="1000" time="2500" center="auto" tween="quadratic"/>
				</animation>
			</control>
			<control type="image">
				<description>Raindrop 4 animation</description>
				<left>1550</left>
				<top>800</top>
				<width>128</width>
				<height>128</height>
				<texture colordiffuse="dimgrey" background="true">rain-drop.png</texture>
				<animation type="conditional" reversible="false" loop="true" condition="true">
					<effect type="fade" delay="1500" start="0" end="100" time="200"/>
					<effect type="fade" delay="2100" start="100" end="0" time="800"/>
					<effect type="zoom" delay="1500" start="30" end="1200" time="2500" center="auto" tween="quadratic"/>
				</animation>
			</control>
			<control type="image">
				<description>Raindrop 5 animation</description>
				<left>700</left>
				<top>550</top>
				<width>128</width>
				<height>128</height>
				<texture colordiffuse="dimgrey" background="true">rain-drop.png</texture>
				<animation type="conditional" reversible="false" loop="true" condition="true">
					<effect type="fade" delay="2200" start="0" end="100" time="200"/>
					<effect type="fade" delay="2400" start="100" end="0" time="3000"/>
					<effect type="zoom" delay="2200" start="30" end="1400" time="3700" center="auto" tween="quadratic"/>
				</animation>
			</control>
			<control type="image">
				<description>Raindrop 6 animation</description>
				<left>1400</left>
				<top>100</top>
				<width>128</width>
				<height>128</height>
				<texture colordiffuse="dimgrey" background="true">rain-drop.png</texture>
				<animation type="conditional" reversible="false" loop="true" condition="true">
					<effect type="fade" delay="1500" start="0" end="100" time="200"/>
					<effect type="fade" delay="2100" start="100" end="0" time="2000"/>
					<effect type="zoom" delay="1500" start="30" end="1200" time="3000" center="auto" tween="quadratic"/>
				</animation>
			</control>
			<control type="image">
				<description>Raindrop 7 animation</description>
				<left>1150</left>
				<top>450</top>
				<width>128</width>
				<height>128</height>
				<texture colordiffuse="dimgrey" background="true">rain-drop.png</texture>
				<animation type="conditional" reversible="false" loop="true" condition="true">
					<effect type="fade" delay="1000" start="0" end="100" time="200"/>
					<effect type="fade" delay="700" start="100" end="0" time="3500"/>
					<effect type="zoom" delay="1000" start="30" end="700" time="1500" center="auto" tween="quadratic"/>
				</animation>
			</control>
			<control type="image">
				<description>Raindrop 8 animation</description>
				<left>1000</left>
				<top>800</top>
				<width>128</width>
				<height>128</height>
				<texture colordiffuse="dimgrey" background="true">rain-drop.png</texture>
				<animation type="conditional" reversible="false" loop="true" condition="true">
					<effect type="fade" delay="700" start="0" end="100" time="200"/>
					<effect type="fade" delay="300" start="100" end="0" time="4000"/>
					<effect type="zoom" delay="700" start="30" end="900" time="3000" center="auto" tween="quadratic"/>
				</animation>
			</control>
		</control>
	</include>

	<include name="FanartDiffuseBackground">
		<!-- fanart   : texture source — override per view with the correct Container(id) reference -->
		<!-- visible  : optional condition to hide both layers (e.g. !Window.IsActive(videoplaylist)) -->
		<!-- fadetime : ms cross-fade between items; 0 for grid views, 600 for row/spotlight views -->
		<param name="fanart">$INFO[ListItem.Art(fanart)]</param>
		<param name="visible">true</param>
		<param name="fadetime">0</param>
		<definition>
			<!-- Black base: diffuse-transparent areas render black, not the dimmed background fanart -->
			<control type="image">
				<left>0</left>
				<top>0</top>
				<width>100%</width>
				<height>100%</height>
				<visible>$PARAM[visible]</visible>
				<texture>colors/black.png</texture>
			</control>
			<!-- Fanart with diffuse mask for the focused item -->
			<control type="image">
				<right>0</right>
				<top>0</top>
				<width>70%</width>
				<height>70%</height>
				<visible>$PARAM[visible]</visible>
				<aspectratio align="left" aligny="top" scalediffuse="false">scale</aspectratio>
				<fadetime>$PARAM[fadetime]</fadetime>
				<animation effect="fade" time="400">VisibleChange</animation>
				<texture background="true" diffuse="diffuse/flixart_new.png">$PARAM[fanart]</texture>
			</control>
		</definition>
	</include>

</includes>
