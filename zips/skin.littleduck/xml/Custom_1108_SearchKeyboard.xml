<?xml version="1.0" encoding="UTF-8"?>
<!--
    Unified Search Dialog — Custom_1108_SearchKeyboard.xml
    Window ID: 1108

    LAYOUT: Split screen.
      Left  (1236px): header + input display + autocomplete row + QWERTY grid
      Right ( 564px): live search results (poster + title + year)

    NAVIGATION:
      Keyboard UP (row 1)    → autocomplete panel (id=9010, if items present)
      Keyboard RIGHT (any row) → results list (id=9020)
      Autocomplete RIGHT     → results list (id=9020)
      Results LEFT           → keyboard rows group (id=78500)

    PYTHON DEPENDENCY:
      Each key calls:  RunScript(script.littleduck.helper,mode=keyboard_char,char=X)
      Autocomplete OK: RunScript(script.littleduck.helper,mode=keyboard_char_set,text=$INFO[ListItem.Label])
      Done:            RunScript(script.littleduck.helper,mode=search_input)
      Cancel:          Dialog.Close(1108)
      Clear:           RunScript(script.littleduck.helper,mode=keyboard_char,char=clear)

      Add to router.py:
        if mode == "keyboard_char":
            from modules.search_utils import keyboard_char_handler
            return keyboard_char_handler(params)
        if mode == "keyboard_char_set":
            from modules.search_utils import keyboard_char_set_handler
            return keyboard_char_set_handler(params)

      Add to search_utils.py:
        def keyboard_char_handler(params):
            char  = params.get("char", "")
            shift = xbmc.getCondVisibility("Skin.HasSetting(KeyboardShift)")
            current = xbmc.getInfoLabel("Skin.String(SearchInputRaw)")
            if char == "backspace":
                new_text = current[:-1]
            elif char == "clear":
                new_text = ""
            elif char == "space":
                new_text = current + " "
            else:
                new_text = current + (char.upper() if shift else char)
                if shift:
                    xbmc.executebuiltin("Skin.Reset(KeyboardShift)")
            encoded = quote(new_text)
            xbmc.executebuiltin(f"Skin.SetString(SearchInputRaw,{new_text})")
            xbmc.executebuiltin(f"Skin.SetString(SearchInput,{new_text})")
            xbmc.executebuiltin(f"Skin.SetString(SearchInputEncoded,{encoded})")

        def keyboard_char_set_handler(params):
            text = params.get("text", "")
            encoded = quote(text)
            xbmc.executebuiltin(f"Skin.SetString(SearchInputRaw,{text})")
            xbmc.executebuiltin(f"Skin.SetString(SearchInput,{text})")
            xbmc.executebuiltin(f"Skin.SetString(SearchInputEncoded,{encoded})")
-->
