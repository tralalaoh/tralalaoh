					<control type="image">
						<left>0</left>
						<top>2</top>
						<width>90</width>
						<height>40</height>
						<aspectratio>keep</aspectratio>
						<texture background="true">$VAR[MPAARatingIconVar]</texture>
					</control>
					<!-- Star icon -->
					<control type="image">
						<left>100</left>
						<top>9</top>
						<width>26</width>
						<height>26</height>
						<texture>icons/infodialogs/rating.png</texture>
						<colordiffuse>accent_color</colordiffuse>
					</control>
					<!-- Numeric rating -->
