		<!-- ══════════════════════════════════════════════════════════
		     PAUSE CARD — cinematic info overlay (non-LiveTV)
		     Auto-shows on pause and when Info / i is pressed
		     Group covers bottom 700px of screen (y=380..y=1080)
		     ══════════════════════════════════════════════════════════ -->
		<control type="group">
			<visible>!Window.IsVisible(playerprocessinfo)</visible>
			<visible>[Player.ShowInfo | Window.IsActive(fullscreeninfo) | Player.Paused] + !VideoPlayer.Content(LiveTV) + Window.IsActive(fullscreenvideo)</visible>
