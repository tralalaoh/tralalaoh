						<left>132</left>
						<top>0</top>
						<width>200</width>
						<height>44</height>
						<label>$INFO[VideoPlayer.Rating]</label>
						<font>font12</font>
						<textcolor>FFE5E5E5</textcolor>
						<aligny>center</aligny>
					</control>
				</control>

				<!-- PLOT (scrolls while paused) -->
				<control type="textbox">
					<left>20</left>
					<top>62</top>
					<right>20</right>
					<height>120</height>
					<label fallback="19055">$INFO[VideoPlayer.Plot]</label>
					<font>font12</font>
					<textcolor>99FFFFFF</textcolor>
					<autoscroll delay="6000" repeat="8000" time="5000">Player.Paused</autoscroll>
