                        <aligny>center</aligny>
                        <texturefocus />
                        <texturenofocus />
                        <onfocus>SetProperty(spotlight.custom2.tab,1,home)</onfocus>
                        <onfocus>SetProperty(spotlight.custom2.path,plugin://plugin.video.themoviedb.helper/?info=trakt_trending&genres=anime&tmdb_type=tv,home)</onfocus>
                        <onfocus>Skin.SetString(spotlight.custom2.type,landscape)</onfocus>
                        <onleft>9000</onleft>
                        <onright>36062</onright>
                        <onup>9000</onup>
                        <ondown condition="String.IsEqual(Skin.String(spotlight.custom2.type),landscape)">39410</ondown>
                        <ondown condition="String.IsEqual(Skin.String(spotlight.custom2.type),landscapeinfo)">39421</ondown>
                        <ondown condition="String.IsEqual(Skin.String(spotlight.custom2.type),walll)">39451</ondown>
                        <ondown condition="String.IsEqual(Skin.String(spotlight.custom2.type),wallp)">39461</ondown>
                        <ondown>39400</ondown>
