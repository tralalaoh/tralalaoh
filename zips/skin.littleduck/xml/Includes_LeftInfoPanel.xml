<?xml version="1.0" encoding="UTF-8"?>
<includes>

	<!--
		LeftInfoPanel — hero-style vertical info panel for all left content panels.
		Single source of truth: edit this file to restyle all library browse panels.

		Mirrors SpotlightViewHero visual style:
		  clearlogo (left-align, keep-aspect) · font52_title fallback
		  font27 infoline · RatingChipVertical chips · font12 plot with autoscroll
		  fade-in animation on WindowOpen

		Layout params (change here to restyle everywhere):
		  panel_width             ContentPanel total width              (default: 1106)
		  content_width           inner column width                    (default: 550)
		  art_top                 top of clearlogo/art block            (default: 120)
		  art_height              height of clearlogo/art block         (default: 140)
		  ratings_top             top of ratings section                (default: 280)
		  plot_top                top of simple plot (no-ratings mode)  (default: 420)
		  plot_bottom             bottom reserve for simple plot        (default: 70)
		  art_fallback            fallback image                        (default: DefaultFolder.png)
		  ratings_spacing         chip itemgap in ratings rows          (default: 25)
		  ratings_height_noalt    max plot height (normal mode)         (default: 375)
		  ratings_height_alt_movie    max plot height (movie, alt)      (default: 250)
		  ratings_height_alt_tvshow   max plot height (tvshow, alt)     (default: 170)

		Show/hide flags:
		  show_clearlogo          show art/clearlogo image              (default: true)
		  show_title              show title fallback label             (default: true)
		  show_ratings            embed full RatingsInfoPanel section   (default: false)
		  show_plot               show simple plot textbox              (default: true)
		  show_collection_list    show InfoList for collections         (default: false)

		Content params:
		  clearlogo_texture       art/clearlogo texture                 (default: $INFO[ListItem.Art(clearlogo)])
		  clearlogo_visible       condition to show art image           (default: !String.IsEmpty(ListItem.Art(clearlogo)))
		  title_label             title fallback text                   (default: $INFO[ListItem.Label])
		  title_visible           condition to show title               (default: String.IsEmpty(ListItem.Art(clearlogo)))
		  plot_label              plot text (simple mode)               (default: $INFO[ListItem.Plot])
		  infopanel_label         metadata text (no-API-key fallback)   (default: empty)
		  infopanel_ep_label      episode metadata (no-API-key)         (default: empty)
	-->
	<include name="LeftInfoPanel">
		<!-- Layout params -->
		<param name="panel_width">1106</param>
		<param name="content_width">550</param>
		<param name="art_top">120</param>
		<param name="art_height">140</param>
		<param name="ratings_top">280</param>
		<param name="infoline_top">272</param>
		<param name="plot_top">420</param>
		<param name="plot_bottom">70</param>
		<param name="art_fallback">DefaultFolder.png</param>
		<param name="ratings_spacing">25</param>
		<param name="ratings_height_noalt">375</param>
		<param name="ratings_height_alt_movie">250</param>
		<param name="ratings_height_alt_tvshow">170</param>
		<!-- Show/hide flags -->
		<param name="show_clearlogo">true</param>
		<param name="show_title">true</param>
		<param name="show_ratings">false</param>
		<param name="show_infoline">false</param>
		<param name="show_plot">true</param>
		<param name="show_collection_list">false</param>
		<!-- passes through to RatingsInfoPanel: false = hide verbose metadata, show compact infoline instead -->
		<param name="show_infopanel_top">false</param>
		<!-- Content params -->
		<param name="clearlogo_texture">$INFO[ListItem.Art(clearlogo)]</param>
		<param name="clearlogo_visible">!String.IsEmpty(ListItem.Art(clearlogo))</param>
		<param name="title_label">$INFO[ListItem.Label]</param>
		<param name="title_visible">String.IsEmpty(ListItem.Art(clearlogo))</param>
		<param name="plot_label">$INFO[ListItem.Plot]</param>
		<param name="infoline_label"></param>
		<param name="infopanel_label"></param>
		<param name="infopanel_ep_label"></param>
		<definition>
		<include content="ContentPanel">
			<param name="width" value="$PARAM[panel_width]" />
		</include>
		<control type="group">
			<width>$PARAM[content_width]</width>
			<animation effect="fade" start="0" end="100" time="400">WindowOpen</animation>

			<!-- ── CLEARLOGO / ART IMAGE ──────────────────────────────── -->
			<control type="image">
				<left>30</left>
				<top>$PARAM[art_top]</top>
				<width>490</width>
				<height>$PARAM[art_height]</height>
				<texture background="true" fallback="$PARAM[art_fallback]">$PARAM[clearlogo_texture]</texture>
				<aspectratio align="left" aligny="center">keep</aspectratio>
				<visible>$PARAM[show_clearlogo] + $PARAM[clearlogo_visible]</visible>
			</control>

			<!-- ── TITLE FALLBACK (no clearlogo/art) ─────────────────── -->
			<control type="label">
				<left>30</left>
				<top>$PARAM[art_top]</top>
				<width>490</width>
				<height>$PARAM[art_height]</height>
				<aligny>center</aligny>
				<font>font52_title</font>
				<textcolor>white</textcolor>
				<shadowcolor>text_shadow</shadowcolor>
				<label>$PARAM[title_label]</label>
				<visible>$PARAM[show_title] + $PARAM[title_visible]</visible>
			</control>

			<!-- ── COMPACT INFO LINE: ★ rating | year | MPAA | duration ─ -->
			<!-- textbox instead of label: wraps to 2 lines instead of truncating with … -->
			<control type="textbox">
				<left>30</left>
				<top>$PARAM[infoline_top]</top>
				<width>490</width>
				<height>72</height>
				<font>font27</font>
				<textcolor>white</textcolor>
				<shadowcolor>text_shadow</shadowcolor>
				<label>$PARAM[infoline_label]</label>
				<visible>$PARAM[show_infoline]</visible>
			</control>

			<!-- ── RATINGS + METADATA SECTION (video, show_ratings=true) -->
			<control type="group">
				<visible>$PARAM[show_ratings]</visible>

				<!-- No-API-key fallback: legacy metadata textboxes -->
				<control type="group">
					<visible>String.IsEmpty(Skin.String(mdblist_api_key))</visible>
					<control type="label">
						<left>30</left>
						<top>265</top>
						<width>490</width>
						<height>50</height>
						<aligny>center</aligny>
						<font>font36_title</font>
						<textcolor>unfocused_text</textcolor>
						<label>Season $INFO[ListItem.Season], Episode $INFO[ListItem.Episode]</label>
						<visible>String.IsEqual(ListItem.DbType,episode)</visible>
					</control>
					<control type="textbox">
						<left>30</left>
						<top>$PARAM[ratings_top]</top>
						<width>490</width>
						<bottom>115</bottom>
						<font>font27</font>
						<textcolor>unfocused_text</textcolor>
						<shadowcolor>text_shadow</shadowcolor>
						<autoscroll delay="10000" time="3000" repeat="10000">Skin.HasSetting(autoscroll)</autoscroll>
						<label>$PARAM[infopanel_label]</label>
					</control>
					<control type="textbox">
						<left>30</left>
						<top>380</top>
						<width>490</width>
						<bottom>105</bottom>
						<font>font12</font>
						<textcolor>unfocused_text</textcolor>
						<shadowcolor>text_shadow</shadowcolor>
						<autoscroll delay="10000" time="3000" repeat="10000">Skin.HasSetting(autoscroll)</autoscroll>
						<label>$PARAM[infopanel_ep_label]</label>
					</control>
					<control type="label">
						<left>30</left>
						<top>467</top>
						<width>490</width>
						<height>413</height>
						<align>center</align>
						<aligny>center</aligny>
						<font>font27</font>
						<textcolor>80FFFFFF</textcolor>
						<label>$LOCALIZE[19055]</label>
						<visible>String.IsEmpty(ListItem.Plot) + String.IsEmpty(ListItem.Tagline) + !ListItem.IsCollection + !ListItem.IsParentFolder</visible>
					</control>
				</control>

				<!-- With-API-key: full RatingsInfoPanel (chips + plot, verbose text suppressed by default) -->
				<include condition="!String.IsEmpty(Skin.String(mdblist_api_key))" content="RatingsInfoPanel">
					<param name="left" value="30" />
					<param name="width" value="490" />
					<param name="top" value="$PARAM[ratings_top]" />
					<param name="ratings_spacing" value="$PARAM[ratings_spacing]" />
					<param name="height_noalt" value="$PARAM[ratings_height_noalt]" />
					<param name="height_alt_movie" value="$PARAM[ratings_height_alt_movie]" />
					<param name="height_alt_tvshow" value="$PARAM[ratings_height_alt_tvshow]" />
					<param name="show_infopanel_top" value="$PARAM[show_infopanel_top]" />
				</include>

			</control>

			<!-- ── COLLECTION ITEM LIST ───────────────────────────────── -->
			<control type="group">
				<left>20</left>
				<top>245</top>
				<visible>$PARAM[show_collection_list] + ListItem.IsCollection + String.IsEmpty(ListItem.Plot)</visible>
				<include content="InfoList">
					<param name="bottom" value="108" />
					<param name="width" value="490" />
					<param name="sortby" value="year" />
					<param name="sortorder" value="ascending" />
					<param name="font" value="font13" />
				</include>
			</control>

			<!-- ── SIMPLE PLOT (generic / non-video content) ─────────── -->
			<control type="textbox">
				<left>30</left>
				<top>$PARAM[plot_top]</top>
				<width>490</width>
				<bottom>$PARAM[plot_bottom]</bottom>
				<font>font12</font>
				<textcolor>unfocused_text</textcolor>
				<shadowcolor>text_shadow</shadowcolor>
				<autoscroll delay="10000" time="3000" repeat="10000">Skin.HasSetting(autoscroll)</autoscroll>
				<label>$PARAM[plot_label]</label>
				<visible>$PARAM[show_plot]</visible>
			</control>

		</control>
		</definition>
	</include>

</includes>
