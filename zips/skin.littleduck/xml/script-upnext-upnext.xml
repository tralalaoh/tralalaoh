<?xml version="1.0" encoding="UTF-8"?>
<!--
    service.upnext — "Up Next" banner
    Styled for skin.littleduck: dark background, gold (#FCC200) accent.

    Control IDs must not change (hardcoded in service.upnext):
        3012 = Play Next button
        3013 = Dismiss button
        3014 = countdown progress bar (on the thumbnail)
-->
<window>
    <defaultcontrol always="true">3012</defaultcontrol>
    <onload>Dialog.Close(fullscreeninfo,true)</onload>
    <onload>Dialog.Close(videoosd,true)</onload>
    <controls>
        <control type="group">
            <!-- Slide in from top + fade -->
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="350" tween="sine" easing="out"/>
                <effect type="slide" start="0,-200" end="0,0" time="350" tween="sine" easing="out"/>
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="fade" start="100" end="0" time="300" tween="sine" easing="in"/>
                <effect type="slide" start="0,0" end="0,-200" time="300" tween="sine" easing="in"/>
            </animation>

            <control type="group">
                <height>200</height>

                <!-- Dark background -->
                <control type="image">
                    <left>0</left>
                    <top>0</top>
                    <width>100%</width>
                    <height>200</height>
                    <texture colordiffuse="E6141414">colors/white.png</texture>
                </control>

                <!-- Gold left accent bar -->
                <control type="image">
                    <left>0</left>
                    <top>0</top>
                    <width>5</width>
                    <height>200</height>
                    <texture colordiffuse="accent_color">colors/white.png</texture>
                </control>

                <!-- Thumbnail / landscape image -->
                <control type="group">
                    <left>24</left>
                    <top>18</top>

                    <!-- Subtle dark bg placeholder when no art is available -->
                    <control type="image">
                        <width>290</width>
                        <height>163</height>
                        <texture colordiffuse="30FFFFFF">colors/white.png</texture>
                    </control>

                    <!-- Fallback show title text when no artwork -->
                    <control type="textbox">
                        <left>10</left>
                        <top>10</top>
                        <width>270</width>
                        <height>143</height>
                        <font>font12</font>
                        <textcolor>unfocused_text</textcolor>
                        <align>center</align>
                        <aligny>center</aligny>
                        <label>$INFO[Window.Property(tvshowtitle)]</label>
                        <visible>String.IsEmpty(Window.Property(thumb)) + String.IsEmpty(Window.Property(landscape)) + String.IsEmpty(Window.Property(fanart))</visible>
                    </control>

                    <!-- Landscape image (preferred) -->
                    <control type="image">
                        <width>290</width>
                        <height>163</height>
                        <texture>$INFO[Window.Property(landscape)]</texture>
                        <aspectratio>scale</aspectratio>
                    </control>

                    <!-- Fanart fallback -->
                    <control type="image">
                        <width>290</width>
                        <height>163</height>
                        <texture>$INFO[Window.Property(fanart)]</texture>
                        <aspectratio>scale</aspectratio>
                        <visible>String.IsEmpty(Window.Property(landscape))</visible>
                    </control>

                    <!-- Thumb fallback -->
                    <control type="image">
                        <width>290</width>
                        <height>163</height>
                        <texture>$INFO[Window.Property(thumb)]</texture>
                        <aspectratio>scale</aspectratio>
                        <visible>String.IsEmpty(Window.Property(landscape)) + String.IsEmpty(Window.Property(fanart))</visible>
                    </control>

                    <!-- Countdown progress bar (gold fill, transparent bg) -->
                    <control type="progress" id="3014">
                        <top>158</top>
                        <width>290</width>
                        <height>5</height>
                        <reveal>true</reveal>
                        <righttexture></righttexture>
                        <overlaytexture></overlaytexture>
                        <lefttexture></lefttexture>
                        <texturebg colordiffuse="00FFFFFF">colors/white.png</texturebg>
                        <midtexture colordiffuse="accent_color">colors/white.png</midtexture>
                    </control>
                </control>

                <!-- Text and buttons -->
                <control type="group">
                    <top>18</top>
                    <left>334</left>
                    <right>24</right>

                    <!-- "UP NEXT" heading / countdown label -->
                    <!-- Shows "Up next" when >60s remain, countdown string when <60s -->
                    <control type="label">
                        <width>auto</width>
                        <height>30</height>
                        <aligny>center</aligny>
                        <font>font20_title</font>
                        <textcolor>accent_color</textcolor>
                        <label>$ADDON[service.upnext 30036]</label>
                        <visible>!Integer.IsGreater(Player.TimeRemaining,59)</visible>
                    </control>
                    <control type="label">
                        <width>auto</width>
                        <height>30</height>
                        <aligny>center</aligny>
                        <font>font20_title</font>
                        <textcolor>accent_color</textcolor>
                        <label>$ADDON[service.upnext 30008]</label>
                        <visible>Integer.IsGreater(Player.TimeRemaining,59)</visible>
                    </control>

                    <!-- Show · SxEx · Episode Title -->
                    <control type="grouplist">
                        <orientation>horizontal</orientation>
                        <top>38</top>
                        <height>35</height>
                        <itemgap>0</itemgap>
                        <control type="label">
                            <width>auto</width>
                            <height>35</height>
                            <aligny>center</aligny>
                            <font>font25_title</font>
                            <textcolor>unfocused_text</textcolor>
                            <label>$INFO[Window.Property(tvshowtitle),, · ]$INFO[Window.Property(season),S,]$INFO[Window.Property(episode),E, · ]$INFO[Window.Property(title)]</label>
                            <visible>!String.IsEmpty(Window.Property(title))</visible>
                        </control>
                    </control>

                    <!-- Year and rating row -->
                    <control type="grouplist">
                        <orientation>horizontal</orientation>
                        <top>80</top>
                        <height>28</height>
                        <itemgap>6</itemgap>
                        <control type="label">
                            <width>auto</width>
                            <height>28</height>
                            <aligny>center</aligny>
                            <font>font12</font>
                            <textcolor>grey</textcolor>
                            <label>$INFO[Window.Property(year),(,)]</label>
                            <visible>!String.IsEmpty(Window.Property(year))</visible>
                        </control>
                        <!-- Separator dot between year and rating -->
                        <control type="label">
                            <width>auto</width>
                            <height>28</height>
                            <aligny>center</aligny>
                            <font>font12</font>
                            <textcolor>grey</textcolor>
                            <label>  ·  </label>
                            <visible>!String.IsEmpty(Window.Property(year)) + !String.IsEmpty(Window.Property(rating))</visible>
                        </control>
                        <!-- Gold star icon shifted down to mid-line -->
                        <control type="image">
                            <width>16</width>
                            <height>16</height>
                            <aspect>keep</aspect>
                            <texture colordiffuse="accent_color">osd/fullscreen/buttons/rating.png</texture>
                            <animation effect="slide" end="0,6" time="0" condition="true">Conditional</animation>
                            <visible>!String.IsEmpty(Window.Property(rating))</visible>
                        </control>
                        <control type="label">
                            <width>auto</width>
                            <height>28</height>
                            <aligny>center</aligny>
                            <font>font12</font>
                            <textcolor>grey</textcolor>
                            <label>$INFO[Window.Property(rating), ,]</label>
                            <visible>!String.IsEmpty(Window.Property(rating))</visible>
                        </control>
                    </control>

                    <!-- Action buttons -->
                    <control type="grouplist">
                        <orientation>horizontal</orientation>
                        <height>52</height>
                        <bottom>18</bottom>
                        <itemgap>12</itemgap>

                        <!-- Play Next (primary, gold on focus) -->
                        <control type="button" id="3012">
                            <label>$ADDON[service.upnext 30006]</label>
                            <height>52</height>
                            <width min="180">auto</width>
                            <font>font20_title</font>
                            <textoffsetx>20</textoffsetx>
                            <textcolor>unfocused_text</textcolor>
                            <focusedcolor>focused_text</focusedcolor>
                            <selectedcolor>unfocused_text</selectedcolor>
                            <align>center</align>
                            <aligny>center</aligny>
                            <texturefocus colordiffuse="button_focus">buttons/dialog-btn.png</texturefocus>
                            <texturenofocus colordiffuse="20FFFFFF">buttons/dialog-btn.png</texturenofocus>
                            <pulseonselect>no</pulseonselect>
                        </control>

                        <!-- Dismiss -->
                        <control type="button" id="3013">
                            <label>$ADDON[service.upnext 30034]</label>
                            <height>52</height>
                            <width min="160">auto</width>
                            <font>font20_title</font>
                            <textoffsetx>20</textoffsetx>
                            <textcolor>grey</textcolor>
                            <focusedcolor>focused_text</focusedcolor>
                            <selectedcolor>grey</selectedcolor>
                            <align>center</align>
                            <aligny>center</aligny>
                            <texturefocus colordiffuse="button_focus">buttons/dialog-btn.png</texturefocus>
                            <texturenofocus colordiffuse="00FFFFFF">buttons/dialog-btn.png</texturenofocus>
                            <pulseonselect>no</pulseonselect>
                        </control>
                    </control>

                    <!-- Clock + "Ends at" — top-right corner -->
                    <control type="group">
                        <visible>!Window.IsVisible(extendedprogressdialog)</visible>
                        <animation effect="fade" time="150">VisibleChange</animation>
                        <control type="label">
                            <font>font_clock_small</font>
                            <top>0</top>
                            <right>0</right>
                            <height>120</height>
                            <width>400</width>
                            <align>right</align>
                            <textcolor>30FFFFFF</textcolor>
                            <label>$INFO[System.Time]</label>
                        </control>
                        <control type="label">
                            <right>0</right>
                            <top>56</top>
                            <width>400</width>
                            <height>30</height>
                            <align>right</align>
                            <font>font12</font>
                            <textcolor>grey</textcolor>
                            <label>$ADDON[service.upnext 30009]</label>
                            <visible>!String.IsEmpty(Window.Property(endtime))</visible>
                        </control>
                    </control>
                </control>

            </control>
        </control>
    </controls>
</window>
