<?xml version="1.0" encoding="UTF-8"?>
<!--
    SkinSettings.xml — skin.littleduck
    This window is a legacy redirect kept for backward compatibility.
    The actual settings UI is the Python-driven WindowXMLDialog at:
      skin.littleduck/resources/skins/Default/1080i/DialogSkinSettings.xml
    Launched via: RunScript(script.littleduck.helper,mode=open_skin_settings)

    Primary entry point: Settings.xml calls RunScript directly.
    This window is opened if something still calls ActivateWindow(skinsettings).
-->
<window>
    <defaultcontrol>9000</defaultcontrol>
    <backgroundcolor>background</backgroundcolor>
    <onload>RunScript(script.littleduck.helper,mode=open_skin_settings)</onload>
    <controls>
        <include>DefaultBackground</include>
        <include content="TopBar">
            <param name="breadcrumbs_label" value="Skin Settings" />
        </include>
        <include>BottomBar</include>
        <!-- Invisible focus anchor so Kodi has a valid defaultcontrol -->
        <control type="button" id="9000">
            <left>-9999</left><top>-9999</top>
            <width>1</width><height>1</height>
            <label></label>
        </control>
    </controls>
</window>
