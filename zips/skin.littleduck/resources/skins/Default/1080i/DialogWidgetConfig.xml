<?xml version="1.0" encoding="UTF-8"?>
<!--
    skin.littleduck — Widget Config Dialog
    1920×1080 | panel 1720×920 @ (100,80)
    Header : h=100
    Left   : x=0   w=420  h=820  — active widget slots
    Right  : x=420 w=1300 h=820
      List : h=700  item-h=110
      Info : h=120

    Focus style matches main settings dialog:
      transparent gold bg  33FFCC00  + solid gold right bar
      transparent red  bg  33FF3300  + solid red right bar (danger)

    Radio buttons: 120×75 native → rendered 80×50
-->
<window type="dialog">
    <defaultcontrol always="true">9101</defaultcontrol>
    <controls>

        <!-- dim overlay -->
        <control type="image">
            <left>0</left><top>0</top><width>1920</width><height>1080</height>
            <texture colordiffuse="CC0A0B0F">special://skin/media/colors/white.png</texture>
        </control>

        <control type="group">
            <left>100</left><top>80</top><width>1720</width><height>920</height>

            <!-- panel bg -->
            <control type="image">
                <left>0</left><top>0</top><width>1720</width><height>920</height>
                <texture colordiffuse="F00A0B0F">special://skin/media/colors/white.png</texture>
            </control>
            <control type="image">
                <left>0</left><top>0</top><width>1720</width><height>1</height>
                <texture colordiffuse="14FFFFFF">special://skin/media/colors/white.png</texture>
            </control>
            <control type="image">
                <left>0</left><top>919</top><width>1720</width><height>1</height>
                <texture colordiffuse="14FFFFFF">special://skin/media/colors/white.png</texture>
            </control>

            <!-- ═══════════ HEADER ═══════════ -->
            <control type="group">
                <left>0</left><top>0</top><width>1720</width><height>100</height>
                <control type="image">
                    <left>44</left><top>32</top><width>34</width><height>34</height>
                    <texture colordiffuse="FFFFCC00">special://skin/media/icons/squares-four.png</texture>
                </control>
                <!-- breadcrumb title set by Python -->
                <control type="label" id="9120">
                    <left>92</left><top>0</top><width>1300</width><height>100</height>
                    <label>Skin Settings</label>
                    <font>font32</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <align>left</align><aligny>center</aligny>
                </control>
                <!-- widget count badge -->
                <control type="image">
                    <left>1460</left><top>34</top><width>210</width><height>40</height>
                    <texture colordiffuse="1AFFFFFF">special://skin/media/colors/white.png</texture>
                </control>
                <control type="label" id="9121">
                    <left>1460</left><top>34</top><width>210</width><height>40</height>
                    <label>0 / 10 Widgets</label>
                    <font>font12</font>
                    <textcolor>FF8B92A5</textcolor>
                    <align>center</align><aligny>center</aligny>
                </control>
                <control type="image">
                    <left>0</left><top>99</top><width>1720</width><height>1</height>
                    <texture colordiffuse="14FFFFFF">special://skin/media/colors/white.png</texture>
                </control>
                <!-- ── Back button (touch/tablet) ───────────────────────────
                     Same pattern as DialogSkinSettings: invisible button hitbox
                     + two image overlays that swap on Control.HasFocus(9130).
                     No <onclick>Action(Back)</onclick> — Python onClick(9130) handles close. -->
                <control type="button" id="9130">
                    <left>1652</left><top>28</top><width>44</width><height>44</height>
                    <label></label>
                    <texturenofocus></texturenofocus>
                    <texturefocus></texturefocus>
                </control>
                <control type="image">
                    <left>1652</left><top>28</top><width>44</width><height>44</height>
                    <aspectratio>keep</aspectratio>
                    <texture colordiffuse="FFFFCC00">special://skin/media/icons/back.png</texture>
                    <visible>Control.HasFocus(9130)</visible>
                </control>
                <control type="image">
                    <left>1652</left><top>28</top><width>44</width><height>44</height>
                    <aspectratio>keep</aspectratio>
                    <texture colordiffuse="88FFFFFF">special://skin/media/icons/back.png</texture>
                    <visible>!Control.HasFocus(9130)</visible>
                </control>
            </control>

            <!-- ═══════════ LEFT: ACTIVE WIDGETS PANEL ═══════════ -->
