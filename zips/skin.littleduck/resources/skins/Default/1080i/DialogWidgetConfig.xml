                    <ondown>9100</ondown>
                    <onright>9101</onright>
                    <onleft>9100</onleft>
                    <scrolltime>150</scrolltime>

                    <!-- NORMAL slot (h=90) -->
                    <itemlayout height="90" width="420">
                        <!-- card bg -->
                        <control type="image">
                            <left>8</left><top>6</top><width>404</width><height>78</height>
                            <texture colordiffuse="FF13151E">special://skin/media/colors/white.png</texture>
                        </control>
                        <!-- active: transparent gold tint -->
                        <control type="image">
                            <left>8</left><top>6</top><width>404</width><height>78</height>
                            <texture colordiffuse="18FFCC00">special://skin/media/colors/white.png</texture>
                            <visible>String.IsEqual(ListItem.Property(is_active),true)</visible>
                        </control>
                        <!-- active: solid gold left bar -->
                        <control type="image">
                            <left>8</left><top>16</top><width>3</width><height>58</height>
                            <texture colordiffuse="FFFFCC00">special://skin/media/colors/white.png</texture>
                            <visible>String.IsEqual(ListItem.Property(is_active),true)</visible>
