{
    "name": "Torrentio",
    "id": "torrentio",
    "plugin": "plugin.video.torrentio",
    "priority": 1000,
    "is_resolvable": "true",
    "assert": {
        "play_movie": ["tmdb"],
        "play_episode": ["tmdb", "season", "episode"]
    },
    "play_movie": "plugin://plugin.video.torrentio/?action=list_streams&imdb_id={imdb}&tmdb_id={tmdb}&media_type=movie",
    "play_episode": "plugin://plugin.video.torrentio/?action=list_streams&imdb_id={imdb}&tmdb_id={tmdb}&media_type=series&season={season}&episode={episode}"
}
