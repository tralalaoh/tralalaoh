<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings>
    <!-- User Profile -->
    <category label="User Profile">
        <setting id="user_uuid" type="text" label="AIO Metadata UUID" default=""/>
        <setting type="lsep" label="Your unique identifier for the service"/>
        <setting type="action" label="Generate New UUID" action="RunPlugin(plugin://plugin.video.littleracun/?mode=generate_uuid)"/>
    </category>
    
    <!-- API Configuration -->
    <category label="API Settings">
        <setting id="server_url" type="text" label="Server URL" default="https://aiometadata.elfhosted.com"/>
        <setting type="lsep" label="Default: https://aiometadata.elfhosted.com"/>
        <setting id="api_timeout" type="slider" label="API Timeout (seconds)" default="30" range="5,5,120" option="int"/>
        <setting id="enable_debug" type="bool" label="Enable Debug Logging" default="false"/>
    </category>
    
    <!-- Config -->
    <category label="Config Source">
        <setting id="use_local_config" type="bool" label="Use Local Config File" default="false"/>
        <setting id="config_url" type="text" label="Remote Config URL" default="" enable="!eq(-1,true)"/>
        <setting type="lsep" label="When disabled, config will be fetched from server"/>
    </category>
    
    <!-- Playback -->
    <category label="Playback">
        <setting id="default_player" type="labelenum" label="Default Player" values="Always Ask|Stremio Bridge|Fen Light|Otaku|Universal Bridge" default="Always Ask"/>
        <setting id="remember_player_choice" type="bool" label="Remember Player Choice (This Session)" default="false"/>
        <setting id="preferred_quality" type="labelenum" label="Preferred Quality" values="4K|1080p|720p|480p" default="1080p"/>
        <setting id="auto_play" type="bool" label="Auto Play First Source" default="false"/>
    </category>
    
    <!-- Players -->
    <category label="Players">
        <setting type="lsep" label="Manage Player Configurations"/>
        <setting type="action" label="Download Player from URL" action="RunPlugin(plugin://plugin.video.littleracun/?mode=download_player)"/>
        <setting type="action" label="View Installed Players" action="RunPlugin(plugin://plugin.video.littleracun/?mode=view_players)"/>
        <setting type="lsep" label=""/>
        <setting type="lsep" label="Player JSON Requirements:"/>
        <setting type="lsep" label='• Must have "name" field'/>
        <setting type="lsep" label='• Must have "play_movie" or "play_episode"'/>
        <setting type="lsep" label="• Example: GitHub raw URL, Pastebin raw, etc."/>
    </category>
    
    <!-- Display -->
    <category label="Display">
        <setting id="show_fanart" type="bool" label="Show Fanart" default="true"/>
        <setting id="show_year" type="bool" label="Show Year in Titles" default="true"/>
        <setting id="show_rating" type="bool" label="Show Ratings" default="true"/>
        <setting id="items_per_page" type="slider" label="Items Per Page" default="50" range="10,10,100" option="int"/>
    </category>
</settings>
