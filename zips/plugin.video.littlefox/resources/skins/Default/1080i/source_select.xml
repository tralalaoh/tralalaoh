<?xml version="1.0" encoding="UTF-8"?>
<!--
    source_select.xml — Little Fox server selector
    Layout: floating dialog 1600×900 centred in 1920×1080 (160px sides, 90px top/bottom)
    Sidebar 380px | Servers pane 1220px
    Card: [badge 128px] [content 910px] [right 130px]
    Card height: 120px
    Assets: shared from plugin.video.littletigre/resources/media/
-->
<window type="dialog">
    <controls>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- FULL-SCREEN SCRIM                                                   -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <control type="image">
            <left>0</left><top>0</top><width>1920</width><height>1080</height>
            <texture colordiffuse="CC000000">special://home/addons/plugin.video.littletigre/resources/media/white.png</texture>
        </control>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- DIALOG CONTAINER  1600×900  at (160, 90)                           -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <control type="group">
            <left>160</left><top>90</top><width>1600</width><height>900</height>

            <!-- Dialog background -->
            <control type="image">
                <left>0</left><top>0</top><width>1600</width><height>900</height>
                <texture>special://home/addons/plugin.video.littletigre/resources/media/bg.png</texture>
            </control>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- LEFT SIDEBAR  w=380  h=900                                     -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <control type="group">
                <left>0</left><top>0</top><width>380</width><height>900</height>

                <!-- ─── POSTER  380×570  exact 2:3 ratio ─── -->
                <control type="image">
                    <left>0</left><top>5</top><width>380</width><height>570</height>
                    <texture>$INFO[Window.Property(item.poster)]</texture>
                    <aspectratio align="center">keep</aspectratio>
                    <fadetime>400</fadetime>
                </control>

                <!-- Title — gold -->
                <control type="label">
                    <left>16</left><top>582</top><width>300</width><height>60</height>
                    <font>font24_title</font>
                    <textcolor>FFC9A84C</textcolor>
                    <label>$INFO[Window.Property(item.title)]</label>
                    <wrapmultiline>true</wrapmultiline>
                </control>

                <!-- Year -->
                <control type="label">
                    <left>16</left><top>648</top><width>348</width><height>22</height>
                    <font>font12</font>
                    <textcolor>FFCCCCCC</textcolor>
                    <label>$INFO[Window.Property(item.year)]</label>
                </control>

                <!-- Separator -->
                <control type="image">
                    <left>16</left><top>678</top><width>348</width><height>1</height>
                    <texture colordiffuse="FF333333">special://home/addons/plugin.video.littletigre/resources/media/white.png</texture>
                </control>

                <!-- Plot -->
                <control type="textbox">
                    <left>16</left><top>688</top><width>348</width><height>178</height>
                    <font>font10</font>
                    <textcolor>FFDDDDDD</textcolor>
                    <label>$INFO[Window.Property(item.plot)]</label>
                    <autoscroll delay="4000" time="5000" repeat="6000">true</autoscroll>
                </control>

                <!-- Branding -->
                <control type="label">
                    <left>0</left><top>882</top><width>380</width><height>16</height>
                    <font>font10</font>
                    <textcolor>22FFFFFF</textcolor>
                    <align>center</align>
                    <label>Little Fox</label>
                </control>

                <!-- Right border -->
                <control type="image">
                    <left>379</left><top>0</top><width>1</width><height>900</height>
                    <texture colordiffuse="FF1A1A1A">special://home/addons/plugin.video.littletigre/resources/media/white.png</texture>
                </control>

            </control>
            <!-- END SIDEBAR -->

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- RIGHT SERVERS PANE  x=380  w=1220  h=900                       -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <control type="group">
                <left>380</left><top>0</top><width>1220</width><height>900</height>

                <!-- ─── HEADER  h=56 ─── -->
                <control type="label">
                    <left>22</left><top>18</top><width>1168</width><height>20</height>
                    <font>font10</font>
                    <textcolor>FF666666</textcolor>
                    <label>SELECT SERVER  ·  $INFO[Window.Property(stream_count)]</label>
                </control>

                <!-- Header separator -->
                <control type="image">
                    <left>0</left><top>56</top><width>1220</width><height>1</height>
                    <texture colordiffuse="FF111111">special://home/addons/plugin.video.littletigre/resources/media/white.png</texture>
                </control>

                <!-- ─── SCROLLBAR ─── -->
                <control type="scrollbar" id="1111">
                    <left>1206</left><top>57</top><width>14</width><height>843</height>
                    <onleft>1000</onleft>
                    <onright>2999</onright>
                    <showonepage>false</showonepage>
                    <texturesliderbackground colordiffuse="FF444444">special://home/addons/plugin.video.littletigre/resources/media/white.png</texturesliderbackground>
                    <texturesliderbar colordiffuse="AAC9A84C">special://home/addons/plugin.video.littletigre/resources/media/scrollv.png</texturesliderbar>
                    <texturesliderbarfocus colordiffuse="FFC9A84C">special://home/addons/plugin.video.littletigre/resources/media/scrollv.png</texturesliderbarfocus>
                    <orientation>vertical</orientation>
                </control>

                <!-- ─── SERVER LIST ─── -->
                <control type="list" id="1000">
                    <left>0</left><top>57</top><width>1206</width><height>843</height>
                    <onleft>1000</onleft>
                    <onright>1111</onright>
                    <onup>1000</onup>
                    <ondown>1000</ondown>
                    <pagecontrol>1111</pagecontrol>
                    <scrolltime>120</scrolltime>

                    <!-- ════════════════════════════════════════════════════ -->
                    <!-- FOCUSED CARD  h=120  w=1206                         -->
                    <!-- ════════════════════════════════════════════════════ -->
                    <focusedlayout height="120" width="1206">

                        <control type="image">
                            <left>0</left><top>0</top><width>1206</width><height>119</height>
                            <texture>special://home/addons/plugin.video.littletigre/resources/media/bg.png</texture>
                        </control>
                        <!-- Gold wash overlay -->
                        <control type="image">
                            <left>0</left><top>0</top><width>1206</width><height>119</height>
                            <texture colordiffuse="18C9A84C">special://home/addons/plugin.video.littletigre/resources/media/white.png</texture>
                        </control>
                        <!-- Gold top edge -->
                        <control type="image">
                            <left>0</left><top>0</top><width>1206</width><height>1</height>
                            <texture colordiffuse="AAC9A84C">special://home/addons/plugin.video.littletigre/resources/media/white.png</texture>
                        </control>
                        <!-- Gold bottom edge -->
                        <control type="image">
                            <left>0</left><top>119</top><width>1206</width><height>1</height>
                            <texture colordiffuse="55C9A84C">special://home/addons/plugin.video.littletigre/resources/media/white.png</texture>
                        </control>

                        <!-- ── LEFT ACCENT BAR: green=1080p, amber=720p/HD, slate=lower ── -->
                        <control type="image">
                            <left>0</left><top>1</top><width>4</width><height>118</height>
                            <texture colordiffuse="FF22C55E">special://home/addons/plugin.video.littletigre/resources/media/white.png</texture>
                            <visible>String.IsEqual(ListItem.Property(cached_status),instant)</visible>
                        </control>
                        <control type="image">
                            <left>0</left><top>1</top><width>4</width><height>118</height>
                            <texture colordiffuse="FFFFB347">special://home/addons/plugin.video.littletigre/resources/media/white.png</texture>
                            <visible>String.IsEqual(ListItem.Property(cached_status),cached)</visible>
                        </control>
                        <control type="image">
                            <left>0</left><top>1</top><width>4</width><height>118</height>
                            <texture colordiffuse="FF1E1E1E">special://home/addons/plugin.video.littletigre/resources/media/white.png</texture>
                            <visible>String.IsEqual(ListItem.Property(cached_status),uncached)</visible>
                        </control>

                        <!-- ── QUALITY BADGE (top=18 h=26) ── -->
                        <control type="image">
                            <left>12</left><top>18</top><width>108</width><height>26</height>
                            <texture colordiffuse="1A4A9EFF">special://home/addons/plugin.video.littletigre/resources/media/white.png</texture>
                            <visible>String.IsEqual(ListItem.Property(resolution),1080p)</visible>
                        </control>
                        <control type="image">
                            <left>12</left><top>18</top><width>108</width><height>26</height>
                            <texture colordiffuse="1AB45AFF">special://home/addons/plugin.video.littletigre/resources/media/white.png</texture>
                            <visible>String.IsEqual(ListItem.Property(resolution),720p)</visible>
                        </control>
                        <control type="image">
                            <left>12</left><top>18</top><width>108</width><height>26</height>
                            <texture colordiffuse="10444444">special://home/addons/plugin.video.littletigre/resources/media/white.png</texture>
                            <visible>!String.IsEqual(ListItem.Property(resolution),1080p)+!String.IsEqual(ListItem.Property(resolution),720p)</visible>
                        </control>
                        <control type="label">
                            <left>12</left><top>18</top><width>108</width><height>26</height>
                            <font>font10</font><textcolor>FF4A9EFF</textcolor>
                            <align>center</align><aligny>center</aligny>
                            <label>$INFO[ListItem.Property(badge_res)]</label>
                            <visible>String.IsEqual(ListItem.Property(resolution),1080p)</visible>
                        </control>
                        <control type="label">
                            <left>12</left><top>18</top><width>108</width><height>26</height>
                            <font>font10</font><textcolor>FFB45AFF</textcolor>
                            <align>center</align><aligny>center</aligny>
                            <label>$INFO[ListItem.Property(badge_res)]</label>
                            <visible>String.IsEqual(ListItem.Property(resolution),720p)</visible>
                        </control>
                        <control type="label">
                            <left>12</left><top>18</top><width>108</width><height>26</height>
                            <font>font10</font><textcolor>FFCCCCCC</textcolor>
                            <align>center</align><aligny>center</aligny>
                            <label>$INFO[ListItem.Property(badge_res)]</label>
                            <visible>!String.IsEqual(ListItem.Property(resolution),1080p)+!String.IsEqual(ListItem.Property(resolution),720p)</visible>
                        </control>

                        <!-- ── PROVIDER BADGE (top=52 h=26) ── -->
                        <control type="image">
                            <left>12</left><top>52</top><width>108</width><height>26</height>
                            <texture colordiffuse="154A9EFF">special://home/addons/plugin.video.littletigre/resources/media/white.png</texture>
                        </control>
                        <control type="label">
                            <left>12</left><top>52</top><width>108</width><height>26</height>
                            <font>font10</font><textcolor>FF4A9EFF</textcolor>
                            <align>center</align><aligny>center</aligny>
                            <label>$INFO[ListItem.Property(badge_svc)]</label>
                        </control>

                        <!-- ── PROVIDER NAME small (top=88 h=22) ── -->
                        <control type="label">
                            <left>12</left><top>88</top><width>108</width><height>22</height>
                            <font>font10</font><textcolor>FFAAAAAA</textcolor>
                            <align>center</align>
                            <label>$INFO[ListItem.Property(provider)]</label>
                        </control>

                        <!-- Column separator -->
                        <control type="image">
                            <left>128</left><top>10</top><width>1</width><height>100</height>
                            <texture colordiffuse="FF1E1E1E">special://home/addons/plugin.video.littletigre/resources/media/white.png</texture>
                        </control>

                        <!-- ── SERVER NAME (top=18 h=30) ── -->
                        <control type="label">
                            <left>140</left><top>18</top><width>1052</width><height>30</height>
                            <font>font13_title</font><textcolor>FFFFFFFF</textcolor>
                            <label>$INFO[ListItem.Property(title_clean)]</label>
                            <scroll>true</scroll>
                        </control>

                        <!-- ── TAGS: host + lang chips (top=54 h=26) ── -->
                        <control type="label">
                            <left>140</left><top>54</top><width>1052</width><height>26</height>
                            <font>font12</font><textcolor>FFDDDDDD</textcolor>
                            <label>$INFO[ListItem.Property(tags_line)]</label>
                        </control>

                        <!-- ── DETAIL: full language name (top=88 h=22) ── -->
                        <control type="label">
                            <left>140</left><top>88</top><width>1052</width><height>22</height>
                            <font>font10</font><textcolor>FFCCCCCC</textcolor>
                            <label>$INFO[ListItem.Property(detail_line)]</label>
                        </control>

                    </focusedlayout>

                    <!-- ════════════════════════════════════════════════════ -->
                    <!-- UNFOCUSED CARD  h=120  w=1206                       -->
                    <!-- ════════════════════════════════════════════════════ -->
                    <itemlayout height="120" width="1206">

                        <control type="image">
                            <left>0</left><top>0</top><width>1206</width><height>119</height>
                            <texture>special://home/addons/plugin.video.littletigre/resources/media/bg.png</texture>
                        </control>
                        <!-- Bottom border -->
                        <control type="image">
                            <left>0</left><top>119</top><width>1206</width><height>1</height>
                            <texture colordiffuse="FF111111">special://home/addons/plugin.video.littletigre/resources/media/white.png</texture>
                        </control>

                        <!-- ── LEFT ACCENT BAR (dimmed) ── -->
                        <control type="image">
                            <left>0</left><top>1</top><width>4</width><height>118</height>
                            <texture colordiffuse="8822C55E">special://home/addons/plugin.video.littletigre/resources/media/white.png</texture>
                            <visible>String.IsEqual(ListItem.Property(cached_status),instant)</visible>
                        </control>
                        <control type="image">
                            <left>0</left><top>1</top><width>4</width><height>118</height>
                            <texture colordiffuse="88FFB347">special://home/addons/plugin.video.littletigre/resources/media/white.png</texture>
                            <visible>String.IsEqual(ListItem.Property(cached_status),cached)</visible>
                        </control>
                        <control type="image">
                            <left>0</left><top>1</top><width>4</width><height>118</height>
                            <texture colordiffuse="FF111111">special://home/addons/plugin.video.littletigre/resources/media/white.png</texture>
                            <visible>String.IsEqual(ListItem.Property(cached_status),uncached)</visible>
                        </control>

                        <!-- ── QUALITY BADGE (dimmed) ── -->
                        <control type="image">
                            <left>12</left><top>18</top><width>108</width><height>26</height>
                            <texture colordiffuse="0A4A9EFF">special://home/addons/plugin.video.littletigre/resources/media/white.png</texture>
                            <visible>String.IsEqual(ListItem.Property(resolution),1080p)</visible>
                        </control>
                        <control type="image">
                            <left>12</left><top>18</top><width>108</width><height>26</height>
                            <texture colordiffuse="0AB45AFF">special://home/addons/plugin.video.littletigre/resources/media/white.png</texture>
                            <visible>String.IsEqual(ListItem.Property(resolution),720p)</visible>
                        </control>
                        <control type="image">
                            <left>12</left><top>18</top><width>108</width><height>26</height>
                            <texture colordiffuse="08444444">special://home/addons/plugin.video.littletigre/resources/media/white.png</texture>
                            <visible>!String.IsEqual(ListItem.Property(resolution),1080p)+!String.IsEqual(ListItem.Property(resolution),720p)</visible>
                        </control>
                        <control type="label">
                            <left>12</left><top>18</top><width>108</width><height>26</height>
                            <font>font10</font><textcolor>FF4A9EFF</textcolor>
                            <align>center</align><aligny>center</aligny>
                            <label>$INFO[ListItem.Property(badge_res)]</label>
                            <visible>String.IsEqual(ListItem.Property(resolution),1080p)</visible>
                        </control>
                        <control type="label">
                            <left>12</left><top>18</top><width>108</width><height>26</height>
                            <font>font10</font><textcolor>FFB45AFF</textcolor>
                            <align>center</align><aligny>center</aligny>
                            <label>$INFO[ListItem.Property(badge_res)]</label>
                            <visible>String.IsEqual(ListItem.Property(resolution),720p)</visible>
                        </control>
                        <control type="label">
                            <left>12</left><top>18</top><width>108</width><height>26</height>
                            <font>font10</font><textcolor>FFCCCCCC</textcolor>
                            <align>center</align><aligny>center</aligny>
                            <label>$INFO[ListItem.Property(badge_res)]</label>
                            <visible>!String.IsEqual(ListItem.Property(resolution),1080p)+!String.IsEqual(ListItem.Property(resolution),720p)</visible>
                        </control>

                        <!-- ── PROVIDER BADGE (dimmed) ── -->
                        <control type="image">
                            <left>12</left><top>52</top><width>108</width><height>26</height>
                            <texture colordiffuse="0A4A9EFF">special://home/addons/plugin.video.littletigre/resources/media/white.png</texture>
                        </control>
                        <control type="label">
                            <left>12</left><top>52</top><width>108</width><height>26</height>
                            <font>font10</font><textcolor>FF4A9EFF</textcolor>
                            <align>center</align><aligny>center</aligny>
                            <label>$INFO[ListItem.Property(badge_svc)]</label>
                        </control>

                        <!-- ── PROVIDER NAME small ── -->
                        <control type="label">
                            <left>12</left><top>88</top><width>108</width><height>22</height>
                            <font>font10</font><textcolor>FFAAAAAA</textcolor>
                            <align>center</align>
                            <label>$INFO[ListItem.Property(provider)]</label>
                        </control>

                        <!-- Column separator -->
                        <control type="image">
                            <left>128</left><top>10</top><width>1</width><height>100</height>
                            <texture colordiffuse="FF111111">special://home/addons/plugin.video.littletigre/resources/media/white.png</texture>
                        </control>

                        <!-- ── SERVER NAME ── -->
                        <control type="label">
                            <left>140</left><top>18</top><width>1052</width><height>30</height>
                            <font>font13_title</font><textcolor>FFFFFFFF</textcolor>
                            <label>$INFO[ListItem.Property(title_clean)]</label>
                        </control>

                        <!-- ── TAGS ── -->
                        <control type="label">
                            <left>140</left><top>54</top><width>1052</width><height>26</height>
                            <font>font12</font><textcolor>FFDDDDDD</textcolor>
                            <label>$INFO[ListItem.Property(tags_line)]</label>
                        </control>

                        <!-- ── DETAIL ── -->
                        <control type="label">
                            <left>140</left><top>88</top><width>1052</width><height>22</height>
                            <font>font10</font><textcolor>FFCCCCCC</textcolor>
                            <label>$INFO[ListItem.Property(detail_line)]</label>
                        </control>

                    </itemlayout>
                </control>
                <!-- END LIST -->

            </control>
            <!-- END SERVERS PANE -->

        </control>
        <!-- END DIALOG -->

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- CLOSE BUTTON                                                        -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <control type="button" id="2999">
            <left>1712</left><top>104</top><width>40</width><height>40</height>
            <font>font12</font>
            <textcolor>FF888888</textcolor>
            <focusedcolor>FF000000</focusedcolor>
            <texturefocus colordiffuse="FFC9A84C">special://home/addons/plugin.video.littletigre/resources/media/white.png</texturefocus>
            <texturenofocus colordiffuse="22FFFFFF">special://home/addons/plugin.video.littletigre/resources/media/white.png</texturenofocus>
            <label>X</label>
            <onleft>1111</onleft>
            <onright>1000</onright>
            <onup>2999</onup>
            <ondown>1000</ondown>
            <onclick>Close</onclick>
        </control>

    </controls>
</window>
